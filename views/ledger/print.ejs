<!DOCTYPE html>
<html><head>
  <meta charset="UTF-8">
  <title>Ledger - <%= entity.name %></title>
  <style>
    * { box-sizing:border-box; margin:0; padding:0; }
    body { font-family: Arial, Helvetica, sans-serif; font-size: 14px; color:#000; padding: 18mm 14mm; line-height:1.5; }
    .no-print { text-align:center; margin-bottom:14px; }
    .no-print button, .no-print a { padding:8px 22px; margin:0 5px; border:1px solid #000; background:#fff; cursor:pointer; font-size:13px; text-decoration:none; color:#000; font-weight:600; }
    .header { display:flex; align-items:center; gap:24px; border-bottom:3px solid #000; padding-bottom:14px; margin-bottom:18px; }
    .logo-box { width:140px; height:140px; flex-shrink:0; display:flex; align-items:center; justify-content:center; }
    .logo-box img { max-width:100%; max-height:100%; object-fit:contain; }
    .company-block { flex:1; text-align:center; }
    .company-name { font-size:32px; font-weight:900; letter-spacing:3px; text-transform:uppercase; }
    .doc-title { font-size:18px; font-weight:700; margin-top:6px; letter-spacing:2px; text-transform:uppercase; }

    .party-title { text-align:center; font-size:22px; font-weight:800; text-transform:uppercase; margin:10px 0 6px; letter-spacing:2px; }
    .period { text-align:center; font-size:14px; margin-bottom:14px; font-weight:600; }

    table { width:100%; border-collapse:collapse; border:2px solid #000; margin-bottom:12px; }
    th, td { border:1px solid #000; padding:8px 10px; font-size:14px; }
    thead th { background:#000; color:#fff; font-weight:700; text-transform:uppercase; letter-spacing:1px; text-align:center; }
    tbody td.tr, tbody th.tr { text-align:right; }
    tbody td.fw { font-weight:700; }
    tfoot td { background:#f0f0f0; font-weight:800; font-size:15px; padding:10px; }
    .totals-row td { background:#000; color:#fff; }

    .footer { text-align:center; margin-top:24px; font-size:11px; color:#555; border-top:1px solid #999; padding-top:8px; }
    @media print { .no-print { display:none; } body { padding:10mm 12mm; } }
  </style>
</head><body>
<div class="no-print">
  <button onclick="window.print()">&#128438; Print</button>
  <a href="javascript:history.back()">&#8592; Back</a>
</div>
<%
  var scope = (entity && entity.account_scope) ? entity.account_scope : 'plastic_markaz';
  var bizName = (typeof accountName === 'function') ? accountName(scope) : 'PLASTIC MARKAZ';
  var logoPath = '/Logo.png';
  var totalDebit = 0, totalCredit = 0;
  entries.forEach(function(e){ totalDebit += (e.debit||0); totalCredit += (e.credit||0); });
  var finalBalance = (entity.balance != null) ? Number(entity.balance) : (totalDebit - totalCredit);
%>
<div class="header">
  <div class="logo-box"><img src="<%= logoPath %>" alt="logo"></div>
  <div class="company-block">
    <div class="company-name"><%= bizName %></div>
    <div class="doc-title"><%= entityType === 'customer' ? 'Customer' : 'Vendor' %> Ledger Statement</div>
  </div>
  <div class="logo-box"></div>
</div>

<div class="party-title"><%= entity.name %></div>
<div class="period">Period: <strong><%= from || 'Beginning' %></strong> &nbsp;to&nbsp; <strong><%= to || 'Present' %></strong></div>

<table>
  <thead>
    <tr><th style="width:14%">Date</th><th>Description</th><th style="width:14%">Debit</th><th style="width:14%">Credit</th><th style="width:16%">Balance</th></tr>
  </thead>
  <tbody>
    <% var run = 0; entries.forEach(function(e){
        run += (Number(e.debit)||0) - (Number(e.credit)||0);
    %>
      <tr>
        <td><%= e.txn_date %></td>
        <td><%= e.description || '-' %></td>
        <td class="tr"><%= (Number(e.debit)||0) > 0 ? Number(e.debit).toFixed(2) : '-' %></td>
        <td class="tr"><%= (Number(e.credit)||0) > 0 ? Number(e.credit).toFixed(2) : '-' %></td>
        <td class="tr fw"><%= run.toFixed(2) %></td>
      </tr>
    <% }); %>
    <% if (!entries.length) { %>
      <tr><td colspan="5" style="text-align:center; padding:18px;">No transactions in selected period.</td></tr>
    <% } %>
  </tbody>
  <tfoot>
    <tr class="totals-row">
      <td colspan="2" class="tr">TOTALS</td>
      <td class="tr">PKR <%= totalDebit.toFixed(2) %></td>
      <td class="tr">PKR <%= totalCredit.toFixed(2) %></td>
      <td class="tr">PKR <%= finalBalance.toFixed(2) %></td>
    </tr>
  </tfoot>
</table>

<div class="footer"><%= bizName %> &mdash; Generated <%= new Date().toLocaleString('en-GB') %></div>
<script>window.onload = function(){ if(!window.location.search.includes('noprint')) window.print(); };</script>
</body></html>
