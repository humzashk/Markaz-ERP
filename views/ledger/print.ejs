<!DOCTYPE html>
<html><head>
  <meta charset="UTF-8">
  <title>Ledger - <%= entity.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { font-size: 12px; padding: 20px; }
    .company { font-size: 24px; font-weight: 700; }
    @media print { .no-print { display: none; } }
  </style>
</head><body>
<div class="no-print mb-3"><button onclick="window.print()" class="btn btn-primary btn-sm"><i class="bi bi-printer"></i> Print</button></div>
<div class="text-center mb-3">
  <div class="company">PLASTIC MARKAZ</div>
  <div><%= entityType === 'customer' ? 'Customer' : 'Vendor' %> Ledger</div>
</div>
<div class="row mb-3">
  <div class="col-6"><strong>Name:</strong> <%= entity.name %><br><strong>Phone:</strong> <%= entity.phone || '-' %><br><strong>City:</strong> <%= entity.city || '-' %></div>
  <div class="col-6 text-end"><% if (from || to) { %><strong>Period:</strong> <%= from || 'Start' %> to <%= to || 'Present' %><% } %><br><strong>Balance:</strong> Rs. <%= entity.balance.toFixed(2) %></div>
</div>
<table class="table table-bordered table-sm">
  <thead class="table-dark"><tr><th>Date</th><th>Description</th><th class="text-end">Debit</th><th class="text-end">Credit</th><th class="text-end">Balance</th></tr></thead>
  <tbody>
    <% entries.forEach(e => { %>
    <tr>
      <td><%= e.txn_date %></td>
      <td><%= e.description || '-' %></td>
      <td class="text-end"><%= e.debit > 0 ? e.debit.toFixed(2) : '-' %></td>
      <td class="text-end"><%= e.credit > 0 ? e.credit.toFixed(2) : '-' %></td>
      <td class="text-end fw-bold"><%= e.balance.toFixed(2) %></td>
    </tr>
    <% }) %>
  </tbody>
  <tfoot><tr class="fw-bold"><td colspan="4" class="text-end">Current Balance:</td><td class="text-end">Rs. <%= entity.balance.toFixed(2) %></td></tr></tfoot>
</table>
<div class="text-center text-muted mt-3"><small>PLASTIC MARKAZ - Generated on <%= new Date().toLocaleDateString() %></small></div>
<script>window.onload = () => window.print();</script>
</body></html>
