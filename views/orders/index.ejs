<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-cart"></i> Orders</h2>
  <a href="/orders/add" class="btn btn-primary btn-lg"><i class="bi bi-plus-circle"></i> New Order</a>
</div>

<div class="card">
  <div class="card-header">
    <form method="get" class="d-flex gap-2">
      <input type="text" name="search" class="form-control" placeholder="Search order no or customer name..." value="<%= search %>">
      <button type="submit" class="btn btn-outline-secondary"><i class="bi bi-search"></i> Search</button>
      <% if (search) { %><a href="/orders" class="btn btn-outline-secondary">Clear</a><% } %>
    </form>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead><tr>
          <th>Order #</th><th>Customer</th><th>Order Date</th><th>Delivery Date</th><th>Amount</th><th>Actions</th>
        </tr></thead>
        <tbody>
          <% orders.forEach(o => { %>
          <tr>
            <td><strong><%= o.order_no %></strong></td>
            <td><%= o.customer_name %></td>
            <td><%= formatDate(o.order_date) %></td>
            <td><%= formatDate(o.delivery_date) %></td>
            <td class="fw-bold text-end"><%= formatCurrency(o.total) %></td>
            <td>
              <a href="/orders/view/<%= o.id %>" class="btn btn-sm btn-info"><i class="bi bi-eye"></i> View</a>
              <a href="/orders/print/<%= o.id %>" target="_blank" class="btn btn-sm btn-secondary"><i class="bi bi-printer"></i> Print</a>
              <a href="/orders/edit/<%= o.id %>" class="btn btn-sm btn-warning"><i class="bi bi-pencil"></i> Edit</a>
            </td>
          </tr>
          <% }) %>
          <% if (!orders.length) { %><tr><td colspan="6" class="text-center text-muted py-4">No orders found</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
