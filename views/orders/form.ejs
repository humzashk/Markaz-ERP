<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-cart-plus"></i> <%= edit ? 'Edit Order' : 'New Order' %></h2>
  <a href="/orders" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>
<form method="post" action="/orders/<%= edit ? 'edit/'+order.id : 'add' %>">
<%- include("../partials/form-error") %>
  <div class="row g-3 mb-3">
    <div class="col-md-4">
      <div class="card">
        <div class="card-header">Order Details</div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label fw-bold">Account *</label>
            <select name="account_scope" class="form-select" required>
              <% var _curScope = (order && order.account_scope) || 'plastic_markaz'; %>
              <option value="plastic_markaz"  <%= _curScope === 'plastic_markaz'  ? 'selected' : '' %>>Plastic Markaz</option>
              <option value="wings_furniture" <%= _curScope === 'wings_furniture' ? 'selected' : '' %>>Wings Furniture</option>
              <option value="cooler"          <%= _curScope === 'cooler'          ? 'selected' : '' %>>Cooler</option>
            </select>
            <div class="form-text">This order will be booked under the selected business account.</div>
          </div>
          <div class="mb-3">
            <label class="form-label">Customer *</label>
            <select name="customer_id" class="form-select" required>
              <option value="">Select Customer</option>
              <% customers.forEach(c => { %><option value="<%= c.id %>" <%= (order && c.id==order.customer_id)?'selected':'' %>><%= c.name %></option><% }) %>
            </select>
          </div>
          <div class="mb-3"><label class="form-label">Order Date *</label><input type="date" name="order_date" class="form-control" value="<%= order?.order_date || new Date().toISOString().split('T')[0] %>" required></div>
          <div class="mb-3"><label class="form-label">Delivery Date *</label><input type="date" name="delivery_date" class="form-control" value="<%= order?.delivery_date || today %>" required></div>
          <div class="mb-3"><label class="form-label fw-bold">Warehouse *</label>
            <select name="warehouse_id" class="form-select" required>
              <option value="">Select Warehouse</option>
              <% warehouses?.forEach(w => { %><option value="<%= w.id %>" <%= (order && w.id==order.warehouse_id)?'selected':'' %>><%= w.name %></option><% }) %>
            </select>
          </div>
          <div class="mb-3"><label class="form-label">Bilty #</label><input type="text" name="bilty_no" id="bilty_no" class="form-control" value="<%= order?.bilty_no || '' %>" placeholder="e.g., BLT-0001"></div>
          <div class="mb-3"><label class="form-label">Transport <span id="transportRequired" class="text-danger d-none">*</span></label>
            <div class="input-group">
              <select name="transport_id" id="transport_id" class="form-select">
                <option value="">— None —</option>
                <% (typeof transports !== 'undefined' ? transports : []).forEach(t => { %>
                  <option value="<%= t.id %>" <%= (order && order.transport_id==t.id)?'selected':'' %>><%= t.name %></option>
                <% }) %>
              </select>
              <a href="/transports/add" target="_blank" class="btn btn-outline-secondary" title="New transport"><i class="bi bi-plus"></i></a>
            </div>
            <input type="hidden" name="transporter_name" value="<%= order?.transporter_name || '' %>">
          </div>
          <div class="mb-3"><label class="form-label">Notes</label><textarea name="notes" class="form-control" rows="2"><%= order?.notes || '' %></textarea></div>
        </div>
      </div>
    </div>
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">
          <span>Order Items</span>
          <small class="text-muted ms-2">Commission per item</small>
        </div>
        <div id="stockInfo" class="alert alert-info d-none" style="margin: 12px;">
          <strong>Stock Available:</strong> <span id="stockQty">-</span> pcs
          <span id="stockMeter"></span>
        </div>
        <div class="card-body">
          <%- include('../partials/item-rows', { hideDiscount: true }) %>
          <div class="text-end border-top pt-3">
            <div class="d-flex justify-content-end gap-4 mb-2">
              <span class="text-muted">Subtotal:</span><strong id="subtotal">0.00</strong>
            </div>
            <div class="d-flex justify-content-end gap-4 mb-2">
              <span class="fs-5 fw-bold">TOTAL:</span><strong class="fs-5 text-success" id="grandTotal">0.00</strong>
            </div>
            <div class="d-flex justify-content-end gap-4 mb-2 text-info">
              <span>Less Commission (<span id="commPctDisp">0</span>%):</span><strong id="commAmount">0.00</strong>
            </div>
            <div class="d-flex justify-content-end gap-4 mb-2 text-secondary">
              <span>Less Discount:</span><strong id="discAmount">0.00</strong>
            </div>
            <div class="d-flex justify-content-end gap-4 border-top pt-2">
              <span class="fs-5 fw-bold text-warning">NET AMOUNT:</span><strong class="fs-5 text-warning" id="grossAmount">0.00</strong>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary btn-lg px-5"><i class="bi bi-save"></i> <%= edit ? 'Update Order' : 'Create Order' %></button>
    <a href="/orders" class="btn btn-outline-secondary btn-lg">Cancel</a>
  </div>
</form>

<script>
function onProductChange(sel) {
  const opt = sel.options[sel.selectedIndex];
  if (!opt.value) { document.getElementById('stockInfo').classList.add('d-none'); return; }
  const stock = opt.dataset.stock;
  const row = sel.closest('tr');
  if (row) {
    row.querySelector('.packaging-input').value = opt.dataset.packaging || 1;
    row.querySelector('.rate-input').value = opt.dataset.rate || 0;
    row.querySelector('.commission-input').value = opt.dataset.commission || 0;
  }
  document.getElementById('stockQty').textContent = stock;
  document.getElementById('stockInfo').classList.remove('d-none');
  calcRow(row?.querySelector('.pkg-input'));
}

function calcRow(inp) {
  if (!inp) return;
  const row = inp.closest('tr');
  const pkg = parseInt(row.querySelector('.pkg-input').value) || 0;
  const pcs = parseInt(row.querySelector('.packaging-input').value) || 1;
  const qty = pkg * pcs;
  const rate = parseFloat(row.querySelector('.rate-input').value) || 0;
  row.querySelector('.qty-input').value = qty;
  row.querySelector('.row-amount').textContent = (qty * rate).toFixed(2);
  calcTotal();
}

function onQtyInput(inp) { calcRow(inp); }

function addItemRow() {
  const tbody = document.getElementById('itemsBody');
  const row = document.createElement('tr');
  const idx = tbody.children.length + 1;
  row.innerHTML = `
    <td class="text-muted">${idx}</td>
    <td><select name="product_id" class="form-select product-select" onchange="onProductChange(this)"><option>Select Product</option><% products.forEach(p => { %><option value="<%= p.id %>" data-packaging="<%= p.qty_per_pack %>" data-rate="<%= p.selling_price %>" data-commission="<%= p.default_commission_rate %>" data-stock="<%= p.stock %>"><%= p.name %> · Stock: <%= p.stock %></option><% }) %></select></td>
    <td><input type="number" name="packages" class="form-control pkg-input text-center" min="0" oninput="calcRow(this)"></td>
    <td><input type="number" name="packaging" class="form-control packaging-input text-center" min="1" value="1" oninput="calcRow(this)"></td>
    <td><input type="number" name="quantity" class="form-control qty-input text-center" min="0" oninput="calcRow(this)"></td>
    <td><input type="number" name="rate" class="form-control rate-input text-center" min="0" step="0.01" oninput="calcTotal()"></td>
    <td><input type="number" name="discount_per_pack" class="form-control discount-input text-center" min="0" step="0.01" value="0" oninput="calcTotal()"></td>
    <td><input type="number" name="commission_pct" class="form-control commission-input text-center" min="0" step="0.01" max="100" value="0" oninput="calcTotal()"></td>
    <td class="text-center"><span class="row-amount fw-bold text-success">0.00</span></td>
    <td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRow(this)"><i class="bi bi-x"></i></button></td>
  `;
  tbody.appendChild(row);
}

function removeRow(btn) {
  btn.closest('tr').remove();
  calcTotal();
}

function calcTotal() {
  let subtotal = 0;
  let totalCommission = 0;
  let totalDiscount = 0;
  document.querySelectorAll('tbody tr').forEach(row => {
    const qty = parseFloat(row.querySelector('.qty-input')?.value) || 0;
    const rate = parseFloat(row.querySelector('.rate-input')?.value) || 0;
    const discPack = parseFloat(row.querySelector('.discount-input')?.value) || 0;
    const commPct = parseFloat(row.querySelector('.commission-input')?.value) || 0;
    const amount = qty * rate;
    const comm = amount * commPct / 100;
    const disc = qty * discPack; // discount per pack * qty
    subtotal += amount;
    totalCommission += comm;
    totalDiscount += disc;
  });
  const gross = subtotal - totalCommission - totalDiscount;
  document.getElementById('subtotal').textContent = subtotal.toFixed(2);
  document.getElementById('commPctDisp').textContent = (totalCommission > 0 ? 'Item-wise' : '0');
  document.getElementById('commAmount').textContent = totalCommission.toFixed(2);
  document.getElementById('grandTotal').textContent = subtotal.toFixed(2);
  document.getElementById('discAmount').textContent = totalDiscount.toFixed(2);
  document.getElementById('grossAmount').textContent = gross.toFixed(2);
}

document.addEventListener('DOMContentLoaded', () => {
  calcTotal();
  // Bilty → Transport required toggle
  const bilty = document.getElementById('bilty_no');
  const trans = document.getElementById('transport_id');
  const star = document.getElementById('transportRequired');
  function syncTransportReq() {
    if (!bilty || !trans) return;
    const has = (bilty.value || '').trim().length > 0;
    trans.required = has;
    if (star) star.classList.toggle('d-none', !has);
  }
  if (bilty) bilty.addEventListener('input', syncTransportReq);
  syncTransportReq();
});
</script>
<%- include('../partials/footer') %>
