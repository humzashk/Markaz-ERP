<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Delivery Challan - <%= order.order_no %></title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family: Arial, 'Helvetica', sans-serif; font-size: 12px; color:#000; background:#fff; line-height:1.4; }
.page { width:210mm; min-height:297mm; margin:0 auto; padding:12mm 14mm 10mm; display:flex; flex-direction:column; }
.no-print { text-align:center; padding:10px 0 14px; }
.no-print button, .no-print a { padding:8px 22px; margin:0 5px; border:1px solid #000; background:#fff; color:#000; cursor:pointer; font-size:13px; text-decoration:none; display:inline-block; font-weight:600; }

.header { display:flex; align-items:center; justify-content:flex-start; gap:16px; border-bottom:2px solid #000; padding-bottom:10px; margin-bottom:10px; }
.header .logo-box { width:140px; height:140px; flex-shrink:0; display:flex; align-items:center; justify-content:center; padding:4px; background:#fff; }
.header .logo-box img { max-width:100%; max-height:100%; object-fit:contain; filter: grayscale(100%); display:block; }
.header .company-block { flex:1; text-align:center; }
.header .spacer-right { width:70px; flex-shrink:0; }
.company-name { font-size:24px; font-weight:900; letter-spacing:2px; text-transform:uppercase; }
.company-tagline { font-size:11px; margin-top:2px; }
.account-tag { font-size:10px; font-weight:700; margin-top:4px; letter-spacing:1px; text-transform:uppercase; border:1px solid #000; display:inline-block; padding:2px 8px; }

.meta-row { display:grid; grid-template-columns: 1fr auto 1fr; align-items:center; border:1px solid #000; padding:8px 10px; margin-bottom:8px; gap:12px; }
.meta-title { text-align:center; font-size:16px; font-weight:800; letter-spacing:2.5px; text-transform:uppercase; white-space:nowrap; }
.meta-label { font-weight:700; }

.party-row { display:flex; justify-content:space-between; align-items:flex-start; border:1px solid #000; padding:8px 10px; margin-bottom:10px; font-size:12px; }
.party-name { font-size:14px; font-weight:800; text-transform:uppercase; margin-top:2px; }

table.items { width:100%; border-collapse:collapse; border:1px solid #000; }
table.items th, table.items td { border:1px solid #000; padding:6px 7px; font-size:11px; }
table.items th { background:#000; color:#fff; font-weight:700; text-transform:uppercase; letter-spacing:1px; text-align:center; }
table.items th.desc { text-align:left; }
.tc { text-align:center; }
.tr { text-align:right; }
.fw { font-weight:700; }
.qty-detail { font-size:10px; color:#333; }

table.items tbody tr.total-row td { background:#000; color:#fff; font-weight:800; font-size:12px; }

.spacer { flex:1; min-height:20mm; }
.footer { border-top:1px solid #000; padding-top:10px; margin-top:8px; }
.footer-note { text-align:center; font-size:10px; margin-bottom:20px; font-style:italic; }
.sig-row { display:flex; justify-content:space-between; align-items:flex-end; }
.sig-line { border-top:1px solid #000; min-width:160px; padding-top:6px; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-top:32px; }
.for-company { font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:1px; }

@media print {
  body { background:#fff; -webkit-print-color-adjust:exact; print-color-adjust:exact; }
  .no-print { display:none; }
  .page { margin:0; padding:10mm 12mm 8mm; width:100%; }
}
</style>
</head>
<body>
<%
  var scope = (order && order.account_scope) ? order.account_scope : 'plastic_markaz';
  var bizName = (typeof accountName === 'function') ? accountName(scope) : 'PLASTIC MARKAZ';
  var logoPath = (typeof getLogoPath === 'function') ? getLogoPath(scope) : '/Logo.png';
  var bizAddr = (settings && settings.business_address) || '';
  var bizPhone= (settings && settings.business_phone)  || '';
  var bizCity = (settings && settings.business_city)   || '';

  var totalPkg = items.reduce(function(s,i){ return s + (i.packages||0); }, 0);
  var totalQty = items.reduce(function(s,i){ return s + (i.quantity||0); }, 0);

  var fmtQty = function(v){ return (v||0).toLocaleString('en-US'); };
  var today = new Date().toLocaleDateString('en-GB',{day:'2-digit',month:'2-digit',year:'numeric'});
  var dcNo = (typeof dc !== 'undefined' && dc && dc.dc_no) ? dc.dc_no : 'DC-' + order.order_no;
  var dcDate = (typeof dc !== 'undefined' && dc && dc.dc_date) ? dc.dc_date : today;

  function qtyDetail(item) {
    var p = parseInt(item.packages)||0;
    var pk = parseInt(item.packaging)||1;
    var q = parseInt(item.quantity)||0;
    if (p > 0 && pk > 1) {
      return p + ' cartons × ' + pk + ' pcs = ' + q + ' pcs';
    }
    return q + ' pcs';
  }
%>

<div class="no-print">
  <button onclick="window.print()">&#128438; Print Challan</button>
  <a href="/orders/view/<%= order.id %>">&#8592; Back</a>
</div>

<div class="page">
  <div class="header">
    <% if (logoPath) { %>
      <!-- Logo only, no text -->
      <div style="width:100%; display:flex; justify-content:center; align-items:center;">
        <div class="logo-box">
          <img src="<%= logoPath %>" alt="logo">
        </div>
      </div>
    <% } else { %>
      <!-- No logo: show account name -->
      <div class="company-block">
        <div class="company-name"><%= bizName %></div>
        <% if (bizAddr || bizPhone) { %>
        <div class="company-tagline"><%= bizAddr %><% if(bizCity){ %>, <%= bizCity %><% } %><% if(bizPhone){ %> | Tel: <%= bizPhone %><% } %></div>
        <% } %>
        <div class="account-tag">Account: <%= bizName %></div>
      </div>
    <% } %>
  </div>

  <div class="meta-row">
    <div><span class="meta-label">D/c #:</span> <strong><%= dcNo %></strong></div>
    <div class="meta-title">Delivery Challan</div>
    <div style="text-align:right;"><span class="meta-label">Date:</span> <strong><%= dcDate %></strong></div>
  </div>

  <div class="party-row">
    <div>
      <span style="font-size:11px;">Customer:</span>
      <div class="party-name"><%= order.customer_name %></div>
      <% if (order.customer_phone) { %><div style="font-size:11px;">Tel: <%= order.customer_phone %></div><% } %>
      <% if (order.customer_city) { %><div style="font-size:11px;">City: <%= order.customer_city %></div><% } %>
    </div>
    <div style="text-align:right;">
      <% if (order.notes) { %><div><strong>Note:</strong> <%= order.notes %></div><% } %>
      <div>Order Ref: <strong><%= order.order_no %></strong></div>
    </div>
  </div>

  <table class="items">
    <thead>
      <tr>
        <th style="width:5%">#</th>
        <th class="desc" style="width:40%">Product Description</th>
        <th style="width:12%">Cartons</th>
        <th style="width:10%">Pcs/Ctn</th>
        <th style="width:33%">Total Qty</th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach(function(item, i) { %>
      <tr>
        <td class="tc"><%= i+1 %></td>
        <td class="fw"><%= item.product_name %></td>
        <td class="tc"><%= fmtQty(item.packages || 0) %></td>
        <td class="tc"><%= item.packaging || 1 %></td>
        <td class="fw"><%= qtyDetail(item) %></td>
      </tr>
      <% }); %>
      <% for(var r = items.length; r < 6; r++) { %>
      <tr style="height:24px;"><td></td><td></td><td></td><td></td><td></td></tr>
      <% } %>
      <tr class="total-row">
        <td colspan="2" class="tr" style="padding-right:14px;">GRAND TOTAL</td>
        <td class="tc"><%= fmtQty(totalPkg) %> ctn</td>
        <td class="tc">&mdash;</td>
        <td class="fw"><%= fmtQty(totalPkg) %> cartons = <%= fmtQty(totalQty) %> pcs</td>
      </tr>
    </tbody>
  </table>

  <div class="spacer"></div>

  <div class="footer">
    <div class="footer-note">All items received in good condition.</div>
    <div class="sig-row">
      <div><div class="sig-line">Receiver's Signature</div></div>
      <div style="text-align:right;">
        <div class="for-company">For: <%= bizName %></div>
        <div class="sig-line" style="margin-left:auto;">Authorized Signature</div>
      </div>
    </div>
  </div>
</div>

<script>window.onload = function(){ if(!window.location.search.includes('noprint')) window.print(); };</script>
</body>
</html>
