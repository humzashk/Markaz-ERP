<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Order <%= order.order_no %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; font-size: 14px; color: #333; padding: 20px; }
    .container { max-width: 900px; margin: 0 auto; }
    .header { text-align: center; margin-bottom: 30px; border-bottom: 2px solid #333; padding-bottom: 15px; }
    .company-name { font-size: 24px; font-weight: bold; margin-bottom: 5px; }
    .company-info { font-size: 11px; color: #666; }
    .order-info { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 30px; }
    .info-block { border: 1px solid #ddd; padding: 12px; }
    .info-block h3 { font-size: 12px; font-weight: bold; margin-bottom: 8px; text-transform: uppercase; color: #555; }
    .info-block p { margin: 4px 0; font-size: 13px; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    th { background: #f5f5f5; border: 1px solid #ddd; padding: 10px; text-align: left; font-weight: bold; font-size: 13px; text-transform: uppercase; }
    td { border: 1px solid #ddd; padding: 10px; font-size: 13px; }
    td.text-right { text-align: right; }
    tr.total-row td { background: #f5f5f5; font-weight: bold; }
    .no-print { text-align: center; margin: 20px 0; }
    .no-print button { padding: 10px 20px; margin: 0 5px; background: #333; color: white; border: none; cursor: pointer; font-size: 14px; border-radius: 4px; }
    @page { size: A5; margin: 6mm; }
    @media print {
      .no-print { display: none !important; }
      html, body { padding: 0; width: 148mm; background:#fff; }
      .container { max-width: 138mm !important; }
      body { font-size: 10px; }
      table th, table td { padding: 3px 5px !important; font-size: 9px !important; }
    }
  </style>
</head>
<body>
<div class="no-print">
  <button onclick="window.print()">🖨️ Print Order</button>
  <button onclick="window.close()">✕ Close</button>
</div>
<div class="container">
  <div class="header">
    <div class="company-name"><%= settings.business_name || 'PLASTIC MARKAZ' %></div>
    <div class="company-info">
      <% if (settings.business_address) { %><%= settings.business_address %><br><% } %>
      <% if (settings.business_phone) { %>Phone: <%= settings.business_phone %><% } %>
    </div>
  </div>
  <h2 style="text-align: center; margin-bottom: 20px;">ORDER</h2>
  <div class="order-info">
    <div class="info-block">
      <h3>Order Details</h3>
      <p><strong>Order #:</strong> <%= order.order_no %></p>
      <p><strong>Date:</strong> <%= formatDate(order.order_date) %></p>
      <p><strong>Delivery:</strong> <%= formatDate(order.delivery_date) %></p>
    </div>
    <div class="info-block">
      <h3>Customer</h3>
      <p><strong><%= order.customer_name %></strong></p>
      <% if (order.customer_address) { %><p><%= order.customer_address %></p><% } %>
      <% if (order.customer_city) { %><p><%= order.customer_city %></p><% } %>
      <% if (order.customer_phone) { %><p>Tel: <%= order.customer_phone %></p><% } %>
    </div>
    <div class="info-block">
      <h3>Amount</h3>
      <p style="font-size: 16px; font-weight: bold; color: #d32f2f;"><%= formatCurrency(order.total) %></p>
    </div>
  </div>
  <table>
    <thead><tr>
      <th style="width: 5%">#</th>
      <th style="width: 40%">Product</th>
      <th style="width: 10%; text-align: right;">Packages</th>
      <th style="width: 10%; text-align: right;">Qty/Pack</th>
      <th style="width: 10%; text-align: right;">Qty</th>
      <th style="width: 12%; text-align: right;">Rate</th>
      <th style="width: 13%; text-align: right;">Amount</th>
    </tr></thead>
    <tbody>
      <% items.forEach((item, i) => { %>
      <tr>
        <td><%= i + 1 %></td>
        <td><strong><%= item.product_name %></strong></td>
        <td style="text-align: right;"><%= item.packages || 0 %></td>
        <td style="text-align: right;"><%= item.packaging || 1 %></td>
        <td style="text-align: right;"><strong><%= item.quantity.toLocaleString() %></strong></td>
        <td style="text-align: right;"><%= formatCurrency(item.rate) %></td>
        <td style="text-align: right;"><strong><%= formatCurrency(item.amount) %></strong></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <div style="text-align: right; margin: 30px 0;">
    <table style="width: 300px; margin-left: auto;">
      <tr><td style="border: none;">Subtotal:</td><td style="border: none; text-align: right;"><%= formatCurrency(order.subtotal) %></td></tr>
      <% if (order.commission_amount > 0) { %><tr><td style="border: none;">Commission:</td><td style="border: none; text-align: right; color: red;">-<%= formatCurrency(order.commission_amount) %></td></tr><% } %>
      <tr style="border-top: 2px solid #333;"><td style="border: none; padding: 10px; font-weight: bold;">TOTAL:</td><td style="border: none; padding: 10px; text-align: right; font-weight: bold; font-size: 16px;"><%= formatCurrency(order.total) %></td></tr>
    </table>
  </div>
</div>
<script>window.onload = function() { if (!location.search.includes('noprint')) window.print(); };</script>
</body>
</html>
