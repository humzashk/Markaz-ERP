<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-receipt"></i> Generate Invoice from <%= order.order_no %></h2>
  <a href="/orders/view/<%= order.id %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Order</a>
</div>

<div class="alert alert-info border-0 py-2 mb-3">
  <i class="bi bi-info-circle me-2"></i>
  Review and edit the invoice details below before confirming. All items from the order are pre-filled.
</div>

<form method="POST" action="/orders/generate-invoice/<%= order.id %>">
  <div class="row g-3 mb-3">
    <div class="col-md-3">
      <label class="form-label fw-semibold">Customer</label>
      <input type="text" class="form-control" value="<%= order.customer_name %>" readonly style="background:#f8f9fa">
    </div>
    <div class="col-md-3">
      <label class="form-label fw-semibold">Invoice Date <span class="text-danger">*</span></label>
      <input type="text" name="invoice_date" id="inv_date" class="form-control datepicker" value="<%= today %>" required>
    </div>
    <div class="col-md-3">
      <label class="form-label fw-semibold">Due Date</label>
      <input type="text" name="due_date" id="due_date" class="form-control datepicker" value="<%= dueDateStr %>">
    </div>
    <div class="col-md-3">
      <label class="form-label fw-semibold">Commission %</label>
      <div class="input-group">
        <input type="number" name="commission_pct" id="commission_pct" class="form-control" value="<%= order.commission_pct || 0 %>" step="0.01" min="0" max="100" onchange="calcTotal()">
        <span class="input-group-text">%</span>
      </div>
    </div>
  </div>

  <div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
      <strong>Invoice Items</strong>
      <button type="button" class="btn btn-sm btn-outline-primary" onclick="addInvRow()"><i class="bi bi-plus"></i> Add Row</button>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-bordered mb-0" id="itemsTable">
          <thead class="table-dark">
            <tr>
              <th style="width:35px">#</th>
              <th>Product</th>
              <th style="width:90px" class="text-center">Ctns</th>
              <th style="width:80px" class="text-center">Pcs/Ctn</th>
              <th style="width:100px" class="text-center">Total Pcs</th>
              <th style="width:100px" class="text-center">Rate</th>
              <th style="width:110px" class="text-center">Amount</th>
              <th style="width:40px"></th>
            </tr>
          </thead>
          <tbody id="itemRows">
            <% items.forEach((item, i) => { %>
            <tr>
              <td class="text-center text-muted"><%= i+1 %></td>
              <td>
                <select name="product_id[]" class="form-select form-select-sm" onchange="onProductChange(this)">
                  <option value="">— Select —</option>
                  <% products.forEach(p => { %>
                  <option value="<%= p.id %>" data-rate="<%= p.rate %>" data-packaging="<%= p.packaging %>" <%= p.id == item.product_id ? 'selected' : '' %>><%= p.name %></option>
                  <% }) %>
                </select>
              </td>
              <td><input type="number" name="packages[]" class="form-control form-control-sm text-center" value="<%= item.packages %>" min="0" onchange="calcRowFromPkg(this)"></td>
              <td><input type="number" name="packaging[]" class="form-control form-control-sm text-center" value="<%= item.packaging %>" min="1" onchange="calcRowFromPkg(this)"></td>
              <td><input type="number" name="quantity[]" class="form-control form-control-sm text-center fw-bold" value="<%= item.quantity %>" min="0" onchange="calcRow(this)"></td>
              <td><input type="number" name="rate[]" class="form-control form-control-sm text-center" value="<%= item.rate %>" step="0.01" min="0" onchange="calcRow(this)"></td>
              <td><input type="number" name="amount[]" class="form-control form-control-sm text-center fw-bold" value="<%= item.amount %>" readonly style="background:#f8f9fa"></td>
              <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('tr').remove();calcTotal()"><i class="bi bi-trash"></i></button></td>
            </tr>
            <% }) %>
          </tbody>
          <tfoot class="table-light">
            <tr>
              <td colspan="6" class="text-end fw-bold">Subtotal:</td>
              <td class="text-center fw-bold" id="subtotalDisplay">-</td>
              <td></td>
            </tr>
            <tr>
              <td colspan="6" class="text-end fw-bold text-success">TOTAL:</td>
              <td class="text-center fw-bold text-success fs-5" id="totalDisplay">-</td>
              <td></td>
            </tr>
            <tr class="text-info">
              <td colspan="6" class="text-end">Less Commission (<span id="commPctLabel">0</span>%):</td>
              <td class="text-center" id="commDisplay">-</td>
              <td></td>
            </tr>
            <tr class="table-warning">
              <td colspan="6" class="text-end fw-bold">GROSS AMOUNT:</td>
              <td class="text-center fw-bold" id="grossDisplay">-</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-md-8">
      <label class="form-label fw-semibold">Notes</label>
      <textarea name="notes" class="form-control" rows="2" placeholder="Any notes for this invoice..."><%= order.notes || '' %></textarea>
    </div>
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-success btn-lg px-5"><i class="bi bi-check-circle me-2"></i>Confirm & Create Invoice</button>
    <a href="/orders/view/<%= order.id %>" class="btn btn-outline-secondary btn-lg">Cancel</a>
  </div>
</form>

<script>
const allProducts = <%- JSON.stringify(products) %>;

function calcRow(el) {
  const row = el.closest('tr');
  const qty = parseFloat(row.querySelector('[name="quantity[]"]').value) || 0;
  const rate = parseFloat(row.querySelector('[name="rate[]"]').value) || 0;
  row.querySelector('[name="amount[]"]').value = (qty * rate).toFixed(2);
  calcTotal();
}
function calcRowFromPkg(el) {
  const row = el.closest('tr');
  const pkg = parseInt(row.querySelector('[name="packages[]"]').value) || 0;
  const packaging = parseInt(row.querySelector('[name="packaging[]"]').value) || 1;
  row.querySelector('[name="quantity[]"]').value = pkg * packaging;
  calcRow(el);
}
function onProductChange(sel) {
  const opt = sel.options[sel.selectedIndex];
  const row = sel.closest('tr');
  const rate = parseFloat(opt.dataset.rate) || 0;
  const packaging = parseInt(opt.dataset.packaging) || 1;
  row.querySelector('[name="rate[]"]').value = rate;
  row.querySelector('[name="packaging[]"]').value = packaging;
  calcRow(sel);
}
function calcTotal() {
  let sub = 0;
  document.querySelectorAll('[name="amount[]"]').forEach(i => sub += parseFloat(i.value)||0);
  const commPct = parseFloat(document.getElementById('commission_pct').value)||0;
  const comm = sub * commPct / 100;
  document.getElementById('subtotalDisplay').textContent = 'Rs. ' + sub.toLocaleString('en-PK',{minimumFractionDigits:2});
  document.getElementById('totalDisplay').textContent = 'Rs. ' + sub.toLocaleString('en-PK',{minimumFractionDigits:2});
  // Update commission display if elements exist
  const cd = document.getElementById('commDisplay');
  const gd = document.getElementById('grossDisplay');
  if (cd) cd.textContent = 'Rs. ' + comm.toLocaleString('en-PK',{minimumFractionDigits:2});
  if (gd) gd.textContent = 'Rs. ' + (sub-comm).toLocaleString('en-PK',{minimumFractionDigits:2});
  const cl = document.getElementById('commPctLabel');
  if (cl) cl.textContent = commPct;
}
function addInvRow() {
  const opts = allProducts.map(p => `<option value="${p.id}" data-rate="${p.rate}" data-packaging="${p.packaging}">${p.name} (Stock: ${p.stock})</option>`).join('');
  const i = document.querySelectorAll('#itemRows tr').length + 1;
  const tr = document.createElement('tr');
  tr.innerHTML = `
    <td class="text-center text-muted">${i}</td>
    <td><select name="product_id[]" class="form-select form-select-sm" onchange="onProductChange(this)"><option value="">— Select —</option>${opts}</select></td>
    <td><input type="number" name="packages[]" class="form-control form-control-sm text-center" value="0" min="0" onchange="calcRowFromPkg(this)"></td>
    <td><input type="number" name="packaging[]" class="form-control form-control-sm text-center" value="1" min="1" onchange="calcRowFromPkg(this)"></td>
    <td><input type="number" name="quantity[]" class="form-control form-control-sm text-center fw-bold" value="0" min="0" onchange="calcRow(this)"></td>
    <td><input type="number" name="rate[]" class="form-control form-control-sm text-center" value="0" step="0.01" min="0" onchange="calcRow(this)"></td>
    <td><input type="number" name="amount[]" class="form-control form-control-sm text-center fw-bold" value="0" readonly style="background:#f8f9fa"></td>
    <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('tr').remove();calcTotal()"><i class="bi bi-trash"></i></button></td>
  `;
  document.getElementById('itemRows').appendChild(tr);
}
// Init totals
calcTotal();
</script>
<%- include('../partials/footer') %>
