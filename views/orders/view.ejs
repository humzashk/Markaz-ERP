<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-cart"></i> Order <%= order.order_no %></h2>
  <div class="d-flex gap-2 flex-wrap">
    <a href="/orders/print/<%= order.id %>" target="_blank" class="btn btn-secondary"><i class="bi bi-printer"></i> Print Order</a>
    <button class="btn btn-info" onclick="generateDC(<%= order.id %>)"><i class="bi bi-file-earmark"></i> Generate DC</button>
    <% if (!invoice) { %>
    <a href="/orders/generate-invoice/<%= order.id %>" class="btn btn-success"><i class="bi bi-receipt"></i> Generate Invoice</a>
    <% } else { %>
    <a href="/invoices/view/<%= invoice.id %>" class="btn btn-success"><i class="bi bi-receipt"></i> View Invoice</a>
    <% } %>
    <a href="/orders/edit/<%= order.id %>" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a href="/orders" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header fw-bold">Order Info</div>
      <div class="card-body">
        <table class="table table-borderless mb-0 fs-6">
          <tr><td width="140"><strong>Order #</strong></td><td><%= order.order_no %></td></tr>
          <tr><td><strong>Customer</strong></td><td><%= order.customer_name %></td></tr>
          <tr><td><strong>Phone</strong></td><td><%= order.customer_phone || '-' %></td></tr>
          <tr><td><strong>Address</strong></td><td><%= order.customer_address || '-' %></td></tr>
          <tr><td><strong>City</strong></td><td><%= order.customer_city || '-' %></td></tr>
          <tr><td><strong>Order Date</strong></td><td><%= formatDate(order.order_date) %></td></tr>
          <tr><td><strong>Delivery Date</strong></td><td><%= formatDate(order.delivery_date) %></td></tr>
          <% if (order.notes) { %><tr><td><strong>Notes</strong></td><td><%= order.notes %></td></tr><% } %>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card">
      <div class="card-header fw-bold">DC & Invoice</div>
      <div class="card-body">
        <% if (dc) { %>
        <div class="alert alert-success">
          <strong>Delivery Challan Created</strong><br>
          DC #: <strong><%= dc.dc_no %></strong><br>
          <a href="/orders/challan/<%= order.id %>?noprint=1" target="_blank" class="btn btn-sm btn-outline-success mt-2">
            <i class="bi bi-file-earmark-pdf"></i> View/Print DC
          </a>
        </div>
        <% } else { %>
        <div class="alert alert-warning">
          <strong>No Delivery Challan</strong><br>
          Click "Generate DC" button above to create one.
        </div>
        <% } %>

        <% if (invoice) { %>
        <div class="alert alert-info mt-3">
          <strong>Invoice Created</strong><br>
          Invoice #: <strong><%= invoice.invoice_no %></strong><br>
          <a href="/invoices/view/<%= invoice.id %>" class="btn btn-sm btn-outline-info mt-2">
            <i class="bi bi-receipt"></i> View Invoice
          </a>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div class="card mt-3">
  <div class="card-header fw-bold">Order Items</div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table mb-0">
        <thead class="table-light"><tr><th>#</th><th>Product</th><th class="text-end">Packages</th><th class="text-end">Qty/Pack</th><th class="text-end">Qty</th><th class="text-end">Rate</th><th class="text-end">Amount</th></tr></thead>
        <tbody>
          <% items.forEach((item, i) => { %>
          <tr>
            <td><%= i+1 %></td>
            <td><strong><%= item.product_name %></strong></td>
            <td class="text-end"><%= item.packages || 0 %></td>
            <td class="text-end"><%= item.packaging || 1 %></td>
            <td class="text-end"><strong><%= item.quantity.toLocaleString() %></strong></td>
            <td class="text-end"><%= formatCurrency(item.rate) %></td>
            <td class="text-end fw-bold"><%= formatCurrency(item.amount) %></td>
          </tr>
          <% }) %>
        </tbody>
        <tfoot class="table-light fw-bold">
          <tr><td colspan="6" class="text-end">Subtotal:</td><td class="text-end"><%= formatCurrency(order.subtotal) %></td></tr>
          <% if (order.commission_amount > 0) { %>
          <tr><td colspan="6" class="text-end">Commission (<%=order.commission_pct%>%):</td><td class="text-end text-danger">-<%= formatCurrency(order.commission_amount) %></td></tr>
          <% } %>
          <tr class="fs-5 table-warning"><td colspan="6" class="text-end">TOTAL:</td><td class="text-end text-success"><%= formatCurrency(order.total) %></td></tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>

<script>
function generateDC(orderId) {
  fetch('/orders/delivery-challan/' + orderId, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      alert('Delivery Challan ' + data.dc_no + ' created successfully!');
      location.reload();
    })
    .catch(e => alert('Error: ' + e.message));
}
</script>
<%- include('../partials/footer') %>
