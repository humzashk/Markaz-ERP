<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-truck"></i> Vendors</h2>
  <a href="/vendors/add" class="btn btn-primary"><i class="bi bi-plus"></i> Add Vendor</a>
</div>
<div class="filter-bar">
  <form class="row g-2" method="get">
    <div class="col-md-3">
      <input type="text" name="search" class="form-control form-control-sm" placeholder="Name, phone, city..." value="<%= search %>">
    </div>
    <div class="col-md-2">
      <select name="region" class="form-select form-select-sm">
        <option value="">All Regions</option>
        <% (regions || []).forEach(r => { %><option value="<%= r.name %>" <%= region===r.name?'selected':'' %>><%= r.name %></option><% }) %>
      </select>
    </div>
    <div class="col-md-2">
      <select name="party_type" class="form-select form-select-sm">
        <option value="">All Types</option>
        <% (types || []).forEach(t => { %><option value="<%= t.name %>" <%= party_type===t.name?'selected':'' %>><%= t.name %></option><% }) %>
      </select>
    </div>
    <div class="col-auto"><button class="btn btn-primary btn-sm">Filter</button></div>
    <% if (search || region || party_type) { %><div class="col-auto"><a href="/vendors" class="btn btn-outline-secondary btn-sm">Clear</a></div><% } %>
  </form>
</div>

<!-- Bulk Action Bar -->
<div class="bulk-bar" id="bulkBar">
  <span class="bulk-count"><span id="bulkCount">0</span> selected</span>
  <form method="post" action="/vendors/bulk" id="bulkForm" class="d-flex align-items-center gap-2">
    <input type="hidden" name="ids" id="bulkIds">
    <select name="region" class="form-select form-select-sm" style="width:auto;">
      <option value="">Set Region...</option>
      <% (regions || []).forEach(r => { %><option value="<%= r.name %>"><%= r.name %></option><% }) %>
    </select>
    <select name="party_type" class="form-select form-select-sm" style="width:auto;">
      <option value="">Set Type...</option>
      <% (types || []).forEach(t => { %><option value="<%= t.name %>"><%= t.name %></option><% }) %>
    </select>
    <select name="status" class="form-select form-select-sm" style="width:auto;">
      <option value="">Set Status...</option>
      <option value="active">Active</option>
      <option value="inactive">Inactive</option>
    </select>
    <button type="submit" class="btn btn-sm btn-light"><i class="bi bi-check2"></i> Apply</button>
  </form>
  <button class="btn btn-sm btn-outline-light ms-auto" onclick="clearSelection()"><i class="bi bi-x"></i> Clear</button>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead><tr>
          <th style="width:40px"><input type="checkbox" id="selectAll" class="form-check-input"></th>
          <th>Name</th><th>Region / Type</th><th>Phone</th><th>City</th><th>Balance</th><th>Status</th><th>Actions</th>
        </tr></thead>
        <tbody>
          <% (vendors || []).forEach((v, i) => { %>
          <tr>
            <td><input type="checkbox" class="form-check-input row-check" value="<%= v.id %>"></td>
            <td>
              <strong><%= v.name %></strong>
              <% if(v.notes){ %><br><small class="text-muted"><%= v.notes %></small><% } %>
            </td>
            <td>
              <% const regionCat = (regions||[]).find(r => r.name === v.region); %>
              <% const typeCat   = (types||[]).find(t => t.name === (v.party_type || v.category)); %>
              <% if(regionCat){ %><span class="badge bg-<%= regionCat.color || 'secondary' %>"><%= v.region %></span><% } %>
              <% if(typeCat)  { %> <span class="badge bg-<%= typeCat.color || 'info' %>"><%= typeCat.name %></span><% } %>
              <% if(!v.region && !(v.party_type||v.category)){ %><span class="text-muted small">—</span><% } %>
            </td>
            <td><%= v.phone || '-' %></td>
            <td><%= v.city  || '-' %></td>
            <td class="<%= v.balance > 0 ? 'text-danger fw-bold' : '' %>">
              <%= formatCurrency(v.balance) %>
              <% if (v.balance > 0) { %><small class="d-block text-danger">Payable</small><% } %>
            </td>
            <td><span class="badge bg-<%= statusBadge(v.status) %>"><%= v.status %></span></td>
            <td>
              <a href="/vendors/view/<%= v.id %>" class="btn btn-sm btn-outline-info" title="View"><i class="bi bi-eye"></i></a>
              <a href="/vendors/edit/<%= v.id %>" class="btn btn-sm btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>
              <a href="/ledger/vendor/<%= v.id %>" class="btn btn-sm btn-outline-secondary" title="Ledger"><i class="bi bi-journal-text"></i></a>
              <a href="/payments/pay?vendor_id=<%= v.id %>" class="btn btn-sm btn-outline-primary" title="Pay Vendor"><i class="bi bi-cash-stack"></i></a>
            </td>
          </tr>
          <% }) %>
          <% if (!(vendors||[]).length) { %><tr><td colspan="9" class="text-center text-muted py-4">No vendors found</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<script>
const selectAll = document.getElementById('selectAll');
const bulkBar   = document.getElementById('bulkBar');
const bulkCount = document.getElementById('bulkCount');
const bulkIds   = document.getElementById('bulkIds');
function getChecked() { return [...document.querySelectorAll('.row-check:checked')].map(c => c.value); }
function updateBulk() {
  const ids = getChecked();
  bulkCount.textContent = ids.length;
  bulkIds.value = ids.join(',');
  bulkBar.classList.toggle('visible', ids.length > 0);
}
selectAll.addEventListener('change', () => {
  document.querySelectorAll('.row-check').forEach(c => c.checked = selectAll.checked);
  updateBulk();
});
document.querySelectorAll('.row-check').forEach(c => c.addEventListener('change', () => {
  selectAll.checked = document.querySelectorAll('.row-check').length === getChecked().length;
  updateBulk();
}));
function clearSelection() {
  document.querySelectorAll('.row-check, #selectAll').forEach(c => c.checked = false);
  updateBulk();
}
</script>
<%- include('../partials/footer') %>
