<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-truck"></i> <%= vendor.name %></h2>
  <div class="d-flex gap-2">
    <a href="/vendors/edit/<%= vendor.id %>" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a href="/ledger/vendor/<%= vendor.id %>" class="btn btn-outline-secondary"><i class="bi bi-journal-text"></i> Ledger</a>
    <a href="/payments/add?type=vendor&entity_id=<%= vendor.id %>" class="btn btn-success"><i class="bi bi-cash"></i> Make Payment</a>
    <a href="/vendors" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>
<div class="row g-3">
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Vendor Info</div>
      <div class="card-body">
        <table class="table table-borderless mb-0">
          <tr><th width="100">Phone</th><td><%= vendor.phone || '-' %></td></tr>
          <tr><th>City</th><td><%= vendor.city || '-' %></td></tr>
          <tr><th>Address</th><td><%= vendor.address || '-' %></td></tr>
          <tr><th>Balance</th><td class="<%= vendor.balance < 0 ? 'due-amount fs-5' : '' %>"><%= formatCurrency(Math.abs(vendor.balance)) %><% if (vendor.balance < 0) { %><span class="badge bg-danger ms-2">Payable</span><% } %></td></tr>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-8">
    <div class="card">
      <div class="card-header">Recent Purchases</div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead><tr><th>Purchase No</th><th>Date</th><th>Total</th><th>Status</th><th></th></tr></thead>
          <tbody>
            <% purchases.forEach(p => { %>
            <tr>
              <td><a href="/purchases/view/<%= p.id %>"><%= p.purchase_no %></a></td>
              <td><%= formatDate(p.purchase_date) %></td>
              <td><%= formatCurrency(p.total) %></td>
              <td><span class="badge bg-<%= statusBadge(p.status) %>"><%= p.status %></span></td>
              <td><a href="/purchases/view/<%= p.id %>" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a></td>
            </tr>
            <% }) %>
            <% if (!purchases.length) { %><tr><td colspan="5" class="text-center text-muted">No purchases</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
