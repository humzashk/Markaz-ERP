<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-truck"></i> <%= edit ? 'Edit Transport' : 'New Transport' %></h2>
  <a href="/transports" class="btn btn-outline-secondary">Back</a>
</div>
<form method="post" action="/transports/<%= edit ? 'edit/'+transport.id : 'add' %>">
<%- include('../partials/form-error') %>
<div class="card"><div class="card-body">
  <div class="row g-3">
    <div class="col-md-6"><label class="form-label">Name *</label><input name="name" class="form-control" required value="<%= transport?.name || '' %>"></div>
    <div class="col-md-6"><label class="form-label">Contact Person</label><input name="contact" class="form-control" value="<%= transport?.contact || '' %>"></div>
    <div class="col-md-4"><label class="form-label">Phone</label><input name="phone" class="form-control" value="<%= transport?.phone || '' %>"></div>
    <div class="col-md-4"><label class="form-label">City</label><input name="city" class="form-control" value="<%= transport?.city || '' %>"></div>
    <div class="col-md-4"><label class="form-label">Status</label>
      <select name="status" class="form-select">
        <option value="active"   <%= transport?.status==='active'?'selected':'' %>>Active</option>
        <option value="inactive" <%= transport?.status==='inactive'?'selected':'' %>>Inactive</option>
      </select>
    </div>
    <div class="col-md-6"><label class="form-label">Vehicle #</label><input name="vehicle_no" class="form-control" value="<%= transport?.vehicle_no || '' %>"></div>
    <div class="col-md-6"><label class="form-label">Driver</label><input name="driver_name" class="form-control" value="<%= transport?.driver_name || '' %>"></div>
    <div class="col-12"><label class="form-label">Notes</label><textarea name="notes" class="form-control" rows="2"><%= transport?.notes || '' %></textarea></div>
  </div>
  <div class="mt-3"><button class="btn btn-primary"><i class="bi bi-save"></i> Save</button></div>
</div></div>
</form>
<%- include('../partials/footer') %>
