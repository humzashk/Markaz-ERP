<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-tags"></i> Rate List</h2>
  <a href="/ratelist/add-form" class="btn btn-primary"><i class="bi bi-plus"></i> Add Rate</a>
</div>

<style>
.rate-card { background:#fff; border:1px solid #e0e0e0; border-radius:10px; overflow:hidden; margin-bottom:18px; box-shadow:0 1px 4px rgba(0,0,0,.06); }
.rate-card-header { background:#f8f9fa; border-bottom:1px solid #e0e0e0; padding:10px 16px; display:flex; justify-content:space-between; align-items:center; }
.rate-card-header strong { font-size:15px; color:#2c3e50; }
.rate-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:0; }
.rate-entry { padding:12px 16px; border-right:1px solid #f0f0f0; border-bottom:1px solid #f0f0f0; transition:background .15s; }
.rate-entry:hover { background:#f8f9fa; }
.rate-type { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#888; margin-bottom:3px; }
.rate-value { font-size:20px; font-weight:800; color:#2c3e50; }
.rate-meta { font-size:11px; color:#aaa; margin-top:2px; }
.rate-comm { font-size:11px; color:#3498db; margin-top:1px; }
.rate-hist { font-size:11px; color:#999; }
.rate-hist span { display:inline-block; background:#f8f8f8; border:1px solid #e8e8e8; border-radius:3px; padding:1px 6px; margin:1px; }
.inline-edit-rate { width:90px; border:1px solid #dee2e6; border-radius:4px; padding:2px 6px; font-size:14px; font-weight:700; }
.add-rate-panel { background:#fff; border:1px solid #dee2e6; border-radius:10px; padding:20px; margin-bottom:20px; }
.quick-filter { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px; }
.quick-filter .btn { font-size:13px; padding:4px 12px; }
</style>

<!-- Quick Add Panel -->
<div class="add-rate-panel" id="addPanel" style="display:none;">
  <h6 class="fw-bold mb-3"><i class="bi bi-plus-circle text-primary"></i> Add New Rate</h6>
  <form method="post" action="/ratelist/add" class="row g-2 align-items-end">
    <div class="col-md-3">
      <label class="form-label small fw-semibold">Product *</label>
      <select name="product_id" class="form-select" required tabindex="1">
        <option value="">— Select Product —</option>
        <% products.forEach(p => { %>
        <option value="<%= p.id %>" data-packaging="<%= p.packaging %>" data-rate="<%= p.rate %>"><%= p.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-2">
      <label class="form-label small fw-semibold">Customer Type</label>
      <select name="customer_type" class="form-select" tabindex="2">
        <option value="retail">Retail</option>
        <option value="wholesale">Wholesale</option>
        <option value="special">Special</option>
      </select>
    </div>
    <div class="col-md-1">
      <label class="form-label small fw-semibold">Pcs/Ctn</label>
      <input type="number" name="packaging" id="ap_packaging" class="form-control" value="1" min="1" tabindex="3">
    </div>
    <div class="col-md-2">
      <label class="form-label small fw-semibold">Rate/Pc (Rs.) *</label>
      <input type="number" name="rate" class="form-control fw-bold" step="0.01" min="0" required tabindex="4" placeholder="0.00">
    </div>
    <div class="col-md-1">
      <label class="form-label small fw-semibold">Comm%</label>
      <input type="number" name="commission_pct" class="form-control" step="0.01" min="0" max="100" value="0" tabindex="5" placeholder="0">
    </div>
    <div class="col-md-2">
      <label class="form-label small fw-semibold">Effective Date *</label>
      <input type="date" name="effective_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>" required tabindex="6">
    </div>
    <div class="col-md-1">
      <button type="submit" class="btn btn-primary w-100" tabindex="7"><i class="bi bi-check"></i> Add</button>
    </div>
  </form>
</div>

<!-- Search & Filter -->
<div class="quick-filter">
  <input type="text" id="rateSearch" class="form-control" style="width:220px;" placeholder="Search product...">
  <% ['retail','wholesale','special'].forEach(t => { %>
  <button class="btn btn-outline-secondary type-filter" data-type="<%= t %>"><%= t.charAt(0).toUpperCase()+t.slice(1) %></button>
  <% }) %>
  <button class="btn btn-outline-secondary type-filter active" data-type="">All Types</button>
</div>

<!-- Rate Cards grouped by product -->
<%
  const grouped = {};
  rates.forEach(r => {
    if (!grouped[r.product_name]) grouped[r.product_name] = { category: r.category, entries: [] };
    grouped[r.product_name].entries.push(r);
  });
%>

<% if (!rates.length) { %>
<div class="text-center text-muted py-5">
  <i class="bi bi-tags" style="font-size:3rem;opacity:.3;"></i>
  <p class="mt-3">No rates defined yet.<br><button class="btn btn-primary mt-2" onclick="toggleAddPanel()"><i class="bi bi-plus"></i> Add First Rate</button></p>
</div>
<% } else { %>

<% Object.entries(grouped).forEach(([productName, data]) => { %>
<div class="rate-card product-card" data-product="<%= productName.toLowerCase() %>">
  <div class="rate-card-header">
    <div>
      <strong><%= productName %></strong>
      <% if (data.category) { %><span class="badge bg-light text-muted ms-2" style="font-size:10px;"><%= data.category %></span><% } %>
    </div>
    <small class="text-muted"><%= data.entries.length %> rate(s)</small>
  </div>
  <div class="rate-grid">
    <% data.entries.forEach(r => { %>
    <div class="rate-entry type-entry" data-type="<%= r.customer_type %>">
      <div class="rate-type"><%= r.customer_type %></div>
      <div class="d-flex align-items-center gap-2">
        <span class="rate-value">Rs. <span class="rate-val-display"><%= r.rate.toFixed(2) %></span></span>
        <button class="btn btn-xs btn-outline-secondary py-0 px-1" style="font-size:10px;" onclick="inlineEditRate(<%= r.id %>, this)" title="Edit Rate"><i class="bi bi-pencil"></i></button>
      </div>
      <% if (r.packaging > 1) { %><div class="rate-comm"><i class="bi bi-box2"></i> <%= r.packaging %> pcs/ctn</div><% } %>
      <% if (r.commission_pct > 0) { %><div class="rate-comm"><i class="bi bi-percent"></i> Commission: <strong><%= r.commission_pct %>%</strong></div><% } %>
      <div class="rate-meta"><i class="bi bi-calendar3"></i> <%= formatDate(r.effective_date) %></div>
      <%
        const hist = rateHistory.filter(h => h.product_id === r.product_id);
        if (hist.length > 0) {
      %>
      <div class="rate-hist mt-1">Prev: <% hist.slice(0,3).forEach(h => { %><span><%= h.old_rate?.toFixed(2) %></span><% }) %></div>
      <% } %>
      <form class="d-inline delete-form mt-1" method="post" action="/ratelist/delete/<%= r.id %>">
        <button class="btn btn-xs btn-outline-danger py-0 px-1" style="font-size:10px;" title="Delete"><i class="bi bi-trash"></i></button>
      </form>
    </div>
    <% }) %>
  </div>
</div>
<% }) %>
<% } %>

<!-- Inline Edit Modal -->
<div class="modal fade" id="editRateModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <form method="post" id="editRateForm">
        <div class="modal-header py-2"><h6 class="modal-title">Edit Rate</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="mb-2"><label class="form-label small fw-semibold">Rate/Pc (Rs.) *</label>
            <input type="number" name="rate" id="editRateVal" class="form-control fw-bold" step="0.01" min="0" required></div>
          <div class="mb-2"><label class="form-label small fw-semibold">Pcs/Ctn</label>
            <input type="number" name="packaging" id="editPackaging" class="form-control" min="1"></div>
          <div class="mb-2"><label class="form-label small fw-semibold">Commission %</label>
            <input type="number" name="commission_pct" id="editCommPct" class="form-control" step="0.01" min="0" max="100"></div>
          <div class="mb-2"><label class="form-label small fw-semibold">Effective Date</label>
            <input type="date" name="effective_date" id="editEffDate" class="form-control"></div>
        </div>
        <div class="modal-footer py-2">
          <button type="submit" class="btn btn-primary btn-sm">Save</button>
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
// Auto-fill packaging when product selected in add form
document.querySelector('#addPanel select[name=product_id]')?.addEventListener('change', function() {
  const opt = this.options[this.selectedIndex];
  if (opt.dataset.packaging) document.getElementById('ap_packaging').value = opt.dataset.packaging;
});

function toggleAddPanel() {
  const p = document.getElementById('addPanel');
  p.style.display = p.style.display === 'none' ? 'block' : 'none';
}
document.querySelector('.page-header .btn-primary')?.addEventListener('click', function(e) {
  e.preventDefault(); toggleAddPanel();
  document.querySelector('#addPanel select[name=product_id]')?.focus();
});

// Search filter
document.getElementById('rateSearch').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  document.querySelectorAll('.product-card').forEach(card => {
    card.style.display = card.dataset.product.includes(q) ? '' : 'none';
  });
});

// Type filter
document.querySelectorAll('.type-filter').forEach(btn => {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.type-filter').forEach(b => b.classList.remove('active'));
    this.classList.add('active');
    const type = this.dataset.type;
    document.querySelectorAll('.type-entry').forEach(e => {
      e.style.display = !type || e.dataset.type === type ? '' : 'none';
    });
  });
});

// Inline edit
function inlineEditRate(id, btn) {
  const entry = btn.closest('.rate-entry');
  const rate = entry.querySelector('.rate-val-display').textContent;
  const packing = entry.querySelector('.rate-comm')?.textContent.match(/(\d+) pcs/)?.[1] || 1;
  const commText = entry.querySelectorAll('.rate-comm');
  let comm = 0;
  commText.forEach(el => { const m = el.textContent.match(/(\d+(?:\.\d+)?)%/); if(m) comm = m[1]; });

  document.getElementById('editRateVal').value = rate;
  document.getElementById('editPackaging').value = packing;
  document.getElementById('editCommPct').value = comm;
  document.getElementById('editEffDate').value = new Date().toISOString().split('T')[0];
  document.getElementById('editRateForm').action = '/ratelist/edit/' + id;
  new bootstrap.Modal(document.getElementById('editRateModal')).show();
  setTimeout(() => document.getElementById('editRateVal').focus(), 300);
}

// Delete confirm
document.querySelectorAll('.delete-form').forEach(f => {
  f.addEventListener('submit', e => { if (!confirm('Delete this rate?')) e.preventDefault(); });
});
</script>
<%- include('../partials/footer') %>
