<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-journal-bookmark"></i> Journal Entry: <%= entry.entry_no %></h2>
  <div class="d-flex gap-2">
    <button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i> Print</button>
    <form class="d-inline delete-form no-print" method="post" action="/journal/delete/<%= entry.id %>">
      <button class="btn btn-outline-danger"><i class="bi bi-trash"></i> Delete</button>
    </form>
    <a href="/journal" class="btn btn-outline-secondary no-print"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>
<div class="card" style="max-width:700px">
  <div class="card-body">
    <div class="row mb-3">
      <div class="col-6">
        <div class="text-muted small">Entry No</div>
        <div class="fw-bold fs-5"><%= entry.entry_no %></div>
      </div>
      <div class="col-3">
        <div class="text-muted small">Date</div>
        <div class="fw-semibold"><%= formatDate(entry.entry_date) %></div>
      </div>
      <div class="col-3">
        <div class="text-muted small">Status</div>
        <span class="badge bg-success fs-6"><%= entry.status %></span>
      </div>
    </div>
    <% if (entry.description) { %>
    <div class="mb-3 p-3 bg-light rounded">
      <div class="text-muted small">Description</div>
      <div><%= entry.description %></div>
      <% if (entry.reference) { %><div class="text-muted small mt-1">Ref: <%= entry.reference %></div><% } %>
    </div>
    <% } %>

    <table class="table table-bordered">
      <thead class="table-dark">
        <tr><th>Account</th><th>Description</th><th class="text-end">Debit (PKR)</th><th class="text-end">Credit (PKR)</th></tr>
      </thead>
      <tbody>
        <% lines.forEach(l => { %>
        <tr>
          <td><strong><%= l.account %></strong></td>
          <td class="text-muted"><%= l.description || '-' %></td>
          <td class="text-end text-danger"><%= l.debit > 0 ? formatCurrency(l.debit) : '-' %></td>
          <td class="text-end text-success"><%= l.credit > 0 ? formatCurrency(l.credit) : '-' %></td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot class="table-light fw-bold">
        <% const totalDr = lines.reduce((s,l) => s+(l.debit||0), 0); %>
        <% const totalCr = lines.reduce((s,l) => s+(l.credit||0), 0); %>
        <tr>
          <td colspan="2" class="text-end">TOTAL</td>
          <td class="text-end text-danger"><%= formatCurrency(totalDr) %></td>
          <td class="text-end text-success"><%= formatCurrency(totalCr) %></td>
        </tr>
      </tfoot>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
