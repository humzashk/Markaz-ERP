<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-wallet2"></i> <%= edit ? 'Edit' : 'Add' %> Expense</h2>
  <a href="/expenses" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>
<div class="card" style="max-width:620px">
  <div class="card-body">
    <form method="post" action="/expenses/<%= edit ? 'edit/'+expense.id : 'add' %>">
      <div class="row g-3">
        <div class="col-12">
          <label class="form-label fw-semibold">Category *</label>
          <input type="text" name="category" class="form-control" required
            value="<%= expense?.category || '' %>"
            placeholder="Select or type a category"
            list="catList">
          <datalist id="catList">
            <% allCats.forEach(c => { %><option value="<%= c %>"><% }) %>
          </datalist>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Amount (Rs.) *</label>
          <div class="input-group">
            <span class="input-group-text">Rs.</span>
            <input type="number" name="amount" class="form-control" step="0.01" min="0" required value="<%= expense?.amount || '' %>" placeholder="0.00">
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Date *</label>
          <input type="date" name="expense_date" class="form-control datepicker" required
            value="<%= expense?.expense_date || new Date().toISOString().split('T')[0] %>">
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Payment Method</label>
          <select name="payment_method" class="form-select">
            <% ['cash','bank_transfer','cheque','online'].forEach(m => { %>
            <option value="<%= m %>" <%= (expense?.payment_method||'cash')===m?'selected':'' %>><%= m === 'bank_transfer' ? 'Bank Transfer' : m.charAt(0).toUpperCase()+m.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Reference / Voucher No.</label>
          <input type="text" name="reference" class="form-control" value="<%= expense?.reference || '' %>" placeholder="Optional">
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Paid To <span class="text-muted fw-normal">(person/vendor)</span></label>
          <input type="text" name="paid_to" class="form-control" value="<%= expense?.paid_to || '' %>" placeholder="Optional">
        </div>
        <div class="col-12">
          <label class="form-label fw-semibold">Description</label>
          <textarea name="description" class="form-control" rows="2" placeholder="Additional details..."><%= expense?.description || '' %></textarea>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary btn-lg px-5"><i class="bi bi-save"></i> <%= edit ? 'Update' : 'Save' %> Expense</button>
        </div>
      </div>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
