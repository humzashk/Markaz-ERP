<%- include('../partials/header') %>
<%
  var _biltyScope = (bilty && bilty.account_scope) ? bilty.account_scope : 'plastic_markaz';
  var _biltyBiz   = (typeof accountName === 'function') ? accountName(_biltyScope) : ((appSettings && appSettings.business_name) || 'PLASTIC MARKAZ');
  var _biltyLogo  = (typeof getLogoPath === 'function') ? getLogoPath(_biltyScope) : '/Logo.png';
  var _biltyAddr  = (appSettings && appSettings.business_address) || '';
  var _biltyCity  = (appSettings && appSettings.business_city) || '';
  var _biltyPh    = (appSettings && appSettings.business_phone) || '';
%>

<div class="page-header">
  <h2><i class="bi bi-send"></i> Bilty: <%= bilty.bilty_no || 'N/A' %></h2>
  <div class="d-flex gap-2">
    <button type="button" class="btn btn-dark" id="btnDownloadJpg">
      <i class="bi bi-image"></i> Download JPG
    </button>
    <button type="button" class="btn btn-outline-dark" onclick="window.print()">
      <i class="bi bi-printer"></i> Print
    </button>
    <a href="/bilty/edit/<%= bilty.id %>" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a href="/bilty" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>

<style>
  /* ====== Aesthetic Bilty Card (used both on screen and for JPG export) ====== */
  .bilty-wrapper { display:flex; justify-content:center; padding:20px 0; }
  #biltyCard {
    width: 720px;
    background: #ffffff;
    color: #1a252f;
    font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(26,37,47,0.08);
  }
  #biltyCard .bc-header {
    background: linear-gradient(135deg, #0f1c26 0%, #2c3e50 60%, #34495e 100%);
    color: #fff;
    padding: 22px 28px;
    display: flex;
    align-items: center;
    gap: 18px;
    position: relative;
  }
  #biltyCard .bc-header::after {
    content:""; position:absolute; right:-40px; top:-40px;
    width:180px; height:180px; border-radius:50%;
    background: radial-gradient(circle, rgba(255,255,255,0.08), transparent 70%);
  }
  #biltyCard .bc-logo {
    width: 64px; height: 64px; border-radius: 12px;
    background:#fff; display:flex; align-items:center; justify-content:center;
    padding:6px; box-shadow: 0 4px 14px rgba(0,0,0,0.25);
    flex-shrink:0;
  }
  #biltyCard .bc-logo img { max-width:100%; max-height:100%; object-fit:contain; }
  #biltyCard .bc-brand { flex:1; }
  #biltyCard .bc-brand .name {
    font-size: 22px; font-weight: 800; letter-spacing: 1.5px;
    text-transform: uppercase; line-height:1.1;
  }
  #biltyCard .bc-brand .tag {
    font-size: 11px; opacity:.85; margin-top:4px; letter-spacing:.5px;
  }
  #biltyCard .bc-title {
    text-align:right;
  }
  #biltyCard .bc-title .t-label {
    font-size:10px; letter-spacing:3px; opacity:.8; text-transform:uppercase;
  }
  #biltyCard .bc-title .t-big {
    font-size: 22px; font-weight:900; letter-spacing:2px; text-transform:uppercase;
  }
  #biltyCard .bc-title .t-no {
    margin-top:6px; display:inline-block;
    background:#fff; color:#1a252f; padding:4px 12px;
    border-radius:20px; font-weight:800; font-size:13px; letter-spacing:1px;
  }

  #biltyCard .bc-meta {
    display:grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    background:#f8fafc;
    border-bottom:1px solid #e2e8f0;
  }
  #biltyCard .bc-meta > div {
    padding:14px 20px;
    border-right:1px solid #e2e8f0;
  }
  #biltyCard .bc-meta > div:last-child { border-right:none; }
  #biltyCard .bc-meta .lbl {
    font-size:10px; letter-spacing:1.5px; color:#64748b;
    text-transform:uppercase; font-weight:700; margin-bottom:4px;
  }
  #biltyCard .bc-meta .val {
    font-size:14px; font-weight:800; color:#0f172a;
  }

  #biltyCard .bc-route {
    padding: 26px 28px;
    display:flex; align-items:center; gap:14px;
    background: linear-gradient(to right, #ffffff, #f1f5f9, #ffffff);
    border-bottom: 1px dashed #cbd5e1;
  }
  #biltyCard .route-box {
    flex:1; background:#fff; border:2px solid #1a252f;
    border-radius:10px; padding:10px 16px; text-align:center;
  }
  #biltyCard .route-box .r-lbl { font-size:10px; letter-spacing:2px; color:#64748b; text-transform:uppercase; }
  #biltyCard .route-box .r-val { font-size:18px; font-weight:900; color:#0f172a; text-transform:uppercase; margin-top:2px; }
  #biltyCard .route-arrow {
    font-size: 26px; color:#1a252f; font-weight:900;
  }

  #biltyCard .bc-grid {
    display:grid; grid-template-columns: 1fr 1fr;
    gap:0;
  }
  #biltyCard .bc-grid .cell {
    padding:12px 20px; border-bottom:1px solid #f1f5f9; border-right:1px solid #f1f5f9;
    display:flex; justify-content:space-between; align-items:center;
  }
  #biltyCard .bc-grid .cell:nth-child(2n) { border-right:none; }
  #biltyCard .bc-grid .cell .k {
    font-size:11px; color:#64748b; font-weight:600; text-transform:uppercase; letter-spacing:1px;
  }
  #biltyCard .bc-grid .cell .v { font-size:14px; font-weight:700; color:#0f172a; }
  #biltyCard .bc-grid .cell .v.money { color:#047857; font-size:16px; }
  #biltyCard .bc-grid .cell .v.badge-lite {
    background:#1a252f; color:#fff; padding:3px 12px; border-radius:20px;
    font-size:11px; text-transform:uppercase; letter-spacing:1px;
  }

  #biltyCard .bc-freight {
    background: linear-gradient(135deg, #1a252f, #2c3e50);
    color:#fff;
    padding: 18px 28px;
    display:flex; justify-content:space-between; align-items:center;
  }
  #biltyCard .bc-freight .f-lbl {
    font-size:12px; letter-spacing:2.5px; text-transform:uppercase; opacity:.85;
  }
  #biltyCard .bc-freight .f-val {
    font-size: 26px; font-weight:900; letter-spacing:1px;
  }

  #biltyCard .bc-notes {
    padding: 14px 28px; background:#fffbea; border-top:1px solid #fde68a;
    font-size:12px; color:#78350f;
  }
  #biltyCard .bc-notes strong { color:#92400e; }

  #biltyCard .bc-footer {
    padding: 18px 28px;
    display:flex; justify-content:space-between; align-items:flex-end;
    font-size:11px; color:#64748b;
    background:#f8fafc; border-top:1px solid #e2e8f0;
  }
  #biltyCard .sig {
    border-top: 2px solid #1a252f; padding-top:6px; min-width:170px;
    text-align:center; font-weight:700; text-transform:uppercase; letter-spacing:1px;
    color:#1a252f;
  }
  #biltyCard .bc-footer .issued { font-size:10px; letter-spacing:.5px; }

  @media print {
    .page-header, #sidebar, .topbar, nav, .btn, button { display:none !important; }
    body { background:#fff; }
    #biltyCard { box-shadow:none; border:none; }
  }
</style>

<div class="bilty-wrapper">
  <div id="biltyCard">
    <!-- Header -->
    <div class="bc-header">
      <div class="bc-logo">
        <% if (_biltyLogo) { %>
          <img src="<%= _biltyLogo %>" alt="logo" crossorigin="anonymous">
        <% } else { %>
          <i class="bi bi-box-seam" style="font-size:34px;color:#1a252f;"></i>
        <% } %>
      </div>
      <% if (!_biltyLogo || _biltyLogo === '/Logo.png') { %>
        <!-- No custom logo: show account name -->
        <div class="bc-brand">
          <div class="name"><%= _biltyBiz %></div>
          <div class="tag">
            <% if (_biltyAddr) { %><%= _biltyAddr %><% if(_biltyCity){ %>, <%= _biltyCity %><% } %><% } %>
            <% if (_biltyPh) { %> &nbsp;|&nbsp; Tel: <%= _biltyPh %><% } %>
          </div>
        </div>
      <% } %>
      <div class="bc-title">
        <div class="t-label">Transport</div>
        <div class="t-big">Bilty</div>
        <div class="t-no">#<%= bilty.bilty_no || 'N/A' %></div>
      </div>
    </div>

    <!-- Meta row -->
    <div class="bc-meta">
      <div>
        <div class="lbl">Date</div>
        <div class="val"><%= formatDate(bilty.bilty_date) %></div>
      </div>
      <div>
        <div class="lbl">Transport Company</div>
        <div class="val"><%= bilty.transport_name || '-' %></div>
      </div>
      <div>
        <div class="lbl">Status</div>
        <div class="val" style="text-transform:uppercase;"><%= bilty.status || '-' %></div>
      </div>
    </div>

    <!-- Route -->
    <div class="bc-route">
      <div class="route-box">
        <div class="r-lbl">From</div>
        <div class="r-val"><%= bilty.from_city || '-' %></div>
      </div>
      <div class="route-arrow">→</div>
      <div class="route-box">
        <div class="r-lbl">To</div>
        <div class="r-val"><%= bilty.to_city || '-' %></div>
      </div>
    </div>

    <!-- Details grid -->
    <div class="bc-grid">
      <div class="cell">
        <div class="k">Customer</div>
        <div class="v"><%= bilty.customer_name || '-' %></div>
      </div>
      <div class="cell">
        <div class="k">Packages</div>
        <div class="v"><%= bilty.packages_count || 0 %></div>
      </div>
      <div class="cell">
        <div class="k">Weight</div>
        <div class="v"><%= bilty.weight || '-' %></div>
      </div>
      <div class="cell">
        <div class="k">Reference</div>
        <div class="v">
          <% if (bilty.order_no) { %><%= bilty.order_no %><% } %>
          <% if (bilty.invoice_no) { %><%= bilty.order_no ? ' / ' : '' %><%= bilty.invoice_no %><% } %>
          <% if (!bilty.order_no && !bilty.invoice_no) { %>-<% } %>
        </div>
      </div>
    </div>

    <!-- Freight highlight -->
    <div class="bc-freight">
      <div class="f-lbl">Freight Charges</div>
      <div class="f-val"><%= formatCurrency(bilty.freight_charges) %></div>
    </div>

    <!-- Notes -->
    <% if (bilty.notes) { %>
    <div class="bc-notes">
      <strong>Notes:</strong> <%= bilty.notes %>
    </div>
    <% } %>

    <!-- Footer -->
    <div class="bc-footer">
      <div class="issued">
        Issued by <strong><%= _biltyBiz %></strong><br>
        Generated: <%= new Date().toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}) %>
      </div>
      <div class="sig">Authorized Signature</div>
    </div>
  </div>
</div>

<!-- html2canvas for JPG export -->
<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script>
(function(){
  var btn = document.getElementById('btnDownloadJpg');
  if (!btn) return;
  btn.addEventListener('click', function(){
    var card = document.getElementById('biltyCard');
    if (!card) return;
    btn.disabled = true;
    var orig = btn.innerHTML;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Generating...';

    html2canvas(card, {
      scale: 2,
      backgroundColor: '#ffffff',
      useCORS: true,
      allowTaint: true,
      logging: false
    }).then(function(canvas){
      var url = canvas.toDataURL('image/jpeg', 0.95);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'Bilty-<%= (bilty.bilty_no || bilty.id) %>.jpg';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
    }).catch(function(err){
      console.error('html2canvas error:', err);
      alert('Could not generate JPG. ' + (err && err.message ? err.message : ''));
    }).finally(function(){
      btn.disabled = false;
      btn.innerHTML = orig;
    });
  });
})();
</script>
<%- include('../partials/footer') %>
