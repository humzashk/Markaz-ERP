<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-send"></i> Bilty / Transport</h2>
  <a href="/bilty/add" class="btn btn-primary"><i class="bi bi-plus"></i> Add Bilty</a>
</div>

<% if (locals.ok) { %><div class="alert alert-success alert-dismissible"><%= ok %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
<% if (locals.err) { %><div class="alert alert-danger alert-dismissible"><%= err %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>

<!-- Bulk Bar -->
<div class="bulk-bar" id="bulkBar">
  <span class="bulk-count"><span id="bulkCount">0</span> selected</span>
  <form method="post" action="/bilty/bulk" id="bulkForm" class="d-flex align-items-center gap-2">
    <input type="hidden" name="ids" id="bulkIds">
    <select name="action" class="form-select form-select-sm" style="width:auto;" id="bulkAction">
      <option value="">-- Action --</option>
      <option value="delete">Delete Selected</option>
    </select>
    <button type="submit" class="btn btn-sm btn-light" onclick="return confirmBulk()"><i class="bi bi-check2"></i> Apply</button>
  </form>
  <button class="btn btn-sm btn-outline-light ms-auto" onclick="clearSelection()"><i class="bi bi-x"></i> Clear</button>
</div>

<div class="filter-bar">
  <form class="row g-2" method="get">
    <div class="col-md-6"><input type="text" name="search" class="form-control" placeholder="Search by bilty no, transport, city..." value="<%= search %>"></div>
    <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-search"></i></button></div>
    <% if (search) { %><div class="col-auto"><a href="/bilty" class="btn btn-outline-secondary">Clear</a></div><% } %>
  </form>
</div>
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead><tr>
          <th style="width:40px"><input type="checkbox" id="selectAll" class="form-check-input"></th>
          <th>Bilty No</th><th>Transport</th><th>From → To</th><th>Date</th><th>Freight</th><th>Order/Invoice</th><th>Status</th><th>Actions</th>
        </tr></thead>
        <tbody>
          <% bilties.forEach(b => { %>
          <tr>
            <td><input type="checkbox" class="form-check-input row-check" value="<%= b.id %>"></td>
            <td><strong><%= b.bilty_no || '-' %></strong></td>
            <td><%= b.transport_name %></td>
            <td><%= b.from_city %> → <%= b.to_city %></td>
            <td><%= formatDate(b.bilty_date) %></td>
            <td class="fw-bold"><%= formatCurrency(b.freight_charges) %></td>
            <td><% if (b.order_no) { %><a href="/orders/view/<%= b.order_id %>"><%= b.order_no %></a><% } %><% if (b.invoice_no) { %> <a href="/invoices/view/<%= b.invoice_id %>"><%= b.invoice_no %></a><% } %></td>
            <td><span class="badge bg-<%= statusBadge(b.status) %>"><%= b.status %></span></td>
            <td>
              <a href="/bilty/view/<%= b.id %>" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
              <a href="/bilty/edit/<%= b.id %>" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
              <form class="d-inline delete-form" method="post" action="/bilty/delete/<%= b.id %>"><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>
            </td>
          </tr>
          <% }) %>
          <% if (!bilties.length) { %><tr><td colspan="9" class="text-center text-muted py-4">No bilty records</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
const bulkBar = document.getElementById('bulkBar');
const bulkCount = document.getElementById('bulkCount');
const bulkIds = document.getElementById('bulkIds');

function getChecked() { return [...document.querySelectorAll('.row-check:checked')].map(c => c.value); }
function updateBulk() {
  const checked = getChecked();
  bulkCount.textContent = checked.length;
  bulkIds.value = checked.join(',');
  bulkBar.classList.toggle('active', checked.length > 0);
}
function clearSelection() {
  document.querySelectorAll('.row-check, #selectAll').forEach(c => c.checked = false);
  updateBulk();
}
function confirmBulk() {
  const action = document.getElementById('bulkAction').value;
  if (!action) { alert('Please select a bulk action.'); return false; }
  if (action === 'delete') return confirm('Delete selected bilty records? This cannot be undone.');
  return true;
}
document.getElementById('selectAll').addEventListener('change', function() {
  document.querySelectorAll('.row-check').forEach(c => c.checked = this.checked);
  updateBulk();
});
document.querySelectorAll('.row-check').forEach(c => c.addEventListener('change', updateBulk));
</script>
<%- include('../partials/footer') %>
