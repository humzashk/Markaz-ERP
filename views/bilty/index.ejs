<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-send"></i> Bilty / Transport</h2>
  <a href="/bilty/add" class="btn btn-primary"><i class="bi bi-plus"></i> Add Bilty</a>
</div>
<div class="filter-bar">
  <form class="row g-2" method="get">
    <div class="col-md-6"><input type="text" name="search" class="form-control" placeholder="Search by bilty no, transport, city..." value="<%= search %>"></div>
    <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-search"></i></button></div>
    <% if (search) { %><div class="col-auto"><a href="/bilty" class="btn btn-outline-secondary">Clear</a></div><% } %>
  </form>
</div>
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead><tr><th>Bilty No</th><th>Transport</th><th>From → To</th><th>Date</th><th>Freight</th><th>Order/Invoice</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% bilties.forEach(b => { %>
          <tr>
            <td><strong><%= b.bilty_no || '-' %></strong></td>
            <td><%= b.transport_name %></td>
            <td><%= b.from_city %> → <%= b.to_city %></td>
            <td><%= formatDate(b.bilty_date) %></td>
            <td class="fw-bold"><%= formatCurrency(b.freight_charges) %></td>
            <td><% if (b.order_no) { %><a href="/orders/view/<%= b.order_id %>"><%= b.order_no %></a><% } %><% if (b.invoice_no) { %> <a href="/invoices/view/<%= b.invoice_id %>"><%= b.invoice_no %></a><% } %></td>
            <td><span class="badge bg-<%= statusBadge(b.status) %>"><%= b.status %></span></td>
            <td>
              <a href="/bilty/view/<%= b.id %>" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
              <a href="/bilty/edit/<%= b.id %>" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
              <form class="d-inline delete-form" method="post" action="/bilty/delete/<%= b.id %>"><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>
            </td>
          </tr>
          <% }) %>
          <% if (!bilties.length) { %><tr><td colspan="8" class="text-center text-muted py-4">No bilty records</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
