<%- include('../partials/header') %>

<%
  var isCustomer = payment.entity_type === 'customer';
  var fmtAmt = (n) => 'Rs. ' + Number(n||0).toLocaleString('en-PK',{minimumFractionDigits:2,maximumFractionDigits:2});
  var fmtDt  = (d) => d ? new Date(d).toLocaleDateString('en-PK',{day:'2-digit',month:'short',year:'numeric'}) : '—';
  var methodLabel = { cash:'Cash', cheque:'Cheque', bank_transfer:'Bank Transfer' };
  var scopeLabel  = { plastic_markaz:'Plastic Markaz', wings_furniture:'Wings Furniture', cooler:'Cooler' };
%>

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
  <h2>
    <i class="bi bi-<%= isCustomer ? 'cash-coin' : 'cash-stack' %>"></i>
    <%= isCustomer ? 'Payment Received' : 'Payment Made' %>
    <span class="text-muted fs-5 fw-normal ms-2">#<%= payment.id %></span>
  </h2>
  <div class="d-flex gap-2 flex-wrap">
    <% if (entity) { %>
      <a href="/ledger/<%= payment.entity_type %>/<%= entity.id %>" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-journal-text"></i> View Ledger
      </a>
    <% } %>
    <a href="/payments/<%= isCustomer ? 'received' : 'paid' %>" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-list"></i> All <%= isCustomer ? 'Received' : 'Paid' %>
    </a>
    <a href="/payments/<%= isCustomer ? 'receive' : 'pay' %><%= entity ? '?'+(isCustomer?'customer_id':'vendor_id')+'='+entity.id : '' %>" class="btn btn-<%= isCustomer ? 'success' : 'primary' %> btn-sm">
      <i class="bi bi-plus-circle"></i> New Payment
    </a>
  </div>
</div>

<% if (ok)  { %><div class="alert alert-success alert-dismissible fade show py-2"><i class="bi bi-check-circle"></i> Payment recorded successfully.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
<% if (err) { %><div class="alert alert-danger  alert-dismissible fade show py-2"><%= err %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>

<div class="row g-3">

  <%/* ── Payment summary card ── */%>
  <div class="col-lg-5">
    <div class="card h-100">
      <div class="card-header fw-semibold bg-<%= isCustomer ? 'success' : 'primary' %> text-white">
        <i class="bi bi-receipt"></i> Payment Summary
      </div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <tr>
            <th class="ps-3" style="width:40%"><%= isCustomer ? 'Customer' : 'Vendor' %></th>
            <td class="fw-bold">
              <% if (entity) { %>
                <a href="/ledger/<%= payment.entity_type %>/<%= entity.id %>" class="text-decoration-none">
                  <%= entity.name %>
                </a>
              <% } else { %>—<% } %>
            </td>
          </tr>
          <tr>
            <th class="ps-3">Amount</th>
            <td class="fw-bold fs-5 text-<%= isCustomer ? 'success' : 'primary' %>"><%= fmtAmt(payment.amount) %></td>
          </tr>
          <tr>
            <th class="ps-3">Date</th>
            <td><%= fmtDt(payment.payment_date) %></td>
          </tr>
          <tr>
            <th class="ps-3">Method</th>
            <td>
              <%
                var mIcon = { cash:'cash-coin', cheque:'bank', bank_transfer:'building' };
                var mKey  = payment.payment_method || 'cash';
              %>
              <i class="bi bi-<%= mIcon[mKey] || 'cash' %>"></i>
              <%= methodLabel[mKey] || mKey %>
            </td>
          </tr>
          <% if (payment.reference) { %>
          <tr>
            <th class="ps-3">Reference</th>
            <td class="text-muted"><%= payment.reference %></td>
          </tr>
          <% } %>
          <tr>
            <th class="ps-3">Account</th>
            <td><%= scopeLabel[payment.account_scope] || payment.account_scope || '—' %></td>
          </tr>
          <% if (payment.notes) { %>
          <tr>
            <th class="ps-3">Notes</th>
            <td class="text-muted"><%= payment.notes %></td>
          </tr>
          <% } %>
          <tr>
            <th class="ps-3">Recorded</th>
            <td class="text-muted small"><%= fmtDt(payment.created_at) %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <%/* ── Ledger impact + entity balance ── */%>
  <div class="col-lg-7">

    <% if (ledgerRow) { %>
    <div class="card mb-3">
      <div class="card-header fw-semibold"><i class="bi bi-arrow-left-right text-info"></i> Ledger Impact</div>
      <div class="card-body">
        <div class="row g-3 text-center">
          <div class="col-4">
            <div class="border rounded p-3">
              <div class="text-muted small mb-1">Debit (Dr)</div>
              <div class="fw-bold text-danger fs-6">
                <%= Number(ledgerRow.debit||0) > 0 ? fmtAmt(ledgerRow.debit) : '—' %>
              </div>
            </div>
          </div>
          <div class="col-4">
            <div class="border rounded p-3">
              <div class="text-muted small mb-1">Credit (Cr)</div>
              <div class="fw-bold text-success fs-6">
                <%= Number(ledgerRow.credit||0) > 0 ? fmtAmt(ledgerRow.credit) : '—' %>
              </div>
            </div>
          </div>
          <div class="col-4">
            <div class="border rounded p-3 bg-light">
              <div class="text-muted small mb-1">Net Effect</div>
              <div class="fw-bold fs-6">
                <% var net = Number(ledgerRow.debit||0) - Number(ledgerRow.credit||0); %>
                <span class="<%= net > 0 ? 'text-danger' : 'text-success' %>">
                  <%= net > 0 ? '+ ' : '− ' %><%= fmtAmt(Math.abs(net)) %>
                </span>
              </div>
            </div>
          </div>
        </div>
        <p class="text-muted small mt-2 mb-0">
          <i class="bi bi-info-circle"></i>
          <% if (isCustomer) { %>
            Credit reduces customer's outstanding balance (they owe less).
          <% } else { %>
            Debit reduces vendor liability (we owe less).
          <% } %>
        </p>
      </div>
    </div>
    <% } %>

    <% if (entity) { %>
    <div class="card">
      <div class="card-header fw-semibold"><i class="bi bi-person-circle text-secondary"></i> <%= isCustomer ? 'Customer' : 'Vendor' %> Balance</div>
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="fw-bold fs-5"><%= entity.name %></div>
            <% if (entity.phone) { %><div class="text-muted small"><i class="bi bi-telephone"></i> <%= entity.phone %></div><% } %>
          </div>
          <div class="text-end">
            <div class="text-muted small mb-1">Current Balance</div>
            <div class="fw-bold fs-5 <%= (entity.balance||0) > 0 ? 'text-danger' : (entity.balance||0) < 0 ? 'text-success' : 'text-secondary' %>">
              <%= fmtAmt(Math.abs(entity.balance||0)) %>
            </div>
            <div class="text-muted" style="font-size:11px">
              <%= (entity.balance||0) > 0 ? (isCustomer ? 'Outstanding Due' : 'We Owe Vendor') : (entity.balance||0) < 0 ? 'Advance / Overpaid' : 'Settled' %>
            </div>
          </div>
        </div>
        <div class="mt-3 d-flex gap-2">
          <a href="/ledger/<%= payment.entity_type %>/<%= entity.id %>" class="btn btn-sm btn-outline-primary flex-fill">
            <i class="bi bi-journal-text"></i> Full Ledger
          </a>
          <a href="/payments/<%= isCustomer ? 'receive' : 'pay' %>?<%= isCustomer ? 'customer_id' : 'vendor_id' %>=<%= entity.id %>" class="btn btn-sm btn-<%= isCustomer ? 'success' : 'primary' %> flex-fill">
            <i class="bi bi-plus"></i> Another Payment
          </a>
        </div>
      </div>
    </div>
    <% } %>

  </div>
</div>

<%/* ── Delete (with 2-month lock handled server-side) ── */%>
<div class="mt-4 pt-3 border-top no-print">
  <form method="post" action="/payments/delete/<%= payment.id %>" onsubmit="return confirm('Delete this payment? This will reverse the ledger entry.')">
    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete Payment</button>
  </form>
</div>

<%- include('../partials/footer') %>
