<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-exclamation-triangle"></i> Breakage Record</h2>
  <div class="d-flex gap-2">
    <a href="/breakage/challan/<%= breakage.id %>" class="btn btn-outline-secondary" target="_blank"><i class="bi bi-printer"></i> Print Challan</a>
    <% if (breakage.credit_note_no) { %>
    <a href="/breakage/credit-note/<%= breakage.id %>" class="btn btn-outline-info" target="_blank"><i class="bi bi-file-text"></i> Credit Note</a>
    <% } %>
    <a href="/breakage" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>
<div class="row g-3">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">Breakage Details</div>
      <div class="card-body">
        <table class="table table-borderless mb-0">
          <tr><th width="150">Customer</th><td><strong><%= breakage.customer_name %></strong></td></tr>
          <tr><th>Product</th><td><strong><%= breakage.product_name %></strong></td></tr>
          <tr><th>Quantity</th><td><%= breakage.quantity > 0 ? breakage.quantity + ' pcs' : 'Not specified' %></td></tr>
          <tr><th>Amount Adjusted</th><td><strong class="text-danger fs-5">Rs. <%= breakage.adjustment_amount.toFixed(2) %></strong></td></tr>
          <tr><th>Date</th><td><%= formatDate(breakage.breakage_date) %></td></tr>
          <tr><th>Notes</th><td><%= breakage.notes || '-' %></td></tr>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-success">
      <div class="card-header bg-success text-white"><i class="bi bi-file-earmark-check"></i> Credit Note</div>
      <div class="card-body">
        <% if (breakage.credit_note_no) { %>
        <table class="table table-borderless mb-0">
          <tr><th width="130">Credit Note #</th><td><strong class="text-success"><%= breakage.credit_note_no %></strong></td></tr>
          <tr><th>Amount</th><td><strong>Rs. <%= breakage.adjustment_amount.toFixed(2) %></strong></td></tr>
          <tr><th>Status</th><td><span class="badge bg-success">Issued</span></td></tr>
        </table>
        <a href="/breakage/credit-note/<%= breakage.id %>" class="btn btn-success mt-2" target="_blank">
          <i class="bi bi-printer"></i> Print Credit Note
        </a>
        <% } else { %>
        <p class="text-muted mb-0">No credit note generated.</p>
        <% } %>
      </div>
    </div>
    <div class="card mt-3 border-danger">
      <div class="card-header text-danger"><i class="bi bi-trash"></i> Actions</div>
      <div class="card-body">
        <form method="post" action="/breakage/delete/<%= breakage.id %>" onsubmit="return confirm('Delete this breakage record? This will also reverse the ledger adjustment.')">
          <button class="btn btn-outline-danger"><i class="bi bi-trash"></i> Delete Breakage Record</button>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
