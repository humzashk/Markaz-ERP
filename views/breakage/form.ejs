<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-exclamation-triangle"></i> Record Breakage</h2>
  <a href="/breakage" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>
<div class="row g-3">
  <div class="col-md-7">
    <div class="card">
      <div class="card-header">Breakage Details</div>
      <div class="card-body">
        <form method="post" action="/breakage/add">
          <div class="mb-3">
            <label class="form-label">Customer *</label>
            <select name="customer_id" class="form-select" required>
              <option value="">Select Customer</option>
              <% customers.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Product *</label>
            <select name="product_id" class="form-select" required>
              <option value="">Select Product</option>
              <% products.forEach(p => { %>
              <option value="<%= p.id %>"><%= p.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label">Quantity (pcs) <small class="text-muted">Optional</small></label>
              <input type="number" name="quantity" class="form-control" min="0" value="0">
            </div>
            <div class="col-md-6">
              <label class="form-label">Adjustment Amount (PKR) *</label>
              <input type="number" name="amount" class="form-control" min="0" step="0.01" required placeholder="0.00">
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Breakage Date *</label>
            <input type="date" name="breakage_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Notes / Reason</label>
            <textarea name="notes" class="form-control" rows="2" placeholder="Describe the breakage..."></textarea>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-lg px-5"><i class="bi bi-save"></i> Record Breakage</button>
            <a href="/breakage" class="btn btn-outline-secondary btn-lg">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
  <div class="col-md-5">
    <div class="card border-info">
      <div class="card-header bg-info text-white"><i class="bi bi-info-circle"></i> What Happens</div>
      <div class="card-body">
        <p class="mb-2"><strong>1. Ledger Credit:</strong> The adjustment amount is credited to the customer's ledger, reducing their outstanding balance.</p>
        <p class="mb-2"><strong>2. Credit Note:</strong> A Credit Note (CN) is auto-generated and linked to this breakage record.</p>
        <p class="mb-0"><strong>3. Print:</strong> You can print a Breakage Challan and Credit Note for records.</p>
      </div>
    </div>
    <div class="card mt-3 border-warning">
      <div class="card-header bg-warning"><i class="bi bi-exclamation-triangle"></i> Note</div>
      <div class="card-body">
        <small>Breakage does <strong>not</strong> adjust stock levels. It only adjusts the financial balance of the customer. For stock adjustments, use <a href="/stock/add">Stock Management</a>.</small>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
