<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-exclamation-triangle"></i> Breakage / Credit Notes</h2>
  <a href="/breakage/add" class="btn btn-primary"><i class="bi bi-plus"></i> Record Breakage</a>
</div>
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead><tr>
          <th>#</th>
          <th>Date</th>
          <th>Product</th>
          <th>Qty</th>
          <th>Customer</th>
          <th>Amount</th>
          <th>Credit Note</th>
          <th>Notes</th>
          <th>Actions</th>
        </tr></thead>
        <tbody>
          <% breakages.forEach((b, i) => { %>
          <tr>
            <td><%= i+1 %></td>
            <td><small><%= formatDate(b.breakage_date) %></small></td>
            <td><strong><%= b.product_name %></strong></td>
            <td><%= b.quantity > 0 ? b.quantity + ' pcs' : '-' %></td>
            <td><%= b.party_name || '-' %></td>
            <td class="fw-bold text-danger"><%= formatCurrency(b.adjustment_amount) %></td>
            <td>
              <% if (b.credit_note) { %>
                <a href="/breakage/credit-note/<%= b.id %>" class="btn btn-sm btn-outline-info" target="_blank">
                  <i class="bi bi-file-text"></i> <%= b.credit_note %>
                </a>
              <% } else { %>
                <span class="text-muted small">-</span>
              <% } %>
            </td>
            <td><small class="text-muted"><%= b.notes || '-' %></small></td>
            <td>
              <a href="/breakage/view/<%= b.id %>" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
              <a href="/breakage/challan/<%= b.id %>" class="btn btn-sm btn-outline-primary" target="_blank" title="Print Challan"><i class="bi bi-printer"></i></a>
              <form class="d-inline delete-form" method="post" action="/breakage/delete/<%= b.id %>">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
          <% if (!breakages.length) { %>
          <tr><td colspan="9" class="text-center text-muted py-4">No breakage records found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
