<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Sign In - Markaz ERP</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { min-height:100vh; display:flex; align-items:center; justify-content:center;
           background: linear-gradient(135deg, #1a252f 0%, #2c3e50 100%); font-family: 'Segoe UI', sans-serif; }
    .login-card { width: 100%; max-width: 400px; background:#fff; border-radius: 10px;
                  box-shadow: 0 10px 30px rgba(0,0,0,0.2); padding: 32px; }
    .brand { text-align:center; margin-bottom: 20px; }
    .brand h3 { font-weight: 800; letter-spacing: 1.5px; margin: 8px 0 4px; }
    .brand small { color: #7f8c8d; letter-spacing: 1px; }
    .form-label { font-weight: 600; font-size: 13px; }
    .btn-login { background: linear-gradient(135deg, #1a252f 0%, #2c3e50 100%); color:#fff; font-weight:600; }
    .btn-login:hover { color:#fff; opacity:.95; }
    .small-note { font-size:11px; color:#7f8c8d; text-align:center; margin-top:16px; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="brand">
      <i class="bi bi-box-seam" style="font-size:42px;color:#2c3e50;"></i>
      <h3>MARKAZ ERP</h3>
      <small>Enterprise Login</small>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger py-2 small">
        <% if (error === 'invalid') { %>Invalid username or password.
        <% } else if (error === 'missing') { %>Please enter username and password.
        <% } else if (error === 'server') { %>Server error. Please try again.
        <% } else { %><%= error %><% } %>
      </div>
    <% } %>

    <form method="POST" action="/login" autocomplete="off">
      <div class="mb-3">
        <label class="form-label">Username</label>
        <input type="text" name="username" class="form-control" required autofocus value="<%= username %>">
      </div>
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" required>
      </div>
      <button type="submit" class="btn btn-login w-100 py-2">
        <i class="bi bi-box-arrow-in-right"></i> Sign In
      </button>
    </form>

    <div class="small-note">
      Default: <strong>admin</strong> / <strong>admin123</strong> (change after first login)
    </div>
  </div>
</body>
</html>
