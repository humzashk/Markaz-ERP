<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-box"></i> <%= product.name %></h2>
  <div class="d-flex gap-2">
    <a href="/products/edit/<%= product.id %>" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a href="/reports/stock-ledger?product_id=<%= product.id %>" class="btn btn-outline-secondary"><i class="bi bi-journal-text"></i> Stock Ledger</a>
    <a href="/products" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>
<div class="row g-3">
  <div class="col-md-5">
    <div class="card">
      <div class="card-header">Product Details</div>
      <div class="card-body">
        <table class="table table-borderless mb-0">
          <tr><th width="130">Category</th><td><%= product.category || '-' %></td></tr>
          <tr><th>Pcs per Carton</th><td><strong><%= product.qty_per_pack %></strong></td></tr>
          <tr><th>Rate / Piece</th><td><strong class="text-success"><%= formatCurrency(product.rate) %></strong></td></tr>
          <tr><th>Current Stock</th><td>
            <% const _qpp = Math.max(1, product.qty_per_pack||1); const _ctn = Math.floor((product.stock||0)/_qpp); const _loose = (product.stock||0) % _qpp; %>
            <strong class="<%= product.stock <= product.min_stock ? 'text-danger' : 'text-success' %> fs-5"><%= _ctn %> Ctn</strong>
            <% if (_loose > 0) { %><small class="text-muted ms-2">(+ <%= _loose %> loose pcs)</small><% } %>
          </td></tr>
          <tr><th>Min Stock</th><td><%= product.min_stock %></td></tr>
          <tr><th>Status</th><td><span class="badge bg-<%= statusBadge(product.status) %>"><%= product.status %></span></td></tr>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-7">
    <div class="card">
      <div class="card-header d-flex justify-content-between"><span>Rate History</span><a href="/ratelist" class="btn btn-sm btn-outline-primary">Manage Rates</a></div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead><tr><th>Customer Type</th><th>Rate</th><th>Effective Date</th></tr></thead>
          <tbody>
            <% rates.forEach(r => { %>
            <tr><td><%= r.customer_type %></td><td><%= formatCurrency(r.rate) %></td><td><%= formatDate(r.effective_date) %></td></tr>
            <% }) %>
            <% if (!rates.length) { %><tr><td colspan="3" class="text-center text-muted">No rate history</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Stock Movement Tracking -->
<div class="card mt-3">
  <div class="card-header">
    <h5 class="mb-0"><i class="bi bi-arrow-left-right"></i> Stock Movement Tracking</h5>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Date</th>
            <th>Party</th>
            <th>Type</th>
            <th class="text-end">Quantity</th>
            <th>Reference</th>
          </tr>
        </thead>
        <tbody>
          <% movements.forEach(m => { %>
          <tr>
            <td><small><%= formatDate(m.movement_date) %></small></td>
            <td><strong><%= m.party_name %></strong></td>
            <td>
              <% if (m.party_type === 'Customer') { %>
                <span class="badge bg-danger">Outbound</span>
              <% } else { %>
                <span class="badge bg-success">Inbound</span>
              <% } %>
            </td>
            <td class="text-end fw-bold"><%= m.quantity.toLocaleString() %></td>
            <td>
              <% if (m.doc_type === 'Order') { %>
                <a href="/orders/view/<%= m.order_id %>" class="btn btn-sm btn-outline-info">
                  <i class="bi bi-eye"></i> <%= m.reference_number %>
                </a>
              <% } else if (m.doc_type === 'Purchase') { %>
                <a href="/purchases/view/<%= m.purchase_id %>" class="btn btn-sm btn-outline-info">
                  <i class="bi bi-eye"></i> <%= m.reference_number %>
                </a>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% if (!movements.length) { %>
            <tr>
              <td colspan="5" class="text-center text-muted py-4">
                No stock movements found for this product
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
