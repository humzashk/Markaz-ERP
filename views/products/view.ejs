<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-box"></i> <%= product.name %></h2>
  <div class="d-flex gap-2">
    <a href="/products/edit/<%= product.id %>" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a href="/products" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>

<% const qpp = Math.max(1, product.qty_per_pack || 1); %>
<% const stockPcs = product.stock || 0; %>
<% const stockCtn = Math.floor(stockPcs / qpp); %>
<% const stockLoose = stockPcs % qpp; %>
<% const isLow = stockPcs <= (product.min_stock || 0); %>
<% const sellingRate = Number(product.selling_price || product.rate || 0); %>
<% const costRate = Number(product.cost_price || 0); %>
<% const margin = sellingRate - costRate; %>
<% const marginPct = costRate > 0 ? (margin / costRate * 100).toFixed(1) : null; %>

<!-- Key Metrics -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card border-success shadow-sm h-100">
      <div class="card-body text-center py-4">
        <div class="text-muted small text-uppercase fw-semibold mb-1">
          <i class="bi bi-tags-fill text-success"></i> Selling Rate / Pc
        </div>
        <div class="display-4 fw-bold text-success"><%= formatCurrency(sellingRate) %></div>
        <div class="text-muted small mt-1">Per Piece</div>
        <div class="mt-2 fs-6 fw-semibold text-secondary">
          <%= formatCurrency(sellingRate * qpp) %> / Ctn &nbsp;<span class="text-muted">(<%= qpp %> pcs)</span>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-<%= isLow ? 'danger' : 'primary' %> shadow-sm h-100">
      <div class="card-body text-center py-4">
        <div class="text-muted small text-uppercase fw-semibold mb-1">
          <i class="bi bi-boxes text-<%= isLow ? 'danger' : 'primary' %>"></i> Current Stock
        </div>
        <div class="display-4 fw-bold text-<%= isLow ? 'danger' : 'primary' %>">
          <%= stockCtn %> <small class="fs-4">Ctn</small>
        </div>
        <% if (stockLoose > 0) { %>
          <div class="text-muted small mt-1">+ <%= stockLoose %> loose pcs</div>
        <% } %>
        <div class="text-muted small mt-1"><%= stockPcs %> pcs total &nbsp;|&nbsp; Min: <%= product.min_stock || 0 %> pcs</div>
        <% if (isLow) { %><span class="badge bg-danger mt-1">&#9888; Low Stock</span><% } %>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-secondary shadow-sm h-100">
      <div class="card-body text-center py-4">
        <div class="text-muted small text-uppercase fw-semibold mb-1">
          <i class="bi bi-cash-coin text-secondary"></i> Cost Price / Pc
        </div>
        <div class="display-4 fw-bold text-secondary"><%= formatCurrency(costRate) %></div>
        <div class="text-muted small mt-1">Per Piece</div>
        <% if (marginPct !== null) { %>
          <div class="mt-2 fs-6 fw-semibold text-<%= margin >= 0 ? 'success' : 'danger' %>">
            Margin: <%= formatCurrency(margin) %> (<%= marginPct %>%)
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <!-- Product Details -->
  <div class="col-md-4">
    <div class="card">
      <div class="card-header fw-semibold"><i class="bi bi-info-circle"></i> Product Info</div>
      <div class="card-body">
        <table class="table table-sm table-borderless mb-0">
          <tbody>
            <tr><th style="width:45%">Item ID</th><td><code><%= product.item_id || '—' %></code></td></tr>
            <tr><th>Category</th><td><%= product.category || '—' %></td></tr>
            <tr><th>Unit</th><td><%= product.unit || 'PCS' %></td></tr>
            <tr><th>Pcs / Ctn</th><td><strong><%= qpp %></strong></td></tr>
            <tr><th>Commission %</th><td><%= product.default_commission_rate || 0 %>%</td></tr>
            <tr><th>Min Stock</th><td><%= product.min_stock || 0 %> pcs</td></tr>
            <tr><th>Status</th><td><span class="badge bg-<%= statusBadge(product.status) %>"><%= product.status %></span></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Recent Stock Movements -->
  <div class="col-md-8">
    <div class="card">
      <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
        <span><i class="bi bi-arrow-left-right"></i> Recent Stock Movements</span>
        <a href="/stock/movements?search=<%= encodeURIComponent(product.name) %>" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-clock-history"></i> Full History
        </a>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Party</th>
                <th class="text-end">Qty (Ctn)</th>
                <th class="text-end">Pcs</th>
              </tr>
            </thead>
            <tbody>
              <% if (movements && movements.length) { %>
                <% movements.forEach(m => { %>
                <tr>
                  <td><small><%= formatDate(m.movement_date || m.created_at) %></small></td>
                  <td>
                    <% if ((m.qty_delta || 0) >= 0) { %>
                      <span class="badge bg-success">In</span>
                    <% } else { %>
                      <span class="badge bg-danger">Out</span>
                    <% } %>
                    <small class="text-muted ms-1"><%= m.doc_type || m.ref_type || '' %></small>
                  </td>
                  <td><small><%= m.party_name || '—' %></small></td>
                  <td class="text-end fw-bold <%= (m.qty_delta||0) >= 0 ? 'text-success' : 'text-danger' %>">
                    <%= (m.qty_delta||0) >= 0 ? '+' : '' %><%= Math.floor(Math.abs(m.qty_delta||0) / qpp) * ((m.qty_delta||0) >= 0 ? 1 : -1) %>
                  </td>
                  <td class="text-end text-muted"><small><%= m.qty_delta || 0 %></small></td>
                </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="5" class="text-center text-muted py-3">No movements found</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
