<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-person"></i> <%= customer.name %></h2>
  <div class="d-flex gap-2">
    <a href="/customers/edit/<%= customer.id %>" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a href="/ledger/customer/<%= customer.id %>" class="btn btn-outline-secondary"><i class="bi bi-journal-text"></i> Ledger</a>
    <a href="/payments/add?type=customer&entity_id=<%= customer.id %>" class="btn btn-success"><i class="bi bi-cash"></i> Receive Payment</a>
    <a href="/customers" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>
<div class="row g-3 mb-4">
  <div class="col-md-5">
    <div class="card">
      <div class="card-header">Customer Info</div>
      <div class="card-body">
        <table class="table table-borderless mb-0">
          <tr><th width="120">Phone</th><td><%= customer.phone || '-' %></td></tr>
          <tr><th>Email</th><td><%= customer.email || '-' %></td></tr>
          <tr><th>City</th><td><%= customer.city || '-' %></td></tr>
          <tr><th>Address</th><td><%= customer.address || '-' %></td></tr>
          <tr><th>Status</th><td><span class="badge bg-<%= statusBadge(customer.status) %>"><%= customer.status %></span></td></tr>
          <tr>
            <th>Balance</th>
            <td class="<%= customer.balance > 0 ? 'due-amount fs-5' : 'credit-amount fs-5' %>">
              <%= formatCurrency(customer.balance) %>
              <% if (customer.balance > 0) { %><span class="badge bg-danger ms-2">Due</span><% } %>
            </td>
          </tr>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-7">
    <div class="card">
      <div class="card-header">Recent Invoices</div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead><tr><th>Invoice No</th><th>Date</th><th>Total</th><th>Status</th></tr></thead>
          <tbody>
            <% invoices.forEach(inv => { %>
            <tr>
              <td><a href="/invoices/view/<%= inv.id %>"><%= inv.invoice_no %></a></td>
              <td><%= formatDate(inv.invoice_date) %></td>
              <td><%= formatCurrency(inv.total) %></td>
              <td><span class="badge bg-<%= statusBadge(inv.status) %>"><%= inv.status %></span></td>
            </tr>
            <% }) %>
            <% if (!invoices.length) { %><tr><td colspan="4" class="text-center text-muted">No invoices</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
