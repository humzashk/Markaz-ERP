            <tr>
              <td><a href="/customers/ledger/<%= c.id %>"><strong><%= c.name %></strong></a></td>
              <td class="small"><%= c.phone || '—' %></td>
              <td class="text-end small"><%= formatDate(c.last_order) %></td>
              <td class="text-end"><span class="badge bg-info"><%= Math.round(c.days_since) %>d</span></td>
              <td><a href="/orders/add?customer_id=<%= c.id %>" class="btn btn-sm btn-outline-primary">Order</a></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } else { %><div class="p-3 text-center text-muted small">No reorder predictions</div><% } %>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card h-100 ai-card">
      <div class="card-header"><i class="bi bi-shield-exclamation text-danger"></i> AI: Credit Risk Scoring</div>
      <div class="card-body p-0">
