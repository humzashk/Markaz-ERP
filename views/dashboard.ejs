              <td class="text-end"><%= formatCurrency(c.balance) %></td>
              <td class="text-end text-danger"><a href="/invoices?customer_id=<%= c.id %>&status=overdue" class="text-decoration-none text-danger"><%= formatCurrency(c.overdue_amt) %> <span class="text-muted small">(<%= c.overdue_cnt %>)</span></a></td>
              <td><span class="badge bg-<%= c.risk==='high'?'danger':c.risk==='medium'?'warning text-dark':'success' %>"><%= c.risk.toUpperCase() %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } else { %><div class="p-3 text-center text-success small"><i class="bi bi-check-circle"></i> No credit risk</div><% } %>
      </div>
    </div>
  </div>
</div>

<!-- Anomalies + Bottlenecks -->
<div class="row g-3 mb-3">
