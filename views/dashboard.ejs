      </div>
    </div>
  </div>
</div>
<% } %>

<!-- User Monitoring (Audit Log) -->
<% if (can('dash.audit')) { %>
<div class="row g-3 mb-3">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between">
        <span><i class="bi bi-person-check"></i> User Activity Monitoring (Last 7 Days)</span>
        <a href="/reports/audit-log" class="small">Full Audit Log →</a>
      </div>
      <div class="card-body p-0">
        <% if (userEdits.length) { %>
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>User</th>
                <th>Action</th>
                <th>Type</th>
                <th>Reference</th>
                <th>Party</th>
                <th class="text-end">Amount</th>
                <th class="text-end">When</th>
                <th class="text-center">View</th>
              </tr>
            </thead>
            <tbody>
              <% userEdits.forEach(u => { %>
              <tr class="audit-row <%= u.link ? 'clickable' : '' %>" <%= u.link ? `onclick="window.location.href='${u.link}'"` : '' %>>
                <td onclick="event.stopPropagation()">
                  <% if (u.user_link) { %>
                    <a href="<%= u.user_link %>" class="text-decoration-none">
                      <i class="bi bi-person-circle"></i>
                      <strong><%= u.user_name || u.username || 'system' %></strong>
                      <% if (u.role) { %><span class="badge bg-<%= u.role==='superadmin'?'danger':u.role==='admin'?'primary':'secondary' %> ms-1" style="font-size:10px"><%= u.role %></span><% } %>
                    </a>
                  <% } else { %>
                    <i class="bi bi-gear"></i> <em class="text-muted">system</em>
                  <% } %>
                </td>
                <td><span class="badge audit-action-<%= u.action %>"><%= u.action.toUpperCase() %></span></td>
                <td><small class="text-muted"><%= u.entity_type || '—' %></small></td>
                <td>
                  <% if (u.link && u.ref_no) { %>
                    <span class="fw-bold text-primary"><%= u.ref_no %></span>
                  <% } else if (u.ref_no) { %>
                    <span class="fw-bold"><%= u.ref_no %></span>
                  <% } else { %>
                    <span class="text-muted small"><%= u.entity_id ? '#'+u.entity_id : '—' %></span>
                  <% } %>
                </td>
                <td><small><%= u.party_name || '—' %></small></td>
                <td class="text-end">
                  <% if (u.amount) { %>
                    <strong><%= formatCurrency(u.amount) %></strong>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>
                <td class="text-end small text-muted"><%= formatDate(u.created_at) %></td>
                <td class="text-center" onclick="event.stopPropagation()">
                  <% if (u.link && u.action !== 'delete') { %>
                    <a href="<%= u.link %>" class="btn btn-sm btn-outline-primary" title="View transaction"><i class="bi bi-eye"></i></a>
                  <% } else if (u.action === 'delete') { %>
                    <span class="badge bg-danger" title="Record was deleted"><i class="bi bi-trash"></i> Deleted</span>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <small class="d-block text-muted text-center py-2"><i class="bi bi-info-circle"></i> Click any row to view the transaction</small>
        <% } else { %>
        <div class="p-3 text-center text-muted small">No user activity in the last 7 days</div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<% } %>

