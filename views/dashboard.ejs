              <td><a href="/products/edit/<%= p.id %>"><strong><%= p.name %></strong></a></td>
              <td class="text-end"><%= formatCurrency(p.revenue) %></td>
              <td class="text-end text-danger"><%= formatCurrency(p.profit) %></td>
              <td class="text-end"><span class="badge bg-warning text-dark"><%= m %>%</span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } else { %><div class="p-3 text-center text-success small"><i class="bi bi-check-circle"></i> No profit leakage</div><% } %>
      </div>
    </div>
  </div>
  <% } %>
</div>
<% } %>

<!-- AI Insights -->
<% if (can('dash.ai')) { %>
<div class="section-title">AI INSIGHTS & RISK</div>
<div class="row g-3 mb-3">
  <div class="col-md-6">
    <div class="card h-100 ai-card">
      <div class="card-header"><i class="bi bi-arrow-repeat text-primary"></i> Customer Reorder Prediction</div>
      <div class="card-body p-0">
        <% if (reorderPredictions.length) { %>
        <table class="table table-sm mb-0">
          <thead class="table-light"><tr><th>Customer</th><th>Phone</th><th class="text-end">Last Order</th><th class="text-end">Days</th><th>Action</th></tr></thead>
          <tbody>
