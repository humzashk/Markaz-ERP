  </div>
</div>
<% } %>

<% if (can('dash.charts')) { %>
<script>
const chartData = <%- JSON.stringify(chartData) %>;
function initRevenueChart() {
  if (typeof Chart === 'undefined') { return setTimeout(initRevenueChart, 50); }
  const el = document.getElementById('revenueChart');
  if (!el) return;
  const ctx = el.getContext('2d');
  new Chart(ctx, {
  type: 'bar',
  data: {
    labels: chartData.map(d => d.month),
    datasets: [
      { label: 'Sales', data: chartData.map(d => d.sales), backgroundColor: 'rgba(52,152,219,0.85)', borderRadius: 4 },
      { label: 'COGS',  data: chartData.map(d => d.cogs),  backgroundColor: 'rgba(231,76,60,0.75)', borderRadius: 4 }
    ]
  },
  options: {
    responsive: true,
    plugins: { legend: { position: 'top' }, tooltip: { callbacks: { label: ctx => ' PKR ' + ctx.parsed.y.toLocaleString('en-PK', {minimumFractionDigits:0}) } } },
    scales: { y: { beginAtZero: true, ticks: { callback: v => 'PKR' + (v>=1000 ? (v/1000).toFixed(0)+'k' : v) } } }
  }
});
}
if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initRevenueChart);
else initRevenueChart();
</script>
<% } %>
<%- include('partials/footer') %>
