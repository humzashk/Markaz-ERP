<%- include('partials/header') %>
<% if (typeof dashboardErrors !== 'undefined' && dashboardErrors && dashboardErrors.length) { %>
  <div class="alert alert-warning d-flex align-items-start gap-2 mb-3" role="alert">
    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
    <div>
      <strong>Some dashboard metrics could not be loaded (<%= dashboardErrors.length %> issue<%= dashboardErrors.length===1?'':'s' %>).</strong>
      Affected widgets show fallback values. Errors have been logged for review.
      <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'superadmin') { %>
        <details class="mt-1"><summary class="small">Details</summary>
          <ul class="small mb-0">
            <% dashboardErrors.slice(0,10).forEach(function(e){ %>
              <li><code><%= e.scope %></code>: <%= e.message %></li>
            <% }); %>
          </ul>
        </details>
      <% } %>
    </div>
  </div>
<% } %>
<style>
  .ai-card { border-left: 4px solid #6366f1; background: linear-gradient(135deg,#f5f3ff,#fff); }
  .risk-high { background: #fee2e2 !important; }
  .risk-medium { background: #fef3c7 !important; }
  .risk-low { background: #d1fae5 !important; }
  .neg-stock { background: #fecaca !important; font-weight: 700; }
  .metric-mini { padding: 10px 12px; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; }
  .metric-mini .lbl { font-size: 10px; text-transform: uppercase; color: #6b7280; letter-spacing: .5px; font-weight: 600; }
  .metric-mini .val { font-size: 16px; font-weight: 700; margin-top: 2px; }
  .acct-card { background: linear-gradient(135deg,#fff,#f8fafc); border: 1px solid #e5e7eb; border-radius: 10px; padding: 14px; transition: all .15s; }
  .acct-card:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,0,0,.08); }
  .acct-card.acct-active { border-color: #3b82f6; box-shadow: 0 0 0 2px rgba(59,130,246,.2); }
  .suggestion-pill { display: flex; align-items: center; gap: 8px; padding: 8px 12px; margin-bottom: 6px; border-radius: 6px; font-size: 13px; text-decoration: none; transition: all .15s; }
  .suggestion-pill:hover { transform: translateX(3px); }
  .ageing-block { padding: 12px; border-radius: 8px; text-align: center; cursor: pointer; transition: all .15s; text-decoration: none; display: block; }
  .ageing-block:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,.1); }
  .ageing-30 { background: #fef3c7; color: #92400e; }
  .ageing-60 { background: #fed7aa; color: #9a3412; }
  .ageing-90 { background: #fecaca; color: #991b1b; }
  .section-title { font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: #6b7280; font-weight: 700; margin: 18px 0 8px; padding-left: 4px; border-left: 3px solid #3b82f6; }
  .stat-card-link { text-decoration: none; color: inherit; display: block; transition: transform .15s; }
  .stat-card-link:hover { transform: translateY(-2px); color: inherit; }
  .audit-row td { vertical-align: middle; }
  .audit-row.clickable { cursor: pointer; transition: background .15s; }
  .audit-row.clickable:hover { background: #eff6ff !important; }
  .audit-action-create { background: #d1fae5; color: #065f46; }
  .audit-action-update { background: #fef3c7; color: #92400e; }
  .audit-action-delete { background: #fecaca; color: #991b1b; }
</style>

<div class="page-header">
  <h2><i class="bi bi-speedometer2"></i> Dashboard
    <% if (isSuperadmin) { %><span class="badge bg-danger ms-2" style="font-size:11px;">SUPERADMIN</span><% } %>
  </h2>
  <div class="d-flex gap-2">
    <a href="/orders/add" class="btn btn-primary"><i class="bi bi-cart-plus"></i> New Order</a>
    <a href="/invoices/add" class="btn btn-success"><i class="bi bi-receipt"></i> New Invoice</a>
    <a href="/purchases/add" class="btn btn-warning"><i class="bi bi-bag-plus"></i> New Purchase</a>
  </div>
</div>

<!-- Period + Account Filter -->
<div class="period-bar mb-3">
  <div class="d-flex align-items-center gap-2 flex-wrap">
    <span class="text-muted small fw-semibold me-1">PERIOD:</span>
    <% ['today','week','month','year','lastyear','all'].forEach(p => { %>
    <a href="?period=<%= p %><%= accountFilter ? '&account='+accountFilter : '' %>" class="period-btn <%= period === p ? 'active' : '' %>">
      <%= p === 'today' ? 'Today' : p === 'week' ? '7 Days' : p === 'month' ? 'This Month' : p === 'year' ? 'This Year' : p === 'lastyear' ? 'Last Year' : 'All Time' %>
    </a>
    <% }) %>
    <span class="ms-2 badge bg-light text-dark border fw-normal" style="font-size:13px"><i class="bi bi-calendar2-check text-primary me-1"></i><%= rangeLabel %></span>

    <span class="text-muted small fw-semibold ms-3 me-1">ACCOUNT:</span>
    <a href="?period=<%= period %>" class="period-btn <%= !accountFilter ? 'active' : '' %>">All</a>
    <a href="?period=<%= period %>&account=plastic_markaz" class="period-btn <%= accountFilter==='plastic_markaz' ? 'active' : '' %>">Plastic Markaz</a>
    <a href="?period=<%= period %>&account=wings_furniture" class="period-btn <%= accountFilter==='wings_furniture' ? 'active' : '' %>">Wings Furniture</a>
    <a href="?period=<%= period %>&account=cooler" class="period-btn <%= accountFilter==='cooler' ? 'active' : '' %>">Cooler</a>
  </div>
</div>

<!-- AI Smart Suggestions -->
<% if (can('dash.ai') && suggestions.length) { %>
<div class="card ai-card mb-3">
  <div class="card-body p-3">
    <div class="d-flex align-items-center mb-2">
      <i class="bi bi-stars text-primary fs-5 me-2"></i>
      <strong>AI Smart Suggestions</strong>
      <span class="badge bg-primary ms-2"><%= suggestions.length %></span>
      <small class="text-muted ms-2">(click to take action)</small>
    </div>
    <div class="row g-2">
      <% suggestions.forEach(s => { %>
      <div class="col-md-6">
        <a href="<%= s.link %>" class="suggestion-pill bg-<%= s.color %> bg-opacity-10 text-<%= s.color %>">
          <i class="bi bi-<%= s.icon %>"></i> <span><%= s.text %></span>
          <i class="bi bi-arrow-right ms-auto"></i>
        </a>
      </div>
      <% }) %>
    </div>
  </div>
</div>
<% } %>

<!-- Row 1: Core Financials -->
<% if (can('dash.financials')) { %>
<div class="row g-3 mb-3">
  <div class="col-6 col-md-3 col-lg-2">
    <a href="/invoices" class="stat-card-link">
      <div class="stat-card stat-blue">
        <div class="stat-icon"><i class="bi bi-receipt"></i></div>
        <div class="stat-info"><h3><%= formatCurrency(rangeRev) %></h3><p>Sales</p><small style="opacity:.85"><%= rangeLabel %></small></div>
      </div>
    </a>
  </div>
  <div class="col-6 col-md-3 col-lg-2">
    <a href="/reports" class="stat-card-link">
      <div class="stat-card <%= rangeProfit >= 0 ? 'stat-green' : 'stat-red' %>">
        <div class="stat-icon"><i class="bi bi-graph-up"></i></div>
        <div class="stat-info"><h3><%= formatCurrency(rangeProfit) %></h3><p>Net Profit</p><small style="opacity:.85"><%= rangeMargin %>% margin</small></div>
      </div>
    </a>
  </div>
  <div class="col-6 col-md-3 col-lg-2">
    <a href="/purchases" class="stat-card-link">
      <div class="stat-card stat-orange">
        <div class="stat-icon"><i class="bi bi-bag"></i></div>
        <div class="stat-info"><h3><%= formatCurrency(rangePurchases) %></h3><p>Purchases</p></div>
      </div>
    </a>
  </div>
  <div class="col-6 col-md-3 col-lg-2">
    <a href="/customers" class="stat-card-link">
      <div class="stat-card stat-teal">
        <div class="stat-icon"><i class="bi bi-arrow-down-circle"></i></div>
        <div class="stat-info"><h3><%= formatCurrency(totalReceivables) %></h3><p>Receivables</p></div>
      </div>
    </a>
  </div>
  <div class="col-6 col-md-3 col-lg-2">
    <a href="/vendors" class="stat-card-link">
      <div class="stat-card stat-red">
        <div class="stat-icon"><i class="bi bi-arrow-up-circle"></i></div>
        <div class="stat-info"><h3><%= formatCurrency(totalPayables) %></h3><p>Payables</p></div>
      </div>
    </a>
  </div>
  <div class="col-6 col-md-3 col-lg-2">
    <a href="/bank" class="stat-card-link">
      <div class="stat-card stat-purple">
        <div class="stat-icon"><i class="bi bi-bank"></i></div>
        <div class="stat-info"><h3><%= formatCurrency(bankBalance) %></h3><p>Bank</p></div>
      </div>
    </a>
  </div>
</div>
<% } %>

<!-- Profit Breakdown + Cash Position -->
<% if (can('dash.profit') || can('dash.cash')) { %>
<div class="row g-3 mb-3">
  <% if (can('dash.profit')) { %>
  <div class="col-md-8">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between"><span><i class="bi bi-pie-chart"></i> Profit Breakdown (<%= rangeLabel %>)</span><a href="/reports" class="small">View Full Report →</a></div>
      <div class="card-body">
        <div class="row g-2">
          <div class="col-md-2 col-6"><a href="/invoices" class="text-decoration-none"><div class="metric-mini"><div class="lbl">Revenue</div><div class="val text-success"><%= formatCurrency(rangeRev) %></div></div></a></div>
          <div class="col-md-2 col-6"><a href="/reports" class="text-decoration-none"><div class="metric-mini"><div class="lbl">- COGS</div><div class="val text-danger"><%= formatCurrency(rangeCOGS) %></div></div></a></div>
          <div class="col-md-2 col-6"><a href="/invoices" class="text-decoration-none"><div class="metric-mini"><div class="lbl">- Commission</div><div class="val text-danger"><%= formatCurrency(rangeCommission) %></div></div></a></div>
          <div class="col-md-2 col-6"><a href="/bilty" class="text-decoration-none"><div class="metric-mini"><div class="lbl">- Delivery</div><div class="val text-danger"><%= formatCurrency(rangeDelivery) %></div></div></a></div>
          <div class="col-md-2 col-6"><a href="/expenses" class="text-decoration-none"><div class="metric-mini"><div class="lbl">- Expenses</div><div class="val text-danger"><%= formatCurrency(rangeExp) %></div></div></a></div>
          <div class="col-md-2 col-6"><div class="metric-mini" style="background:<%= rangeProfit>=0?'#d1fae5':'#fee2e2' %>"><div class="lbl">= Net Profit</div><div class="val <%= rangeProfit>=0?'text-success':'text-danger' %>"><%= formatCurrency(rangeProfit) %></div></div></div>
        </div>
        <div class="mt-3 small text-muted">
          <strong>Today:</strong> Sales <%= formatCurrency(todayRev) %> | Profit <%= formatCurrency(todayProfit) %> &nbsp;|&nbsp;
          <strong>Month:</strong> <%= formatCurrency(monthRev) %> / <%= formatCurrency(monthProfit) %> &nbsp;|&nbsp;
          <strong>Year:</strong> <%= formatCurrency(yearRev) %> / <%= formatCurrency(yearProfit) %>
        </div>
      </div>
    </div>
  </div>
  <% } %>
  <% if (can('dash.cash')) { %>
  <div class="col-md-<%= can('dash.profit') ? '4' : '12' %>">
    <div class="card h-100">
      <div class="card-header"><i class="bi bi-cash-stack"></i> Cash Position</div>
      <div class="card-body">
        <a href="/bank" class="d-flex justify-content-between py-1 text-decoration-none text-dark"><span class="text-muted">Bank Balance</span><strong class="text-success"><%= formatCurrency(bankBalance) %></strong></a>
        <a href="/customers" class="d-flex justify-content-between py-1 text-decoration-none text-dark"><span class="text-muted">+ Receivables</span><strong class="text-info"><%= formatCurrency(totalReceivables) %></strong></a>
        <a href="/vendors" class="d-flex justify-content-between py-1 text-decoration-none text-dark"><span class="text-muted">- Payables</span><strong class="text-danger">(<%= formatCurrency(totalPayables) %>)</strong></a>
        <hr class="my-2">
        <div class="d-flex justify-content-between py-1"><strong>Net Position</strong><strong class="<%= cashPosition>=0?'text-success':'text-danger' %>"><%= formatCurrency(cashPosition) %></strong></div>
      </div>
    </div>
  </div>
  <% } %>
</div>
<% } %>

<!-- Aging + Activity -->
<% if (can('dash.aging') || can('dash.activity')) { %>
<div class="row g-3 mb-3">
  <% if (can('dash.aging')) { %>
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between"><span><i class="bi bi-alarm"></i> Overdue Aging Analysis</span><a href="/invoices?status=overdue" class="small">View All →</a></div>
      <div class="card-body">
        <div class="row g-2">
          <div class="col-4"><a href="/invoices?status=overdue&aging=30" class="ageing-block ageing-30">
            <div class="small">1-30 Days</div><h5 class="my-1"><%= formatCurrency(aging30.v) %></h5><div class="small"><%= aging30.c %> invoices</div>
          </a></div>
          <div class="col-4"><a href="/invoices?status=overdue&aging=60" class="ageing-block ageing-60">
            <div class="small">31-60 Days</div><h5 class="my-1"><%= formatCurrency(aging60.v) %></h5><div class="small"><%= aging60.c %> invoices</div>
          </a></div>
          <div class="col-4"><a href="/invoices?status=overdue&aging=90" class="ageing-block ageing-90">
            <div class="small">90+ Days</div><h5 class="my-1"><%= formatCurrency(aging90.v) %></h5><div class="small"><%= aging90.c %> invoices</div>
          </a></div>
        </div>
      </div>
    </div>
  </div>
  <% } %>
  <% if (can('dash.activity')) { %>
  <div class="col-md-<%= can('dash.aging') ? '6' : '12' %>">
    <div class="card h-100">
      <div class="card-header"><i class="bi bi-activity"></i> Sales Activity (<%= rangeLabel %>)</div>
      <div class="card-body">
        <div class="row g-2">
          <div class="col-3"><a href="/orders" class="text-decoration-none"><div class="metric-mini text-center"><div class="lbl">Orders</div><div class="val text-primary"><%= totalOrders %></div></div></a></div>
          <div class="col-3"><a href="/invoices" class="text-decoration-none"><div class="metric-mini text-center"><div class="lbl">Invoices</div><div class="val text-success"><%= totalInvoices %></div></div></a></div>
          <div class="col-3"><a href="/reports" class="text-decoration-none"><div class="metric-mini text-center"><div class="lbl">Conversion</div><div class="val text-info"><%= conversionRate %>%</div></div></a></div>
          <div class="col-3"><a href="/customers" class="text-decoration-none"><div class="metric-mini text-center"><div class="lbl">Customers</div><div class="val"><%= totalCustomers %></div></div></a></div>
        </div>
        <div class="row g-2 mt-2">
          <div class="col-4"><a href="/invoices?status=unpaid" class="text-decoration-none"><div class="metric-mini text-center"><div class="lbl">Unpaid</div><div class="val text-danger"><%= unpaidInvoices %></div></div></a></div>
          <div class="col-4"><a href="/orders?status=pending" class="text-decoration-none"><div class="metric-mini text-center"><div class="lbl">Pending Orders</div><div class="val text-warning"><%= pendingOrders %></div></div></a></div>
          <div class="col-4"><a href="/invoices?status=overdue" class="text-decoration-none"><div class="metric-mini text-center"><div class="lbl">Overdue</div><div class="val text-danger"><%= overdueInvoices %></div></div></a></div>
        </div>
      </div>
    </div>
  </div>
  <% } %>
</div>
<% } %>

<!-- Account Performance -->
<% if (can('dash.accounts')) { %>
<div class="section-title">ACCOUNT PERFORMANCE</div>
<div class="row g-3 mb-3">
  <% accountList.forEach(a => { %>
  <div class="col-md-4">
    <a href="?period=<%= period %>&account=<%= a.scope %>" class="text-decoration-none text-dark">
      <div class="acct-card <%= accountFilter===a.scope ? 'acct-active' : '' %>">
        <div class="d-flex justify-content-between align-items-center">
          <strong><%= a.name %></strong>
          <span class="btn btn-sm btn-outline-primary">View</span>
        </div>
        <div class="row g-2 mt-2">
          <div class="col-6"><div class="lbl text-muted small">Revenue</div><div class="h5 mb-0 text-success"><%= formatCurrency(a.revenue) %></div></div>
          <div class="col-6"><div class="lbl text-muted small">Invoices</div><div class="h5 mb-0"><%= a.invoices %></div></div>
        </div>
      </div>
    </a>
  </div>
  <% }) %>
</div>
<% } %>

<!-- Charts + AI Forecast -->
<% if (can('dash.charts') || can('dash.ai')) { %>
<div class="row g-3 mb-3">
  <% if (can('dash.charts')) { %>
  <div class="col-lg-<%= can('dash.ai') ? '8' : '12' %>">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="bi bi-bar-chart"></i> Sales vs COGS</span>
        <div class="d-flex align-items-center gap-2">
          <% var _g = (typeof chartGran !== 'undefined' ? chartGran : '6months'); %>
          <% var _qs = function(g){ var p = new URLSearchParams(); if (typeof period !== 'undefined' && period) p.set('period', period); if (typeof accountFilter !== 'undefined' && accountFilter) p.set('account', accountFilter); p.set('chart', g); return '/?' + p.toString(); }; %>
          <select class="form-select form-select-sm" style="width:auto" onchange="window.location.href=this.value">
            <option value="<%= _qs('day') %>"        <%= _g==='day'?'selected':'' %>>Daily (14 days)</option>
            <option value="<%= _qs('week') %>"       <%= _g==='week'?'selected':'' %>>Weekly (12 weeks)</option>
            <option value="<%= _qs('month') %>"      <%= _g==='month'?'selected':'' %>>This Month</option>
            <option value="<%= _qs('quarter') %>"    <%= _g==='quarter'?'selected':'' %>>This Quarter</option>
            <option value="<%= _qs('lastquarter') %>"<%= _g==='lastquarter'?'selected':'' %>>Last Quarter</option>
            <option value="<%= _qs('6months') %>"    <%= _g==='6months'?'selected':'' %>>Last 6 Months</option>
            <option value="<%= _qs('year') %>"       <%= _g==='year'?'selected':'' %>>Last 12 Months</option>
          </select>
          <a href="/reports" class="btn btn-sm btn-outline-secondary">All Reports</a>
        </div>
      </div>
      <div class="card-body"><canvas id="revenueChart" height="90"></canvas></div>
    </div>
  </div>
  <% } %>
  <% if (can('dash.ai')) { %>
  <div class="col-lg-<%= can('dash.charts') ? '4' : '12' %>">
    <div class="card h-100 ai-card">
      <div class="card-header"><i class="bi bi-stars text-primary"></i> AI Sales Forecast</div>
      <div class="card-body">
        <div class="mb-3"><div class="lbl text-muted small">Daily Avg (last 30d)</div><div class="h4 mb-0"><%= formatCurrency(Math.round(dailyAvg)) %></div></div>
        <div class="row g-2">
          <div class="col-6"><a href="/reports" class="text-decoration-none"><div class="metric-mini text-center"><div class="lbl">Next 7 Days</div><div class="val text-primary"><%= formatCurrency(forecast7d) %></div></div></a></div>
          <div class="col-6"><a href="/reports" class="text-decoration-none"><div class="metric-mini text-center"><div class="lbl">Next 30 Days</div><div class="val text-success"><%= formatCurrency(forecast30d) %></div></div></a></div>
        </div>
        <div class="small text-muted mt-2"><i class="bi bi-info-circle"></i> Based on 30-day trailing avg</div>
      </div>
    </div>
  </div>
  <% } %>
</div>
<% } %>

<!-- Stock Intelligence -->
<% if (can('dash.stock')) { %>
<div class="section-title">INVENTORY INTELLIGENCE</div>
<div class="row g-3 mb-3">
  <div class="col-md-3">
    <a href="/reports/inventory-value" class="stat-card-link">
      <div class="stat-card stat-teal">
        <div class="stat-icon"><i class="bi bi-boxes"></i></div>
        <div class="stat-info"><h3><%= formatCurrency(stockValue) %></h3><p>Stock Value</p></div>
      </div>
    </a>
  </div>
  <div class="col-md-3">
    <a href="/reports/low-stock" class="stat-card-link">
      <div class="stat-card stat-orange">
        <div class="stat-icon"><i class="bi bi-exclamation-circle"></i></div>
        <div class="stat-info"><h3><%= lowStock.length %></h3><p>Low Stock Items</p></div>
      </div>
    </a>
  </div>
  <div class="col-md-3">
    <a href="/products?stock=out" class="stat-card-link">
      <div class="stat-card stat-red">
        <div class="stat-icon"><i class="bi bi-x-circle"></i></div>
        <div class="stat-info"><h3><%= outOfStockCount %></h3><p>Out of Stock</p></div>
      </div>
    </a>
  </div>
  <div class="col-md-3">
    <a href="/products?stock=negative" class="stat-card-link">
      <div class="stat-card" style="background:linear-gradient(135deg,#7f1d1d,#dc2626);color:#fff;">
        <div class="stat-icon"><i class="bi bi-dash-circle"></i></div>
        <div class="stat-info"><h3><%= negativeStock.length %></h3><p>Negative Stock ⚠</p></div>
      </div>
    </a>
  </div>
</div>

<div class="row g-3 mb-3">
  <% if (negativeStock.length) { %>
  <div class="col-md-6">
    <div class="card h-100 border-danger">
      <div class="card-header bg-danger text-white"><i class="bi bi-dash-circle"></i> Negative Stock Alert</div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead class="table-light"><tr><th>Product</th><th class="text-end">Stock</th><th>Action</th></tr></thead>
          <tbody>
            <% negativeStock.forEach(p => { %>
            <tr class="neg-stock">
              <td><a href="/products/edit/<%= p.id %>"><%= p.name %></a></td>
              <td class="text-end fw-bold"><%= p.stock %></td>
              <td><a href="/stock/add?product_id=<%= p.id %>" class="btn btn-sm btn-danger">Fix</a></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } %>

  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header text-warning d-flex justify-content-between"><span><i class="bi bi-exclamation-triangle"></i> Low Stock</span><a href="/reports/low-stock" class="small">View All →</a></div>
      <div class="card-body p-0">
        <ul class="list-group list-group-flush">
          <% lowStock.forEach(p => { %>
          <li class="list-group-item d-flex justify-content-between align-items-center py-2">
            <a href="/products/edit/<%= p.id %>" class="text-decoration-none text-dark"><%= p.name %></a>
            <a href="/stock/add?product_id=<%= p.id %>" class="badge bg-warning text-dark text-decoration-none"><%= p.stock %> / min <%= p.min_stock %></a>
          </li>
          <% }) %>
          <% if (!lowStock.length) { %><li class="list-group-item text-success small"><i class="bi bi-check-circle"></i> All stock OK</li><% } %>
        </ul>
      </div>
    </div>
  </div>

  <% if (!negativeStock.length && can('dash.ai')) { %>
  <div class="col-md-6">
    <div class="card h-100 ai-card">
      <div class="card-header"><i class="bi bi-stars text-primary"></i> AI: Stock-Out Risk (Next 14 Days)</div>
      <div class="card-body p-0">
        <% if (stockOutRisk.length) { %>
        <table class="table table-sm mb-0">
          <thead class="table-light"><tr><th>Product</th><th>Stock</th><th>Sold/30d</th><th>Days</th></tr></thead>
          <tbody>
            <% stockOutRisk.forEach(s => { %>
            <tr class="<%= s.days_left <= 7 ? 'risk-high' : 'risk-medium' %>">
              <td><a href="/products/edit/<%= s.id %>"><strong><%= s.name %></strong></a></td>
              <td><%= s.stock %></td>
              <td><%= s.sold_30d %></td>
              <td><a href="/stock/add?product_id=<%= s.id %>" class="badge bg-<%= s.days_left<=7?'danger':'warning text-dark' %> text-decoration-none"><%= s.days_left %>d</a></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } else { %>
        <div class="p-3 text-center text-muted small">No imminent stock-outs.</div>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>
</div>

<!-- Stock Forecast: Running Items Only -->
<div class="row g-3 mb-3">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between"><span><i class="bi bi-speedometer"></i> Stock Forecast - Running Items (sold within last 90 days)</span><a href="/reports/stock-position" class="small">Full Report →</a></div>
      <div class="card-body p-0">
        <% if (stockVelocity.length) { %>
        <div class="table-responsive">
          <table class="table table-sm mb-0">
            <thead class="table-light"><tr><th>Product</th><th>Stock</th><th>Sold/30d</th><th>Sold/90d</th><th>Days Left</th><th>Action</th></tr></thead>
            <tbody>
              <% stockVelocity.forEach(s => { %>
              <tr class="<%= s.days_left <= 7 ? 'risk-high' : s.days_left <= 14 ? 'risk-medium' : '' %>">
                <td><a href="/products/edit/<%= s.id %>"><strong><%= s.name %></strong></a></td>
                <td><%= s.stock %></td>
                <td><%= s.sold_30d %></td>
                <td><%= s.sold_90d %></td>
                <td>
                  <% if (s.days_left <= 7) { %><span class="badge bg-danger"><%= s.days_left %>d ⚠</span>
                  <% } else if (s.days_left <= 14) { %><span class="badge bg-warning text-dark"><%= s.days_left %>d</span>
                  <% } else { %><span class="badge bg-success"><%= s.days_left %>d</span><% } %>
                </td>
                <td>
                  <% if (s.days_left <= 14) { %>
                    <a href="/purchases/add?product_id=<%= s.id %>" class="btn btn-sm btn-outline-danger">Reorder</a>
                  <% } else { %>
                    <a href="/stock/ledger?product_id=<%= s.id %>" class="btn btn-sm btn-outline-secondary">Ledger</a>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="p-4 text-center text-muted small">No running items found (no sales in last 90 days).</div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Top Customers -->
<% if (can('dash.customers')) { %>
<div class="section-title">TOP CUSTOMERS</div>
<div class="row g-3 mb-3">
