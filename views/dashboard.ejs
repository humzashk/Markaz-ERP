<%- include('partials/header') %>
<style>
  /* Minimal dashboard — white bg, black/grey text, no decorative gradients */
  .dash-wrap { background:#fff; color:#1f2937; }
  .dash-wrap h2, .dash-wrap h3 { color:#111827; font-weight:600; letter-spacing:-.01em; }
  .dash-wrap .text-muted { color:#6b7280 !important; }
  .metric { background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:18px 20px; transition:border-color .12s; }
  .metric:hover { border-color:#9ca3af; }
  .metric .lbl { font-size:11px; text-transform:uppercase; letter-spacing:1px; color:#6b7280; font-weight:600; }
  .metric .val { font-size:24px; font-weight:700; color:#111827; margin-top:6px; line-height:1.1; }
  .metric .sub { font-size:12px; color:#6b7280; margin-top:4px; }
  .metric.alert-low { border-left:4px solid #ef4444; }
  .metric.alert-warn { border-left:4px solid #f59e0b; }
  .dash-card { background:#fff; border:1px solid #e5e7eb; border-radius:10px; }
  .dash-card .card-header { background:#fafafa; border-bottom:1px solid #e5e7eb; font-weight:600; color:#111827; padding:12px 16px; display:flex; justify-content:space-between; align-items:center; }
  .dash-card .card-body { padding:0; }
  .dash-card table { margin:0; }
  .dash-card .table thead th { background:#fafafa; color:#374151; border-bottom:1px solid #e5e7eb; font-size:12px; text-transform:uppercase; letter-spacing:.5px; font-weight:600; }
  .dash-card .table td { vertical-align:middle; color:#1f2937; }
  .pill { display:inline-block; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:600; background:#f3f4f6; color:#374151; }
  .pill-warn { background:#fef3c7; color:#92400e; }
  .pill-danger { background:#fee2e2; color:#991b1b; }
  .pill-success { background:#d1fae5; color:#065f46; }
  .view-all { font-size:12px; color:#3b82f6; text-decoration:none; font-weight:500; }
  .view-all:hover { text-decoration:underline; }
  .alert-amount { color:#dc2626; font-weight:600; }
  .neutral { color:#1f2937; }
</style>

<div class="dash-wrap">
  <div class="page-header">
    <h2><i class="bi bi-speedometer2"></i> Dashboard</h2>
    <div class="d-flex gap-2">
      <button id="refreshDash" class="btn btn-sm btn-outline-secondary" title="Refresh"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
      <a href="/orders/add" class="btn btn-sm btn-dark"><i class="bi bi-plus"></i> New Order</a>
      <a href="/invoices/add" class="btn btn-sm btn-outline-dark"><i class="bi bi-plus"></i> New Invoice</a>
    </div>
  </div>

  <!-- TOP METRICS (5 cards) -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg">
      <a href="/invoices" class="text-decoration-none">
        <div class="metric">
          <div class="lbl">Revenue</div>
          <div class="val"><%= formatCurrency(monthRev) %></div>
          <div class="sub">Today: <%= formatCurrency(todayRev) %></div>
        </div>
      </a>
    </div>
    <div class="col-6 col-md-4 col-lg">
      <a href="/reports/profit-loss" class="text-decoration-none">
        <div class="metric">
          <div class="lbl">Profit</div>
          <div class="val <%= monthProfit < 0 ? 'alert-amount' : '' %>"><%= formatCurrency(monthProfit) %></div>
          <div class="sub">Today: <%= formatCurrency(todayProfit) %></div>
        </div>
      </a>
    </div>
    <div class="col-6 col-md-4 col-lg">
      <a href="/ledger" class="text-decoration-none">
        <div class="metric <%= netReceivable < 0 ? 'alert-warn' : '' %>">
          <div class="lbl">Net Receivable</div>
          <div class="val <%= netReceivable < 0 ? 'alert-amount' : '' %>"><%= formatCurrency(netReceivable) %></div>
          <div class="sub">Recv: <%= formatCurrency(totalReceivables) %> · Pay: <%= formatCurrency(totalPayables) %></div>
        </div>
      </a>
    </div>
    <div class="col-6 col-md-4 col-lg">
      <a href="/reports/low-stock" class="text-decoration-none">
        <div class="metric <%= lowStockCount > 0 ? 'alert-low' : '' %>">
          <div class="lbl">Low Stock</div>
          <div class="val <%= lowStockCount > 0 ? 'alert-amount' : '' %>"><%= lowStockCount %></div>
          <div class="sub">Items at or below min stock</div>
        </div>
      </a>
    </div>
    <div class="col-6 col-md-4 col-lg">
      <a href="/orders" class="text-decoration-none">
        <div class="metric">
          <div class="lbl">Orders Today</div>
          <div class="val"><%= ordersToday %></div>
          <div class="sub">New orders booked today</div>
        </div>
      </a>
    </div>
  </div>

  <!-- CHARTS (2) -->
  <div class="row g-3 mb-4">
    <div class="col-lg-7">
      <div class="dash-card">
        <div class="card-header">Revenue vs Expenses (6 months) <a href="/reports" class="view-all">View Reports →</a></div>
        <div class="card-body p-3"><canvas id="revExpChart" height="110"></canvas></div>
      </div>
    </div>
    <div class="col-lg-5">
      <div class="dash-card">
        <div class="card-header">Top 5 Products (30 days) <a href="/reports/product-sales" class="view-all">View All →</a></div>
        <div class="card-body p-3"><canvas id="topProdChart" height="110"></canvas></div>
      </div>
    </div>
  </div>

  <!-- TABLES (3) -->
  <div class="row g-3 mb-4">
    <div class="col-lg-6">
      <div class="dash-card">
        <div class="card-header">Recent Orders <a href="/orders" class="view-all">View All →</a></div>
        <div class="card-body">
          <table class="table table-sm mb-0">
            <thead><tr><th>Order #</th><th>Customer</th><th>Date</th><th class="text-end">Total</th><th>Status</th></tr></thead>
            <tbody>
              <% recentOrders.forEach(o => { %>
                <tr>
                  <td><a href="/orders/view/<%= o.id %>" class="text-dark fw-semibold text-decoration-none"><%= o.order_no %></a></td>
                  <td><%= o.customer_name %></td>
                  <td class="text-muted small"><%= formatDate(o.order_date) %></td>
                  <td class="text-end fw-semibold"><%= formatCurrency(o.total) %></td>
                  <td><span class="pill pill-<%= o.status==='delivered'?'success':o.status==='cancelled'?'danger':'warn' %>"><%= o.status %></span></td>
                </tr>
              <% }) %>
              <% if (!recentOrders.length) { %><tr><td colspan="5" class="text-center text-muted py-3">No orders yet</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="dash-card">
        <div class="card-header">Recent Payments <a href="/payments/receive" class="view-all">View All →</a></div>
        <div class="card-body">
          <table class="table table-sm mb-0">
            <thead><tr><th>Type</th><th>Party</th><th>Date</th><th>Method</th><th class="text-end">Amount</th></tr></thead>
            <tbody>
              <% recentPayments.forEach(p => { %>
                <tr>
                  <td><span class="pill <%= p.entity_type==='customer'?'pill-success':'' %>"><%= p.entity_type==='customer' ? 'IN' : 'OUT' %></span></td>
                  <td><%= p.entity_name || '-' %></td>
                  <td class="text-muted small"><%= formatDate(p.payment_date) %></td>
                  <td class="small"><%= p.payment_method %></td>
                  <td class="text-end fw-semibold"><%= formatCurrency(p.amount) %></td>
                </tr>
              <% }) %>
              <% if (!recentPayments.length) { %><tr><td colspan="5" class="text-center text-muted py-3">No payments yet</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-12">
      <div class="dash-card">
        <div class="card-header">Low Stock <a href="/reports/low-stock" class="view-all">View All →</a></div>
        <div class="card-body">
          <table class="table table-sm mb-0">
            <thead><tr><th>Product</th><th class="text-end">Stock</th><th class="text-end">Min Stock</th><th>Status</th><th></th></tr></thead>
            <tbody>
              <% lowStock.forEach(p => { %>
                <tr>
                  <td><a href="/products/edit/<%= p.id %>" class="text-dark fw-semibold text-decoration-none"><%= p.name %></a></td>
                  <td class="text-end <%= p.stock <= 0 ? 'alert-amount' : '' %>"><%= p.stock %></td>
                  <td class="text-end text-muted"><%= p.min_stock %></td>
                  <td><span class="pill <%= p.stock <= 0 ? 'pill-danger' : 'pill-warn' %>"><%= p.stock <= 0 ? 'Out' : 'Low' %></span></td>
                  <td class="text-end"><a href="/purchases/add?product_id=<%= p.id %>" class="view-all">Reorder →</a></td>
                </tr>
              <% }) %>
              <% if (!lowStock.length) { %><tr><td colspan="5" class="text-center text-muted py-3">All stock OK</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  const chartData  = <%- JSON.stringify(chartData) %>;
  const topProds   = <%- JSON.stringify(topProducts) %>;

  function init() {
    if (typeof Chart === 'undefined') return setTimeout(init, 60);
    // Revenue vs Expenses
    const el1 = document.getElementById('revExpChart');
    if (el1 && !el1._init) {
      el1._init = true;
      new Chart(el1, {
        type: 'bar',
        data: {
          labels: chartData.map(d => d.month),
          datasets: [
            { label: 'Revenue',  data: chartData.map(d => d.revenue),  backgroundColor: '#1f2937', borderRadius: 3 },
            { label: 'Expenses', data: chartData.map(d => d.expenses), backgroundColor: '#9ca3af', borderRadius: 3 }
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { position: 'bottom', labels:{ color:'#374151', font:{size:11} } } },
          scales: {
            x: { ticks: { color: '#6b7280' }, grid: { display: false } },
            y: { beginAtZero: true, ticks: { color: '#6b7280', callback: v => 'Rs. ' + (v >= 1000 ? (v/1000).toFixed(0)+'k' : v) }, grid: { color: '#f3f4f6' } }
          }
        }
      });
    }
    // Top Products
    const el2 = document.getElementById('topProdChart');
    if (el2 && !el2._init) {
      el2._init = true;
      new Chart(el2, {
        type: 'bar',
        data: {
          labels: topProds.map(p => p.name),
          datasets: [{ label: 'Revenue', data: topProds.map(p => p.revenue), backgroundColor: '#374151', borderRadius: 3 }]
        },
        options: {
          indexAxis: 'y', responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { beginAtZero: true, ticks: { color: '#6b7280', callback: v => 'Rs. ' + (v >= 1000 ? (v/1000).toFixed(0)+'k' : v) }, grid: { color: '#f3f4f6' } },
            y: { ticks: { color: '#374151' }, grid: { display: false } }
          }
        }
      });
    }
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();

  // Refresh button — soft re-render via SPA nav if available
  const btn = document.getElementById('refreshDash');
  if (btn) btn.addEventListener('click', () => {
    if (window.SPA && window.SPA.navigate) window.SPA.navigate(location.pathname + location.search, { force: true });
    else location.reload();
  });
})();
</script>
<%- include('partials/footer') %>
