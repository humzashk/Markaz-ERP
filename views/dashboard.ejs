  </div>
  <div class="col-md-6">
    <div class="card h-100 ai-card">
      <div class="card-header"><i class="bi bi-hourglass-split text-warning"></i> Bottlenecks (Pending &gt; 7d)</div>
      <div class="card-body p-0">
        <% if (oldPendingOrders.length) { %>
        <table class="table table-sm mb-0">
          <thead class="table-light"><tr><th>Order</th><th>Customer</th><th class="text-end">Amount</th><th class="text-end">Days</th></tr></thead>
