<%- include('partials/header') %>
<style>
  .dash-wrap { background:#fff; color:#1f2937; }
  .dash-wrap h2, .dash-wrap h3 { color:#111827; font-weight:600; letter-spacing:-.01em; }
  .dash-wrap .text-muted { color:#6b7280 !important; }
  .metric { background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:18px 20px; transition:border-color .12s; }
  .metric:hover { border-color:#9ca3af; }
  .metric .lbl { font-size:11px; text-transform:uppercase; letter-spacing:1px; color:#6b7280; font-weight:600; }
  .metric .val { font-size:24px; font-weight:700; color:#111827; margin-top:6px; line-height:1.1; }
  .metric .sub { font-size:12px; color:#6b7280; margin-top:4px; }
  .metric.alert-low  { border-left:4px solid #ef4444; }
  .metric.alert-warn { border-left:4px solid #f59e0b; }
  .dash-card { background:#fff; border:1px solid #e5e7eb; border-radius:10px; }
  .dash-card .card-header { background:#fafafa; border-bottom:1px solid #e5e7eb; font-weight:600; color:#111827; padding:12px 16px; display:flex; justify-content:space-between; align-items:center; }
  .dash-card .card-body { padding:0; }
  .dash-card table { margin:0; }
  .dash-card .table thead th { background:#fafafa; color:#374151; border-bottom:1px solid #e5e7eb; font-size:12px; text-transform:uppercase; letter-spacing:.5px; font-weight:600; }
  .dash-card .table td { vertical-align:middle; color:#1f2937; }
  .pill { display:inline-block; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:600; background:#f3f4f6; color:#374151; }
  .pill-warn    { background:#fef3c7; color:#92400e; }
  .pill-danger  { background:#fee2e2; color:#991b1b; }
  .pill-success { background:#d1fae5; color:#065f46; }
  .view-all { font-size:12px; color:#3b82f6; text-decoration:none; font-weight:500; }
  .view-all:hover { text-decoration:underline; }
  .alert-amount { color:#dc2626; font-weight:600; }

  /* Health score */
  .health-dot { width:14px; height:14px; border-radius:50%; display:inline-block; flex-shrink:0; }
  .health-green  { background:#16a34a; box-shadow:0 0 6px #16a34a88; }
  .health-yellow { background:#d97706; box-shadow:0 0 6px #d9770688; }
  .health-red    { background:#dc2626; box-shadow:0 0 6px #dc262688; }

  /* Comparison widget */
  .cmp-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:0; }
  .cmp-col { padding:10px 14px; border-right:1px solid #f3f4f6; }
  .cmp-col:last-child { border-right:none; }
  .cmp-lbl  { font-size:10px; text-transform:uppercase; letter-spacing:.8px; color:#9ca3af; font-weight:600; }
  .cmp-cur  { font-size:16px; font-weight:700; color:#111827; margin:2px 0; }
  .cmp-prev { font-size:11px; color:#9ca3af; }
  .cmp-up   { color:#16a34a; font-size:11px; font-weight:600; }
  .cmp-dn   { color:#dc2626; font-size:11px; font-weight:600; }
  .cmp-flat { color:#9ca3af; font-size:11px; }

  /* Fast movers */
  .fm-bar-wrap { padding:10px 14px; }
  .fm-row { display:flex; align-items:center; gap:8px; margin-bottom:8px; }
  .fm-row:last-child { margin-bottom:0; }
  .fm-rank { font-size:11px; color:#9ca3af; font-weight:700; width:16px; text-align:center; flex-shrink:0; }
  .fm-name { font-size:13px; font-weight:500; color:#1f2937; flex:1; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .fm-bar-bg { flex:2; background:#f3f4f6; border-radius:4px; height:7px; overflow:hidden; }
  .fm-bar-fill { background:#1f2937; height:7px; border-radius:4px; }
  .fm-qty { font-size:12px; font-weight:700; color:#374151; width:44px; text-align:right; flex-shrink:0; }
</style>

<div class="dash-wrap">
  <div class="page-header">
    <h2><i class="bi bi-speedometer2"></i> Dashboard</h2>
    <div class="d-flex gap-2">
      <button id="refreshDash" class="btn btn-sm btn-outline-secondary" title="Refresh"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
      <a href="/orders/add" class="btn btn-sm btn-dark"><i class="bi bi-plus"></i> New Order</a>
      <a href="/invoices/add" class="btn btn-sm btn-outline-dark"><i class="bi bi-plus"></i> New Invoice</a>
    </div>
  </div>

  <!-- TOP METRICS -->
  <div class="row g-3 mb-4">
    <% if (isSuperadmin) { %>
    <div class="col-6 col-md-4 col-lg">
      <a href="/invoices" class="text-decoration-none">
        <div class="metric">
          <div class="lbl">Revenue</div>
          <div class="val"><%= formatCurrency(monthRev) %></div>
          <div class="sub">Today: <%= formatCurrency(todayRev) %></div>
        </div>
      </a>
    </div>
    <div class="col-6 col-md-4 col-lg">
      <a href="/reports/profit-loss" class="text-decoration-none">
        <div class="metric">
          <div class="lbl">Profit</div>
          <div class="val <%= monthProfit < 0 ? 'alert-amount' : '' %>"><%= formatCurrency(monthProfit) %></div>
          <div class="sub">Today: <%= formatCurrency(todayProfit) %></div>
        </div>
      </a>
    </div>
    <div class="col-6 col-md-4 col-lg">
      <a href="/ledger" class="text-decoration-none">
        <div class="metric <%= netReceivable < 0 ? 'alert-warn' : '' %>">
          <div class="lbl">Net Receivable</div>
          <div class="val <%= netReceivable < 0 ? 'alert-amount' : '' %>"><%= formatCurrency(netReceivable) %></div>
          <div class="sub">Recv: <%= formatCurrency(totalReceivables) %> · Pay: <%= formatCurrency(totalPayables) %></div>
        </div>
      </a>
    </div>
    <% } %>
    <div class="col-6 col-md-4 col-lg">
      <a href="/reports/low-stock" class="text-decoration-none">
        <div class="metric <%= lowStockCount > 0 ? 'alert-low' : '' %>">
          <div class="lbl">Low Stock</div>
          <div class="val <%= lowStockCount > 0 ? 'alert-amount' : '' %>"><%= lowStockCount %></div>
          <div class="sub">Items at or below min stock</div>
        </div>
      </a>
    </div>
    <div class="col-6 col-md-4 col-lg">
      <a href="/orders" class="text-decoration-none">
        <div class="metric">
          <div class="lbl">Orders Today</div>
          <div class="val"><%= ordersToday %></div>
          <div class="sub">New orders booked today</div>
        </div>
      </a>
    </div>
    <% if (isSuperadmin) { %>
    <!-- Health Score -->
    <div class="col-6 col-md-4 col-lg">
      <div class="metric" style="border-left:4px solid <%= health==='green'?'#16a34a':health==='yellow'?'#d97706':'#dc2626' %>">
        <div class="lbl">Daily Health</div>
        <div class="val d-flex align-items-center gap-2 mt-2">
          <span class="health-dot health-<%= health %>"></span>
          <span style="font-size:18px;color:<%= health==='green'?'#16a34a':health==='yellow'?'#d97706':'#dc2626' %>"><%= healthLabel %></span>
        </div>
        <div class="sub mt-1">
          Cash <% if(todayRev>0){%>✓<%}else{%>–<%}%> &nbsp;·&nbsp;
          Recv <% if(netReceivable>=0){%>✓<%}else{%>✗<%}%> &nbsp;·&nbsp;
          Stock <% if(lowStockCount<=3){%>✓<%}else{%>✗<%}%>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <% if (isSuperadmin) { %>
  <!-- COMPARISON + FAST MOVERS ROW -->
  <div class="row g-3 mb-4">
    <!-- Comparison Widget -->
    <div class="col-lg-7">
      <div class="dash-card">
        <div class="card-header">
          <span>Period Comparison</span>
          <select id="cmpPeriod" class="form-select form-select-sm" style="width:auto;">
            <option value="day">Today vs Yesterday</option>
            <option value="week">This Week vs Last Week</option>
            <option value="month" selected>This Month vs Last Month</option>
          </select>
        </div>
        <div class="cmp-row border-bottom px-0 py-2" style="padding:0!important;">
          <div class="cmp-col">
            <div class="cmp-lbl">Sales</div>
            <div class="cmp-cur" id="cmpSalesCur">—</div>
            <div class="cmp-prev" id="cmpSalesPrev">—</div>
            <span id="cmpSalesDelta"></span>
          </div>
          <div class="cmp-col">
            <div class="cmp-lbl">Cash Received</div>
            <div class="cmp-cur" id="cmpCashCur">—</div>
            <div class="cmp-prev" id="cmpCashPrev">—</div>
            <span id="cmpCashDelta"></span>
          </div>
          <div class="cmp-col">
            <div class="cmp-lbl">Orders</div>
            <div class="cmp-cur" id="cmpOrdCur">—</div>
            <div class="cmp-prev" id="cmpOrdPrev">—</div>
            <span id="cmpOrdDelta"></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Fast Movers -->
    <div class="col-lg-5">
      <div class="dash-card">
        <div class="card-header">
          <span>Fast Movers</span>
          <select id="fmPeriod" class="form-select form-select-sm" style="width:auto;">
            <option value="day">Today</option>
            <option value="week">This Week</option>
            <option value="month" selected>This Month</option>
          </select>
        </div>
        <div class="fm-bar-wrap" id="fmList">
          <div class="text-muted small text-center py-2">Loading...</div>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Top Products Chart -->
  <div class="row g-3 mb-4">
    <div class="col-12">
      <div class="dash-card">
        <div class="card-header">Top 5 Products – Revenue (30 days) <a href="/reports/product-sales" class="view-all">View All →</a></div>
        <div class="card-body p-3"><canvas id="topProdChart" height="80"></canvas></div>
      </div>
    </div>
  </div>

  <!-- TABLES -->
  <div class="row g-3 mb-4">
    <div class="col-lg-6">
      <div class="dash-card">
        <div class="card-header">Recent Orders <a href="/orders" class="view-all">View All →</a></div>
        <div class="card-body">
          <table class="table table-sm mb-0">
            <thead><tr><th>Order #</th><th>Customer</th><th>Date</th><th class="text-end">Total</th><th>Status</th></tr></thead>
            <tbody>
              <% recentOrders.forEach(o => { %>
                <tr>
                  <td><a href="/orders/view/<%= o.id %>" class="text-dark fw-semibold text-decoration-none"><%= o.order_no %></a></td>
                  <td><%= o.customer_name %></td>
                  <td class="text-muted small"><%= formatDate(o.order_date) %></td>
                  <td class="text-end fw-semibold"><%= formatCurrency(o.total) %></td>
                  <td><span class="pill pill-<%= o.status==='delivered'?'success':o.status==='cancelled'?'danger':'warn' %>"><%= o.status %></span></td>
                </tr>
              <% }) %>
              <% if (!recentOrders.length) { %><tr><td colspan="5" class="text-center text-muted py-3">No orders yet</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="dash-card">
        <div class="card-header">Recent Payments <a href="/payments/receive" class="view-all">View All →</a></div>
        <div class="card-body">
          <table class="table table-sm mb-0">
            <thead><tr><th>Type</th><th>Party</th><th>Date</th><th>Method</th><th class="text-end">Amount</th></tr></thead>
            <tbody>
              <% recentPayments.forEach(p => { %>
                <tr>
                  <td><span class="pill <%= p.entity_type==='customer'?'pill-success':'' %>"><%= p.entity_type==='customer' ? 'IN' : 'OUT' %></span></td>
                  <td><%= p.entity_name || '-' %></td>
                  <td class="text-muted small"><%= formatDate(p.payment_date) %></td>
                  <td class="small"><%= p.payment_method %></td>
                  <td class="text-end fw-semibold"><%= formatCurrency(p.amount) %></td>
                </tr>
              <% }) %>
              <% if (!recentPayments.length) { %><tr><td colspan="5" class="text-center text-muted py-3">No payments yet</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-12">
      <div class="dash-card">
        <div class="card-header">Low Stock <a href="/reports/low-stock" class="view-all">View All →</a></div>
        <div class="card-body">
          <table class="table table-sm mb-0">
            <thead><tr><th>Product</th><th class="text-end">Stock</th><th class="text-end">Min Stock</th><th>Status</th><th></th></tr></thead>
            <tbody>
              <% lowStock.forEach(p => { %>
                <tr>
                  <td><a href="/products/edit/<%= p.id %>" class="text-dark fw-semibold text-decoration-none"><%= p.name %></a></td>
                  <td class="text-end <%= p.stock <= 0 ? 'alert-amount' : '' %>"><%= p.stock %></td>
                  <td class="text-end text-muted"><%= p.min_stock %></td>
                  <td><span class="pill <%= p.stock <= 0 ? 'pill-danger' : 'pill-warn' %>"><%= p.stock <= 0 ? 'Out' : 'Low' %></span></td>
                  <td class="text-end"><a href="/purchases/add?product_id=<%= p.id %>" class="view-all">Reorder →</a></td>
                </tr>
              <% }) %>
              <% if (!lowStock.length) { %><tr><td colspan="5" class="text-center text-muted py-3">All stock OK</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  const topProds  = <%- JSON.stringify(topProducts) %>;
  const cmpData   = <%- JSON.stringify(cmp) %>;
  const fmData    = <%- JSON.stringify(fastMovers) %>;

  // ── Top Products Chart ──────────────────────────────────────────────────
  function initCharts() {
    if (typeof Chart === 'undefined') return setTimeout(initCharts, 60);
    const el2 = document.getElementById('topProdChart');
    if (el2 && !el2._init) {
      el2._init = true;
      new Chart(el2, {
        type: 'bar',
        data: {
          labels: topProds.map(p => p.name),
          datasets: [{ label: 'Revenue', data: topProds.map(p => p.revenue), backgroundColor: '#374151', borderRadius: 3 }]
        },
        options: {
          indexAxis: 'y', responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { beginAtZero: true, ticks: { color: '#6b7280', callback: v => 'Rs. ' + (v >= 1000 ? (v/1000).toFixed(0)+'k' : v) }, grid: { color: '#f3f4f6' } },
            y: { ticks: { color: '#374151' }, grid: { display: false } }
          }
        }
      });
    }
  }

  // ── Comparison Widget ───────────────────────────────────────────────────
  function fmtRs(n) {
    if (n >= 1e6)  return 'Rs.' + (n/1e6).toFixed(1) + 'M';
    if (n >= 1000) return 'Rs.' + (n/1000).toFixed(0) + 'k';
    return 'Rs.' + n.toLocaleString('en-PK');
  }
  function delta(cur, prev, isCurrency) {
    if (prev === 0) return '';
    const pct = ((cur - prev) / prev * 100).toFixed(0);
    const fmt = isCurrency ? fmtRs(Math.abs(cur - prev)) : Math.abs(cur - prev);
    if (cur > prev) return `<span class="cmp-up">▲ ${fmt} (+${pct}%)</span>`;
    if (cur < prev) return `<span class="cmp-dn">▼ ${fmt} (${pct}%)</span>`;
    return `<span class="cmp-flat">— no change</span>`;
  }
  const prevLabels = { day: 'Yesterday', week: 'Last week', month: 'Last month' };
  function renderCmp(period) {
    const d = cmpData[period];
    document.getElementById('cmpSalesCur').textContent  = fmtRs(d.sales[0]);
    document.getElementById('cmpSalesPrev').textContent = prevLabels[period] + ': ' + fmtRs(d.sales[1]);
    document.getElementById('cmpSalesDelta').innerHTML  = delta(d.sales[0], d.sales[1], true);
    document.getElementById('cmpCashCur').textContent   = fmtRs(d.cash[0]);
    document.getElementById('cmpCashPrev').textContent  = prevLabels[period] + ': ' + fmtRs(d.cash[1]);
    document.getElementById('cmpCashDelta').innerHTML   = delta(d.cash[0], d.cash[1], true);
    document.getElementById('cmpOrdCur').textContent    = d.orders[0];
    document.getElementById('cmpOrdPrev').textContent   = prevLabels[period] + ': ' + d.orders[1];
    document.getElementById('cmpOrdDelta').innerHTML    = delta(d.orders[0], d.orders[1], false);
  }

  // ── Fast Movers ─────────────────────────────────────────────────────────
  function renderFM(period) {
    const rows = fmData[period] || [];
    const container = document.getElementById('fmList');
    if (!container) return;
    if (!rows.length) { container.innerHTML = '<div class="text-muted small text-center py-3">No data</div>'; return; }
    const max = rows[0].qty || 1;
    container.innerHTML = rows.map((r, i) => `
      <div class="fm-row">
        <span class="fm-rank">${i+1}</span>
        <span class="fm-name" title="${r.name}">${r.name}</span>
        <div class="fm-bar-bg"><div class="fm-bar-fill" style="width:${Math.round(r.qty/max*100)}%"></div></div>
        <span class="fm-qty">${r.qty} <span style="font-size:10px;color:#9ca3af">ctn</span></span>
      </div>`).join('');
  }

  // ── Wire up dropdowns ───────────────────────────────────────────────────
  const cmpSel = document.getElementById('cmpPeriod');
  const fmSel  = document.getElementById('fmPeriod');
  if (cmpSel) { cmpSel.addEventListener('change', () => renderCmp(cmpSel.value)); renderCmp(cmpSel.value); }
  if (fmSel)  { fmSel.addEventListener('change',  () => renderFM(fmSel.value));   renderFM(fmSel.value);  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initCharts);
  else initCharts();

  const btn = document.getElementById('refreshDash');
  if (btn) btn.addEventListener('click', () => { if (window.SPA && window.SPA.navigate) window.SPA.navigate(location.pathname, { force:true }); else location.reload(); });
})();
</script>
<%- include('partials/footer') %>
