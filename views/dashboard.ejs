  <div class="col-md-6">
    <div class="card h-100 ai-card">
      <div class="card-header text-danger"><i class="bi bi-graph-down"></i> AI: Profit Leakage (Margin &lt; 5%)</div>
      <div class="card-body p-0">
        <% if (profitLeakage.length) { %>
        <table class="table table-sm mb-0">
          <thead class="table-light"><tr><th>Product</th><th class="text-end">Revenue</th><th class="text-end">Profit</th><th class="text-end">Margin</th></tr></thead>
