              <td class="text-end fw-bold text-success"><%= formatCurrency(p.profit) %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } else { %><div class="p-3 text-center text-muted small">No data</div><% } %>
      </div>
    </div>
  </div>
