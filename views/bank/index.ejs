<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-bank"></i> Bank Accounts</h2>
  <a href="/bank/add" class="btn btn-primary"><i class="bi bi-plus"></i> Add Account</a>
</div>

<div class="row mb-3">
  <div class="col-md-4">
    <div class="stat-card stat-card-blue">
      <div class="stat-value"><%= formatCurrency(totalBalance) %></div>
      <div class="stat-label">Total Balance</div>
    </div>
  </div>
</div>

<div class="row">
  <% accounts.forEach(a => { %>
  <div class="col-md-4 mb-3">
    <div class="card h-100 <%= a.status !== 'active' ? 'opacity-50' : '' %>">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
          <h5 class="mb-0"><%= a.account_name %></h5>
          <span class="badge bg-<%= a.account_type === 'bank' ? 'primary' : a.account_type === 'cash' ? 'success' : 'info' %>"><%= a.account_type %></span>
        </div>
        <% if (a.bank_name) { %><p class="text-muted mb-1 small"><i class="bi bi-bank2"></i> <%= a.bank_name %></p><% } %>
        <% if (a.account_number) { %><p class="text-muted mb-2 small"><i class="bi bi-credit-card"></i> <%= a.account_number %></p><% } %>
        <div class="fs-4 fw-bold <%= a.balance >= 0 ? 'text-success' : 'text-danger' %>"><%= formatCurrency(a.balance) %></div>
      </div>
      <div class="card-footer d-flex gap-2">
        <a href="/bank/view/<%= a.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-clock-history"></i> Transactions</a>
        <a href="/bank/edit/<%= a.id %>" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
      </div>
    </div>
  </div>
  <% }) %>
  <% if (!accounts.length) { %>
  <div class="col-12"><p class="text-center text-muted py-5">No bank accounts yet. <a href="/bank/add">Add one.</a></p></div>
  <% } %>
</div>
<%- include('../partials/footer') %>
