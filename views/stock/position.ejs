<%- include('../partials/header') %>
<div class="page-header d-flex justify-content-between align-items-center">
  <h2><i class="bi bi-pie-chart"></i> Stock Position</h2>
  <button class="btn btn-outline-secondary btn-sm" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
</div>
<div class="alert alert-info mb-3 no-print">
  <strong>Stock Position:</strong> Quantity in pieces with carton equivalents (Pcs/Carton from Item Master).
</div>

<div class="row g-3 mb-3 no-print">
  <div class="col-md-6">
    <label class="form-label">Filter by Warehouse</label>
    <form class="row g-2" method="get">
      <div class="col-md-10">
        <select name="warehouse_id" class="form-select" onchange="this.form.submit()">
          <option value="">-- All Warehouses --</option>
          <% warehouses.forEach(w => { %>
            <option value="<%= w.id %>" <%= (warehouseId == w.id)?'selected':'' %>><%= w.name %></option>
          <% }) %>
        </select>
      </div>
    </form>
  </div>
</div>

<div class="row g-3 mb-3">
  <div class="col-md-4"><div class="card border-primary"><div class="card-body py-2"><div class="text-muted small">Total Pieces</div><h4 class="mb-0"><%= (typeof totalPcs!=='undefined'?totalPcs:0).toLocaleString() %> <small class="text-muted">pcs</small></h4></div></div></div>
  <div class="col-md-4"><div class="card border-success"><div class="card-body py-2"><div class="text-muted small">Total Cartons</div><h4 class="mb-0"><%= (typeof totalCartons!=='undefined'?totalCartons:0).toLocaleString() %> <small class="text-muted">ctn</small></h4></div></div></div>
  <div class="col-md-4"><div class="card border-warning"><div class="card-body py-2"><div class="text-muted small">Loose Pieces</div><h4 class="mb-0"><%= (typeof totalLoose!=='undefined'?totalLoose:0).toLocaleString() %> <small class="text-muted">pcs</small></h4></div></div></div>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th style="width:30%">Product</th>
            <th>Unit</th>
            <th class="text-end">Pcs/Carton</th>
            <th class="text-end">Quantity (Pcs)</th>
            <th class="text-end">Cartons</th>
            <th class="text-end">Loose Pcs</th>
            <% if (!warehouseId) { %><th class="text-end">Warehouses</th><% } %>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (!position.length) { %>
            <tr><td colspan="8" class="text-center text-muted py-4">No products found</td></tr>
          <% } %>
          <% position.forEach(p => { %>
            <tr>
              <td><strong><%= p.name %></strong></td>
              <td><small><%= p.unit || 'PCS' %></small></td>
              <td class="text-end"><%= p.pcs_per_carton %></td>
              <td class="text-end fw-bold"><%= (p.pcs||0).toLocaleString() %></td>
              <td class="text-end"><span class="badge bg-success"><%= p.cartons %> ctn</span></td>
              <td class="text-end"><span class="text-muted"><%= p.loose %> pcs</span></td>
              <% if (!warehouseId) { %>
                <td class="text-end">
                  <% if (p.warehouse_count > 0) { %><span class="badge bg-info"><%= p.warehouse_count %></span><% } else { %><span class="text-muted">—</span><% } %>
                </td>
              <% } %>
              <td>
                <% if ((p.pcs||0) > 0) { %><span class="badge bg-success">In Stock</span>
                <% } else { %><span class="badge bg-warning">Out of Stock</span><% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
        <tfoot class="table-light fw-bold">
          <tr>
            <td colspan="3" class="text-end">GRAND TOTAL:</td>
            <td class="text-end"><%= (typeof totalPcs!=='undefined'?totalPcs:0).toLocaleString() %> pcs</td>
            <td class="text-end"><%= (typeof totalCartons!=='undefined'?totalCartons:0).toLocaleString() %> ctn</td>
            <td class="text-end"><%= (typeof totalLoose!=='undefined'?totalLoose:0).toLocaleString() %> pcs</td>
            <% if (!warehouseId) { %><td></td><% } %>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>

<style>@media print { .no-print, .sidebar, nav, header, footer, .navbar { display:none !important; } .container-fluid, .container { max-width:100% !important; } }</style>
<%- include('../partials/footer') %>
