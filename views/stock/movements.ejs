<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-arrow-left-right"></i> Stock Movement Tracking</h2>
  <a href="/stock" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Adjustments</a>
</div>

<div class="card mb-3">
  <div class="card-body py-2">
    <form method="GET" class="row g-2 align-items-end">
      <div class="col-md-6">
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Search product..." value="<%= search %>">
      </div>
      <div class="col-md-3">
        <select name="type" class="form-select form-select-sm">
          <option value="">All Movements</option>
          <option value="outbound" <%= type==='outbound'?'selected':'' %>>Outbound (Orders)</option>
          <option value="inbound" <%= type==='inbound'?'selected':'' %>>Inbound (Invoices)</option>
        </select>
      </div>
      <div class="col-md-3">
        <button class="btn btn-sm btn-secondary w-100">Filter</button>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Date</th>
            <th>Product</th>
            <th>Party</th>
            <th>Type</th>
            <th class="text-end">Quantity</th>
            <th>Reference</th>
          </tr>
        </thead>
        <tbody>
          <% movements.forEach(m => { %>
          <tr>
            <td><small><%= formatDate(m.movement_date) %></small></td>
            <td>
              <strong><a href="/products/view/<%= m.product_id %>" class="text-decoration-none"><%= m.product_name %></a></strong>
            </td>
            <td><%= m.party_name %></td>
            <td>
              <% if (m.party_type === 'Customer') { %>
                <span class="badge bg-danger">Outbound</span>
              <% } else { %>
                <span class="badge bg-success">Inbound</span>
              <% } %>
            </td>
            <td class="text-end fw-bold"><%= m.quantity.toLocaleString() %></td>
            <td>
              <% if (m.doc_type === 'Order') { %>
                <a href="/orders/view/<%= m.order_id %>" class="btn btn-sm btn-outline-info">
                  <i class="bi bi-eye"></i> <%= m.reference_number %>
                </a>
              <% } else if (m.doc_type === 'Purchase') { %>
                <a href="/purchases/view/<%= m.purchase_id %>" class="btn btn-sm btn-outline-info">
                  <i class="bi bi-eye"></i> <%= m.reference_number %>
                </a>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% if (!movements.length) { %>
            <tr>
              <td colspan="6" class="text-center text-muted py-4">
                <% if (search || type) { %>
                  No movements found matching your criteria
                <% } else { %>
                  No stock movements found
                <% } %>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="mt-3 text-muted small">
  <p><strong>Legend:</strong></p>
  <ul class="mb-0">
    <li><span class="badge bg-danger">Outbound</span> - Products sold to customers (Orders)</li>
    <li><span class="badge bg-success">Inbound</span> - Products received from vendors (Invoices)</li>
  </ul>
</div>

<%- include('../partials/footer') %>
