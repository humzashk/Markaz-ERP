<%- include('../partials/header') %>
<div class="page-header"><h2><i class="bi bi-file-text"></i> Purchase Invoices</h2><button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button></div>
<div class="filter-bar no-print">
  <form class="row g-2" method="get">
    <div class="col-md-3"><input type="date" name="from" class="form-control" value="<%= from %>"></div>
    <div class="col-md-3"><input type="date" name="to" class="form-control" value="<%= to %>"></div>
    <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-filter"></i></button></div>
  </form>
</div>
<div class="card"><div class="card-body p-0"><div class="table-responsive">
  <table class="table table-hover mb-0"><thead><tr><th>Purchase No</th><th>Vendor</th><th>Date</th><th class="text-end">Total</th><th>Status</th></tr></thead><tbody>
    <% purchases.forEach(p => { %><tr><td><a href="/purchases/view/<%= p.id %>"><%= p.purchase_no %></a></td><td><%= p.vendor_name %></td><td><%= formatDate(p.purchase_date) %></td><td class="text-end fw-bold"><%= formatCurrency(p.total) %></td><td><span class="badge bg-<%= statusBadge(p.status) %>"><%= p.status %></span></td></tr><% }) %>
    <% if (!purchases.length) { %><tr><td colspan="5" class="text-center text-muted py-3">No data</td></tr><% } %>
  </tbody></table>
</div></div></div>
<%- include('../partials/footer') %>
