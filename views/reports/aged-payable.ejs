<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-hourglass-split"></i> Aged Payable</h2>
  <div>
    <a href="javascript:history.back()" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    <button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button>
  </div>
</div>
<div class="card"><div class="card-body p-0"><div class="table-responsive">
  <table class="table table-sm table-hover mb-0">
    <thead class="table-light">
      <tr>
        <th>#</th><th>Vendor</th><th>Phone</th><th>City</th>
        <% AGE_BUCKETS.forEach(b => { %><th class="text-end"><%= b.label %>d</th><% }) %>
        <th class="text-end">Total Payable</th>
      </tr>
    </thead>
    <tbody>
      <% var totals = {}; AGE_BUCKETS.forEach(b => totals[b.key] = 0); var grand = 0; %>
      <% vendors.forEach((v, i) => { %>
        <tr>
          <td><%= i+1 %></td>
          <td><a href="/ledger/vendor/<%= v.id %>"><strong><%= v.name %></strong></a></td>
          <td><%= v.phone || '-' %></td>
          <td><%= v.city || '-' %></td>
          <% AGE_BUCKETS.forEach(b => { var amt = v.buckets[b.key] || 0; totals[b.key] += amt; %>
            <td class="text-end"><%= amt ? formatCurrency(amt) : '-' %></td>
          <% }) %>
          <% var due = Math.abs(v.balance); grand += due; %>
          <td class="text-end fw-bold due-amount"><%= formatCurrency(due) %></td>
        </tr>
      <% }) %>
      <% if (!vendors.length) { %><tr><td colspan="<%= 5 + AGE_BUCKETS.length %>" class="text-center text-muted py-3">No outstanding payables</td></tr><% } %>
    </tbody>
    <% if (vendors.length) { %>
    <tfoot class="table-light">
      <tr class="fw-bold">
        <td colspan="4" class="text-end">TOTAL:</td>
        <% AGE_BUCKETS.forEach(b => { %><td class="text-end"><%= formatCurrency(totals[b.key]) %></td><% }) %>
        <td class="text-end due-amount"><%= formatCurrency(grand) %></td>
      </tr>
    </tfoot>
    <% } %>
  </table>
</div></div></div>
<%- include('../partials/footer') %>
