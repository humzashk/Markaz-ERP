<%- include('../partials/header') %>
<div class="page-header"><h2><i class="bi bi-hourglass-split"></i> Aged Payable</h2><button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button></div>
<div class="card"><div class="card-body p-0"><div class="table-responsive">
  <table class="table table-hover mb-0"><thead><tr><th>#</th><th>Vendor</th><th>Phone</th><th>City</th><th class="text-end">Amount Payable</th><th>Last Transaction</th></tr></thead><tbody>
    <% vendors.forEach((v, i) => { %><tr><td><%= i+1 %></td><td><strong><%= v.name %></strong></td><td><%= v.phone || '-' %></td><td><%= v.city || '-' %></td><td class="text-end due-amount fs-5"><%= formatCurrency(Math.abs(v.balance)) %></td><td><%= formatDate(v.last_txn) %></td></tr><% }) %>
    <% if (!vendors.length) { %><tr><td colspan="6" class="text-center text-muted py-3">No outstanding payables</td></tr><% } %>
  </tbody>
  <% if (vendors.length) { %><tfoot class="table-light"><tr class="fs-5 fw-bold"><td colspan="4" class="text-end">Total Payable:</td><td class="text-end due-amount"><%= formatCurrency(vendors.reduce((s,v) => s+Math.abs(v.balance), 0)) %></td><td></td></tr></tfoot><% } %>
  </table>
</div></div></div>
<%- include('../partials/footer') %>
