<%- include('../partials/header') %>
<div class="page-header"><h2><i class="bi bi-person-lines-fill"></i> Customer Balances</h2><button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button></div>
<div class="mb-3"><div class="stat-card stat-red" style="max-width:300px"><div class="stat-info"><h3><%= formatCurrency(totalDue) %></h3><p>Total Due from Customers</p></div></div></div>
<div class="card"><div class="card-body p-0"><div class="table-responsive">
  <table class="table table-hover mb-0"><thead><tr><th>#</th><th>Customer</th><th>City</th><th>Phone</th><th class="text-end">Balance</th><th>Status</th></tr></thead><tbody>
    <% customers.forEach((c, i) => { %><tr><td><%= i+1 %></td><td><strong><a href="/ledger/customer/<%= c.id || '' %>"><%= c.name %></a></strong></td><td><%= c.city || '-' %></td><td><%= c.phone || '-' %></td><td class="text-end fw-bold <%= c.balance > 0 ? 'due-amount' : c.balance < 0 ? 'credit-amount' : '' %>"><%= formatCurrency(c.balance) %></td><td><% if (c.balance > 0) { %><span class="badge bg-danger">Due</span><% } else if (c.balance < 0) { %><span class="badge bg-success">Advance</span><% } else { %><span class="badge bg-secondary">Settled</span><% } %></td></tr><% }) %>
  </tbody></table>
</div></div></div>
<%- include('../partials/footer') %>
