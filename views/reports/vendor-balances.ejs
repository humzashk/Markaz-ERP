<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-person-lines-fill"></i> Vendor Balances</h2>
  <div>
    <a href="javascript:history.back()" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    <button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button>
  </div>
</div>
<div class="card"><div class="card-body p-0"><div class="table-responsive">
  <table class="table table-hover mb-0">
    <thead class="table-light"><tr><th>#</th><th>Vendor</th><th>Phone</th><th>City</th><th class="text-end">Balance</th><th>State</th></tr></thead>
    <tbody>
      <% vendors.forEach((v,i) => { %>
        <tr>
          <td><%= i+1 %></td>
          <td><a href="/ledger/vendor/<%= v.id || '' %>"><strong><%= v.name %></strong></a></td>
          <td><%= v.phone || '-' %></td>
          <td><%= v.city || '-' %></td>
          <td class="text-end fw-bold <%= v.balance < 0 ? 'due-amount' : '' %>"><%= formatCurrency(Math.abs(v.balance)) %></td>
          <td><%= v.balance < 0 ? '<span class="badge bg-danger">Payable</span>' : (v.balance > 0 ? '<span class="badge bg-info">Advance</span>' : '<span class="badge bg-secondary">Settled</span>') %></td>
        </tr>
      <% }) %>
      <% if (!vendors.length) { %><tr><td colspan="6" class="text-center text-muted py-3">No vendors</td></tr><% } %>
    </tbody>
    <tfoot class="table-light"><tr class="fw-bold fs-5"><td colspan="4" class="text-end">Total Payable:</td><td class="text-end due-amount"><%= formatCurrency(totalDue) %></td><td></td></tr></tfoot>
  </table>
</div></div></div>
<%- include('../partials/footer') %>
