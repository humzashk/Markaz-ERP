<%- include('../partials/header') %>
<div class="page-header"><h2><i class="bi bi-truck"></i> Delivery & Returns</h2><button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button></div>
<div class="filter-bar no-print">
  <form class="row g-2" method="get">
    <div class="col-md-3"><input type="date" name="from" class="form-control" value="<%= from %>"></div>
    <div class="col-md-3"><input type="date" name="to" class="form-control" value="<%= to %>"></div>
    <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-filter"></i></button></div>
  </form>
</div>
<div class="card"><div class="card-body p-0"><div class="table-responsive">
  <table class="table table-hover mb-0"><thead><tr><th>Bilty No</th><th>Transport</th><th>Route</th><th>Date</th><th>Customer</th><th>Freight</th><th>Status</th></tr></thead><tbody>
    <% deliveries.forEach(d => { %><tr><td><%= d.bilty_no || '-' %></td><td><%= d.transport_name %></td><td><%= d.from_city %> → <%= d.to_city %></td><td><%= formatDate(d.bilty_date) %></td><td><%= d.customer_name || '-' %></td><td><%= formatCurrency(d.freight_charges) %></td><td><span class="badge bg-<%= statusBadge(d.status) %>"><%= d.status %></span></td></tr><% }) %>
    <% if (!deliveries.length) { %><tr><td colspan="7" class="text-center text-muted py-3">No data</td></tr><% } %>
  </tbody></table>
</div></div></div>
<%- include('../partials/footer') %>
