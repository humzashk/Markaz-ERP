<%- include('../partials/header') %>
<div class="page-header"><h2><i class="bi bi-journal-check"></i> Trial Balance</h2><button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i> Print</button></div>
<div class="row g-3">
  <div class="col-md-6">
    <div class="card"><div class="card-header">Customer Balances (Debtors)</div><div class="card-body p-0">
      <table class="table table-hover mb-0"><thead><tr><th>Customer</th><th class="text-end">Balance</th></tr></thead><tbody>
        <% customers.forEach(c => { %><tr><td><%= c.name %></td><td class="text-end <%= c.balance > 0 ? 'due-amount' : 'credit-amount' %>"><%= formatCurrency(c.balance) %></td></tr><% }) %>
        <% if (!customers.length) { %><tr><td colspan="2" class="text-center text-muted">None</td></tr><% } %>
      </tbody></table>
    </div></div>
  </div>
  <div class="col-md-6">
    <div class="card"><div class="card-header">Vendor Balances (Creditors)</div><div class="card-body p-0">
      <table class="table table-hover mb-0"><thead><tr><th>Vendor</th><th class="text-end">Balance</th></tr></thead><tbody>
        <% vendors.forEach(v => { %><tr><td><%= v.name %></td><td class="text-end <%= v.balance < 0 ? 'due-amount' : '' %>"><%= formatCurrency(Math.abs(v.balance)) %></td></tr><% }) %>
        <% if (!vendors.length) { %><tr><td colspan="2" class="text-center text-muted">None</td></tr><% } %>
      </tbody></table>
    </div></div>
  </div>
</div>
<%- include('../partials/footer') %>
