<%- include('../partials/header') %>
<div class="page-header"><h2><i class="bi bi-wallet"></i> Vendor Payments</h2><button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button></div>
<div class="filter-bar no-print">
  <form class="row g-2" method="get">
    <div class="col-md-3"><input type="date" name="from" class="form-control" value="<%= from %>"></div>
    <div class="col-md-3"><input type="date" name="to" class="form-control" value="<%= to %>"></div>
    <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-filter"></i></button></div>
  </form>
</div>
<div class="row g-3">
  <div class="col-md-6">
    <div class="card"><div class="card-header">Payments List</div><div class="card-body p-0">
      <table class="table table-hover mb-0"><thead><tr><th>Date</th><th>Vendor</th><th class="text-end">Amount</th><th>Method</th></tr></thead><tbody>
        <% payments.forEach(p => { %><tr><td><%= formatDate(p.payment_date) %></td><td><%= p.vendor_name %></td><td class="text-end fw-bold"><%= formatCurrency(p.amount) %></td><td><%= p.payment_method %></td></tr><% }) %>
        <% if (!payments.length) { %><tr><td colspan="4" class="text-center text-muted">No payments</td></tr><% } %>
      </tbody></table>
    </div></div>
  </div>
  <div class="col-md-6">
    <div class="card"><div class="card-header">Vendor Summary</div><div class="card-body p-0">
      <table class="table table-hover mb-0"><thead><tr><th>Vendor</th><th class="text-end">Paid</th><th class="text-end">Balance</th></tr></thead><tbody>
        <% vendorSummary.forEach(v => { %><tr><td><%= v.name %></td><td class="text-end"><%= formatCurrency(v.total_paid) %></td><td class="text-end <%= v.balance < 0 ? 'due-amount' : '' %>"><%= formatCurrency(Math.abs(v.balance)) %></td></tr><% }) %>
      </tbody></table>
    </div></div>
  </div>
</div>
<%- include('../partials/footer') %>
