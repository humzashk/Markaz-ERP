<%- include('../partials/header') %>
<div class="page-header"><h2><i class="bi bi-calendar3"></i> Sales by Month</h2><button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button></div>
<div class="filter-bar no-print">
  <form class="row g-2" method="get">
    <div class="col-md-2"><input type="number" name="year" class="form-control" value="<%= year %>" min="2020" max="2030"></div>
    <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-filter"></i> Filter</button></div>
  </form>
</div>
<div class="row g-3">
  <div class="col-md-8">
    <div class="card"><div class="card-body"><canvas id="salesChart" height="80"></canvas></div></div>
  </div>
  <div class="col-md-4">
    <div class="card"><div class="card-header">Monthly Data</div><div class="card-body p-0">
      <table class="table table-hover mb-0"><thead><tr><th>Month</th><th class="text-end">Invoices</th><th class="text-end">Total</th></tr></thead><tbody>
        <% monthlySales.forEach(m => { %><tr><td><%= m.month %></td><td class="text-end"><%= m.count %></td><td class="text-end fw-bold"><%= formatCurrency(m.total) %></td></tr><% }) %>
        <% if (!monthlySales.length) { %><tr><td colspan="3" class="text-center text-muted">No data</td></tr><% } %>
      </tbody></table>
    </div></div>
  </div>
</div>
<script>
const data = <%- JSON.stringify(monthlySales) %>;
new Chart(document.getElementById('salesChart'), {
  type: 'bar', data: { labels: data.map(d => d.month), datasets: [{ label: 'Sales', data: data.map(d => d.total), backgroundColor: 'rgba(52,152,219,0.7)', borderRadius: 4 }] },
  options: { responsive: true, scales: { y: { beginAtZero: true } } }
});
</script>
<%- include('../partials/footer') %>
