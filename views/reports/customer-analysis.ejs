<%- include('../partials/header') %>
<div class="page-header"><h2><i class="bi bi-people"></i> Customer Analysis</h2><button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button></div>
<div class="filter-bar no-print">
  <form class="row g-2" method="get">
    <div class="col-md-3"><input type="date" name="from" class="form-control" value="<%= from %>"></div>
    <div class="col-md-3"><input type="date" name="to" class="form-control" value="<%= to %>"></div>
    <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-filter"></i></button></div>
  </form>
</div>
<div class="card"><div class="card-body p-0"><div class="table-responsive">
  <table class="table table-hover mb-0"><thead><tr><th>#</th><th>Customer</th><th>City</th><th class="text-end">Invoices</th><th class="text-end">Total Sales</th><th class="text-end">Balance</th></tr></thead><tbody>
    <% analysis.forEach((a, i) => { %><tr><td><%= i+1 %></td><td><strong><%= a.name %></strong></td><td><%= a.city || '-' %></td><td class="text-end"><%= a.invoice_count %></td><td class="text-end fw-bold text-success"><%= formatCurrency(a.total_sales) %></td><td class="text-end <%= a.balance > 0 ? 'due-amount' : '' %>"><%= formatCurrency(a.balance) %></td></tr><% }) %>
    <% if (!analysis.length) { %><tr><td colspan="6" class="text-center text-muted py-3">No data</td></tr><% } %>
  </tbody></table>
</div></div></div>
<%- include('../partials/footer') %>
