<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-people"></i> Customer Analysis</h2>
  <div>
    <a href="javascript:history.back()" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    <button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button>
  </div>
</div>
<div class="filter-bar no-print mb-3">
  <form class="row g-2" method="get">
    <div class="col-md-4">
      <select name="customer_id" class="form-select">
        <option value="">— All Customers (Summary) —</option>
        <% allCustomers.forEach(c => { %><option value="<%= c.id %>" <%= customerId==c.id?'selected':'' %>><%= c.name %></option><% }) %>
      </select>
    </div>
    <div class="col-md-3"><input type="date" name="from" class="form-control" value="<%= from %>"></div>
    <div class="col-md-3"><input type="date" name="to" class="form-control" value="<%= to %>"></div>
    <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-filter"></i> Apply</button></div>
  </form>
</div>

<% if (detail) { %>
  <div class="row g-3 mb-3">
    <div class="col-md-4">
      <div class="card h-100"><div class="card-header"><i class="bi bi-person"></i> <%= detail.name %></div>
        <div class="card-body">
          <div><strong>Phone:</strong> <%= detail.phone || '-' %></div>
          <div><strong>City:</strong> <%= detail.city || '-' %></div>
          <div><strong>Address:</strong> <%= detail.address || '-' %></div>
          <hr>
          <div class="d-flex justify-content-between"><span class="text-muted">Total Sales</span><strong class="text-success"><%= formatCurrency(detail.totalSales) %></strong></div>
          <div class="d-flex justify-content-between"><span class="text-muted">Total Paid</span><strong class="text-info"><%= formatCurrency(detail.totalPaid) %></strong></div>
          <div class="d-flex justify-content-between"><span class="text-muted">Balance</span><strong class="<%= detail.balance > 0 ? 'due-amount' : '' %>"><%= formatCurrency(detail.balance) %></strong></div>
          <div class="d-flex justify-content-between"><span class="text-muted">Invoices</span><strong><%= detail.invoices.length %></strong></div>
        </div>
      </div>
    </div>
    <div class="col-md-8">
      <div class="card h-100"><div class="card-header"><i class="bi bi-graph-up"></i> Top Products Bought</div>
        <div class="card-body p-0">
          <table class="table table-sm mb-0"><thead class="table-light"><tr><th>Product</th><th class="text-end">Qty</th><th class="text-end">Amount</th></tr></thead>
            <tbody>
              <% detail.topProducts.forEach(p => { %><tr><td><%= p.name %></td><td class="text-end"><%= p.qty %></td><td class="text-end fw-bold"><%= formatCurrency(p.amount) %></td></tr><% }) %>
              <% if (!detail.topProducts.length) { %><tr><td colspan="3" class="text-center text-muted py-2">No purchases in this period</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-3 mb-3">
    <div class="col-md-7">
      <div class="card"><div class="card-header"><i class="bi bi-receipt"></i> Invoices</div>
        <div class="card-body p-0">
          <table class="table table-sm mb-0"><thead class="table-light"><tr><th>Inv #</th><th>Date</th><th class="text-end">Total</th><th>Status</th></tr></thead>
            <tbody>
              <% detail.invoices.forEach(i => { %><tr><td><a href="/invoices/view/<%= i.id %>"><%= i.invoice_no %></a></td><td><%= formatDate(i.invoice_date) %></td><td class="text-end"><%= formatCurrency(i.total) %></td><td><span class="badge bg-<%= statusBadge(i.status) %>"><%= i.status %></span></td></tr><% }) %>
              <% if (!detail.invoices.length) { %><tr><td colspan="4" class="text-center text-muted py-2">None</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="col-md-5">
      <div class="card"><div class="card-header"><i class="bi bi-cash-coin"></i> Payments</div>
        <div class="card-body p-0">
          <table class="table table-sm mb-0"><thead class="table-light"><tr><th>Date</th><th class="text-end">Amount</th><th>Method</th></tr></thead>
            <tbody>
              <% detail.payments.forEach(p => { %><tr><td><%= formatDate(p.payment_date) %></td><td class="text-end fw-bold text-success"><%= formatCurrency(p.amount) %></td><td><%= p.payment_method %></td></tr><% }) %>
              <% if (!detail.payments.length) { %><tr><td colspan="3" class="text-center text-muted py-2">None</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
<% } else { %>
  <div class="card"><div class="card-body p-0"><div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light"><tr><th>#</th><th>Customer</th><th>City</th><th>Phone</th><th class="text-end">Invoices</th><th class="text-end">Avg Sale</th><th class="text-end">Total Sales</th><th>Last Sale</th><th class="text-end">Balance</th></tr></thead>
      <tbody>
      <% analysis.forEach((a, i) => { %>
        <tr>
          <td><%= i+1 %></td>
          <td><a href="?customer_id=<%= a.id %>&from=<%= from %>&to=<%= to %>"><strong><%= a.name %></strong></a></td>
          <td><%= a.city || '-' %></td>
          <td><%= a.phone || '-' %></td>
          <td class="text-end"><%= a.invoice_count %></td>
          <td class="text-end"><%= formatCurrency(a.avg_sale) %></td>
          <td class="text-end fw-bold text-success"><%= formatCurrency(a.total_sales) %></td>
          <td><%= formatDate(a.last_sale) %></td>
          <td class="text-end <%= a.balance > 0 ? 'due-amount' : '' %>"><%= formatCurrency(a.balance) %></td>
        </tr>
      <% }) %>
      <% if (!analysis.length) { %><tr><td colspan="9" class="text-center text-muted py-3">No data</td></tr><% } %>
      </tbody>
    </table>
  </div></div></div>
<% } %>
<%- include('../partials/footer') %>
