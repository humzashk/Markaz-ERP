<%- include('../partials/header') %>
<div class="page-header"><h2><i class="bi bi-send"></i> Bilty / Delivery Report</h2><button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button></div>
<div class="filter-bar no-print">
  <form class="row g-2" method="get">
    <div class="col-md-3"><input type="date" name="from" class="form-control" value="<%= from %>"></div>
    <div class="col-md-3"><input type="date" name="to" class="form-control" value="<%= to %>"></div>
    <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-filter"></i></button></div>
  </form>
</div>
<div class="mb-3"><div class="stat-card stat-teal" style="max-width:300px"><div class="stat-info"><h3><%= formatCurrency(totalFreight) %></h3><p>Total Freight Charges</p></div></div></div>
<div class="card"><div class="card-body p-0"><div class="table-responsive">
  <table class="table table-hover mb-0"><thead><tr><th>Bilty No</th><th>Transport</th><th>Route</th><th>Date</th><th>Customer</th><th>Order/Invoice</th><th class="text-end">Freight</th><th>Status</th></tr></thead><tbody>
    <% bilties.forEach(b => { %><tr><td><%= b.bilty_no || '-' %></td><td><%= b.transport_name %></td><td><%= b.from_city %> → <%= b.to_city %></td><td><%= formatDate(b.bilty_date) %></td><td><%= b.customer_name || '-' %></td><td><%= b.order_no || b.invoice_no || '-' %></td><td class="text-end fw-bold"><%= formatCurrency(b.freight_charges) %></td><td><span class="badge bg-<%= statusBadge(b.status) %>"><%= b.status %></span></td></tr><% }) %>
    <% if (!bilties.length) { %><tr><td colspan="8" class="text-center text-muted py-3">No bilty records</td></tr><% } %>
  </tbody></table>
</div></div></div>
<%- include('../partials/footer') %>
