<%- include('../partials/header') %>
<div class="page-header"><h2><i class="bi bi-exclamation-circle text-danger"></i> Low Stock Alert</h2><button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button></div>
<div class="card"><div class="card-body p-0"><div class="table-responsive">
  <table class="table table-hover mb-0"><thead><tr><th>#</th><th>Product</th><th>Category</th><th class="text-end">Current Stock</th><th class="text-end">Min Stock</th><th class="text-end">Deficit</th></tr></thead><tbody>
    <% products.forEach((p, i) => { %><tr class="table-warning"><td><%= i+1 %></td><td><strong><%= p.name %></strong></td><td><%= p.category || '-' %></td><td class="text-end text-danger fw-bold"><%= p.stock %></td><td class="text-end"><%= p.min_stock %></td><td class="text-end fw-bold text-danger"><%= p.min_stock - p.stock %></td></tr><% }) %>
    <% if (!products.length) { %><tr><td colspan="6" class="text-center text-success py-4"><i class="bi bi-check-circle"></i> All products have sufficient stock</td></tr><% } %>
  </tbody></table>
</div></div></div>
<%- include('../partials/footer') %>
