<%- include('../partials/header') %>
<div class="page-header"><h2><i class="bi bi-wallet2"></i> Expense Report</h2><button onclick="window.print()" class="btn btn-outline-secondary no-print"><i class="bi bi-printer"></i></button></div>
<div class="filter-bar no-print">
  <form class="row g-2" method="get">
    <div class="col-md-3"><input type="date" name="from" class="form-control" value="<%= from %>"></div>
    <div class="col-md-3"><input type="date" name="to" class="form-control" value="<%= to %>"></div>
    <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-filter"></i></button></div>
  </form>
</div>
<div class="mb-3"><div class="stat-card stat-orange" style="max-width:300px"><div class="stat-info"><h3><%= formatCurrency(totalExp) %></h3><p>Total Expenses</p></div></div></div>
<div class="row g-3">
  <div class="col-md-5">
    <div class="card"><div class="card-header">By Category</div><div class="card-body p-0">
      <table class="table mb-0"><thead><tr><th>Category</th><th class="text-end">Count</th><th class="text-end">Total</th></tr></thead><tbody>
        <% byCategory.forEach(c => { %><tr><td><%= c.category %></td><td class="text-end"><%= c.count %></td><td class="text-end fw-bold"><%= formatCurrency(c.total) %></td></tr><% }) %>
      </tbody></table>
    </div></div>
  </div>
  <div class="col-md-7">
    <div class="card"><div class="card-header">All Expenses</div><div class="card-body p-0"><div class="table-responsive">
      <table class="table table-hover mb-0"><thead><tr><th>Date</th><th>Category</th><th>Description</th><th class="text-end">Amount</th></tr></thead><tbody>
        <% expenses.forEach(e => { %><tr><td><%= formatDate(e.expense_date) %></td><td><span class="badge bg-secondary"><%= e.category %></span></td><td><%= e.description || '-' %></td><td class="text-end fw-bold text-danger"><%= formatCurrency(e.amount) %></td></tr><% }) %>
      </tbody></table>
    </div></div></div>
  </div>
</div>
<%- include('../partials/footer') %>
