<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-building"></i> Warehouses</h2>
  <a href="/warehouses/add" class="btn btn-primary"><i class="bi bi-plus"></i> Add Warehouse</a>
</div>
<div class="row">
  <% warehouses.forEach(w => { %>
  <div class="col-md-4 mb-3">
    <div class="card h-100">
      <div class="card-body">
        <h5 class="card-title"><%= w.name %></h5>
        <p class="text-muted mb-1"><i class="bi bi-geo-alt"></i> <%= w.location || 'N/A' %></p>
        <p class="text-muted mb-2 small"><%= w.notes || '' %></p>
        <span class="badge bg-<%= w.status === 'active' ? 'success' : 'secondary' %>"><%= w.status %></span>
      </div>
      <div class="card-footer d-flex gap-2">
        <a href="/warehouses/view/<%= w.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i> Stock</a>
        <a href="/warehouses/edit/<%= w.id %>" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
        <form method="POST" action="/warehouses/delete/<%= w.id %>" class="ms-auto confirm-delete">
          <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
        </form>
      </div>
    </div>
  </div>
  <% }) %>
  <% if (!warehouses.length) { %>
  <div class="col-12"><p class="text-center text-muted py-5">No warehouses yet. <a href="/warehouses/add">Add one.</a></p></div>
  <% } %>
</div>
<%- include('../partials/footer') %>
