<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-bag"></i> Purchase: <%= purchase.purchase_no %></h2>
  <div class="d-flex gap-2">
    <a href="/purchases/edit/<%= purchase.id %>" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a href="/payments/add?type=vendor&entity_id=<%= purchase.vendor_id %>" class="btn btn-success"><i class="bi bi-cash"></i> Make Payment</a>
    <a href="/purchases" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>
<div class="row g-3">
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Purchase Info</div>
      <div class="card-body">
        <table class="table table-borderless mb-0">
          <tr><th width="120">Vendor</th><td><strong><%= purchase.vendor_name %></strong></td></tr>
          <tr><th>Phone</th><td><%= purchase.vendor_phone || '-' %></td></tr>
          <tr><th>Date</th><td><%= formatDate(purchase.purchase_date) %></td></tr>
          <tr><th>Status</th><td><span class="badge bg-<%= statusBadge(purchase.status) %> fs-6"><%= purchase.status %></span></td></tr>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-8">
    <div class="card">
      <div class="card-header">Items</div>
      <div class="card-body p-0">
        <table class="table mb-0">
          <thead><tr><th>#</th><th>Product</th><th class="text-end">Pkg</th><th class="text-end">Pcs/Ctn</th><th class="text-end">Qty</th><th class="text-end">Rate</th><th class="text-end">Amount</th></tr></thead>
          <tbody>
            <% items.forEach((item, i) => { %>
            <tr>
              <td><%= i+1 %></td><td><strong><%= item.product_name %></strong></td>
              <td class="text-end"><%= item.packages %></td><td class="text-end"><%= item.packaging %></td>
              <td class="text-end"><%= item.quantity %></td><td class="text-end"><%= formatCurrency(item.rate) %></td>
              <td class="text-end fw-bold"><%= formatCurrency(item.amount) %></td>
            </tr>
            <% }) %>
          </tbody>
          <tfoot class="table-light fw-bold">
            <tr><td colspan="6" class="text-end">Subtotal:</td><td class="text-end"><%= formatCurrency(purchase.subtotal) %></td></tr>
            <% if (purchase.discount > 0) { %><tr><td colspan="6" class="text-end">Discount:</td><td class="text-end text-danger">-<%= formatCurrency(purchase.discount) %></td></tr><% } %>
            <tr class="fs-5"><td colspan="6" class="text-end">TOTAL:</td><td class="text-end text-success"><%= formatCurrency(purchase.total) %></td></tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
