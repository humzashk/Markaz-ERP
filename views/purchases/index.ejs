<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-bag"></i> Purchases</h2>
  <a href="/purchases/add" class="btn btn-primary btn-lg"><i class="bi bi-plus"></i> New Purchase</a>
</div>
<div class="filter-bar">
  <form class="row g-2" method="get">
    <div class="col-md-6"><input type="text" name="search" class="form-control" placeholder="Search by purchase no, vendor..." value="<%= search %>"></div>
    <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-search"></i></button></div>
    <% if (search) { %><div class="col-auto"><a href="/purchases" class="btn btn-outline-secondary">Clear</a></div><% } %>
  </form>
</div>
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead><tr><th>Purchase No</th><th>Vendor</th><th>Date</th><th>Total</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% purchases.forEach(p => { %>
          <tr>
            <td><strong><%= p.purchase_no %></strong></td>
            <td><%= p.vendor_name %></td>
            <td><%= formatDate(p.purchase_date) %></td>
            <td class="fw-bold"><%= formatCurrency(p.total) %></td>
            <td><span class="badge bg-<%= statusBadge(p.status) %>"><%= p.status %></span></td>
            <td>
              <a href="/purchases/view/<%= p.id %>" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
              <a href="/purchases/edit/<%= p.id %>" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
              <form class="d-inline delete-form" method="post" action="/purchases/delete/<%= p.id %>"><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>
            </td>
          </tr>
          <% }) %>
          <% if (!purchases.length) { %><tr><td colspan="6" class="text-center text-muted py-4">No purchases found</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
