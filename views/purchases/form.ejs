<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-bag-plus"></i> <%= edit ? 'Edit Purchase' : 'New Purchase' %></h2>
  <a href="/purchases" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>
<form method="post" action="/purchases/<%= edit ? 'edit/'+purchase.id : 'add' %>">
<%- include("../partials/form-error") %>
  <div class="row g-3 mb-3">
    <div class="col-md-4">
      <div class="card">
        <div class="card-header">Purchase Details</div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label fw-bold">Account *</label>
            <select name="account_scope" class="form-select" required>
              <% var _purScope = (purchase && purchase.account_scope) || 'plastic_markaz'; %>
              <option value="plastic_markaz"  <%= _purScope === 'plastic_markaz'  ? 'selected' : '' %>>Plastic Markaz</option>
              <option value="wings_furniture" <%= _purScope === 'wings_furniture' ? 'selected' : '' %>>Wings Furniture</option>
              <option value="cooler"          <%= _purScope === 'cooler'          ? 'selected' : '' %>>Cooler</option>
            </select>
            <div class="form-text">Purchase will be booked under this business account.</div>
          </div>
          <div class="mb-3"><label class="form-label">Vendor *</label>
            <select name="vendor_id" class="form-select" required>
              <option value="">Select Vendor</option>
              <% vendors.forEach(v => { %><option value="<%= v.id %>" <%= (purchase && v.id==purchase.vendor_id)?'selected':'' %>><%= v.name %></option><% }) %>
            </select>
          </div>
          <div class="mb-3"><label class="form-label">Purchase Date *</label><input type="date" name="purchase_date" class="form-control" value="<%= purchase?.purchase_date || new Date().toISOString().split('T')[0] %>" required></div>
          <div class="mb-3"><label class="form-label">Delivery Date</label><input type="date" name="delivery_date" class="form-control" value="<%= purchase?.delivery_date || new Date().toISOString().split('T')[0] %>"></div>
          <div class="mb-3"><label class="form-label">Warehouse</label>
            <select name="warehouse_id" class="form-select">
              <option value="">Select Warehouse</option>
              <% warehouses?.forEach(w => { %><option value="<%= w.id %>" <%= (purchase && w.id==purchase.warehouse_id)?'selected':'' %>><%= w.name %></option><% }) %>
            </select>
          </div>
          <div class="mb-3"><label class="form-label">Bilty #</label><input type="text" name="bilty_no" class="form-control" value="<%= purchase?.bilty_no || '' %>"></div>
          <% if (edit) { %>
          <div class="mb-3"><label class="form-label">Status</label>
            <select name="status" class="form-select">
              <% ['pending','confirmed','received','cancelled'].forEach(s => { %><option value="<%= s %>" <%= purchase.status===s?'selected':'' %>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option><% }) %>
            </select>
          </div>
          <% } %>
          <div class="mb-3"><label class="form-label">Transport</label>
            <div class="input-group">
              <select name="transport_id" class="form-select">
                <option value="">— None —</option>
                <% (typeof transports !== 'undefined' ? transports : []).forEach(t => { %>
                  <option value="<%= t.id %>" <%= (purchase && purchase.transport_id==t.id)?'selected':'' %>><%= t.name %></option>
                <% }) %>
              </select>
              <a href="/transports/add" target="_blank" class="btn btn-outline-secondary" title="New transport"><i class="bi bi-plus"></i></a>
            </div>
          </div>
          <div class="mb-3"><label class="form-label">Discount (PKR)</label><input type="number" id="discount" name="discount" class="form-control" value="<%= purchase?.discount || 0 %>" step="0.01" onchange="calcTotal()"></div>
          <div class="mb-3"><label class="form-label">Delivery Charges (PKR)</label><input type="number" id="delivery_charges" name="delivery_charges" class="form-control" value="<%= purchase?.delivery_charges || 0 %>" step="0.01" onchange="calcTotal()"></div>
          <div class="mb-3"><label class="form-label">Notes</label><textarea name="notes" class="form-control" rows="2"><%= purchase?.notes || '' %></textarea></div>
        </div>
      </div>
    </div>
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">Purchase Items</div>
        <div class="card-body">
          <%- include('../partials/item-rows') %>
          <div class="text-end border-top pt-3">
            <div class="d-flex justify-content-end gap-4 mb-2"><span class="text-muted">Subtotal:</span><strong id="subtotal">0.00</strong></div>
            <div class="d-flex justify-content-end gap-4"><span class="fs-5 fw-bold">TOTAL:</span><strong class="fs-5 text-success" id="grandTotal">0.00</strong></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary btn-lg px-5"><i class="bi bi-save"></i> <%= edit ? 'Update' : 'Create' %> Purchase</button>
    <a href="/purchases" class="btn btn-outline-secondary btn-lg">Cancel</a>
  </div>
</form>
<%- include('../partials/footer') %>
