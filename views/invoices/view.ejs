<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-receipt"></i> Invoice: <%= invoice.invoice_no %></h2>
  <div class="d-flex gap-2 flex-wrap no-print">
    <a href="/invoices/print/<%= invoice.id %>" class="btn btn-outline-secondary" target="_blank"><i class="bi bi-printer"></i> Print</a>
    <a href="/invoices/pdf/<%= invoice.id %>" class="btn btn-danger" target="_blank"><i class="bi bi-file-pdf"></i> PDF</a>
    <a href="/invoices/edit/<%= invoice.id %>" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a href="/payments/add?type=customer&entity_id=<%= invoice.customer_id %>&redirect=/invoices/view/<%= invoice.id %>" class="btn btn-success"><i class="bi bi-cash"></i> Receive Payment</a>
    <% if (!bilty) { %><a href="/bilty/add" class="btn btn-info"><i class="bi bi-send"></i> Add Bilty</a><% } %>
    <a href="/invoices" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>

<div class="card print-invoice">
  <!-- Invoice Header -->
  <div class="card-body">
    <div class="row mb-4">
      <div class="col-6">
        <div class="company-name">PLASTIC MARKAZ</div>
        <div class="text-muted">Plastic Products & Trading</div>
      </div>
      <div class="col-6 text-end">
        <div class="invoice-title">INVOICE</div>
        <div><strong><%= invoice.invoice_no %></strong></div>
        <div>Date: <%= formatDate(invoice.invoice_date) %></div>
        <% if (invoice.due_date) { %><div>Due: <%= formatDate(invoice.due_date) %></div><% } %>
        <div class="mt-1"><span class="badge bg-<%= statusBadge(invoice.status) %> fs-6"><%= invoice.status.toUpperCase() %></span></div>
      </div>
    </div>

    <div class="row mb-4 p-3 rounded" style="background:#f8f9fa">
      <div class="col-md-6">
        <strong>Bill To:</strong><br>
        <strong class="fs-5"><%= invoice.customer_name %></strong><br>
        <% if (invoice.customer_phone) { %><i class="bi bi-telephone"></i> <%= invoice.customer_phone %><br><% } %>
        <% if (invoice.customer_address) { %><i class="bi bi-geo-alt"></i> <%= invoice.customer_address %><br><% } %>
        <% if (invoice.customer_city) { %><i class="bi bi-building"></i> <%= invoice.customer_city %><% } %>
      </div>
    </div>

    <!-- Items Table -->
    <div class="table-responsive">
      <table class="table border">
        <thead class="table-dark">
          <tr>
            <th>#</th><th>Product</th>
            <th class="text-end">Pkg (Ctn)</th>
            <th class="text-end">Pcs/Ctn</th>
            <th class="text-end">Qty (Pcs)</th>
            <th class="text-end">Rate/Pc</th>
            <th class="text-end">Amount</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach((item, i) => { %>
          <tr>
            <td><%= i+1 %></td>
            <td><strong><%= item.product_name %></strong></td>
            <td class="text-end"><%= item.packages %></td>
            <td class="text-end"><%= item.packaging %></td>
            <td class="text-end"><strong><%= item.quantity.toLocaleString() %></strong></td>
            <td class="text-end"><%= formatCurrency(item.rate) %></td>
            <td class="text-end fw-bold"><%= formatCurrency(item.amount) %></td>
          </tr>
          <% }) %>
        </tbody>
        <tfoot class="table-light">
          <tr><td colspan="6" class="text-end fw-bold">Subtotal:</td><td class="text-end"><%= formatCurrency(invoice.subtotal) %></td></tr>
          <% if (invoice.discount > 0) { %><tr><td colspan="6" class="text-end fw-bold text-danger">Discount:</td><td class="text-end text-danger">-<%= formatCurrency(invoice.discount) %></td></tr><% } %>
          <tr class="fs-5 table-success"><td colspan="6" class="text-end fw-bold">TOTAL:</td><td class="text-end fw-bold"><%= formatCurrency(invoice.total) %></td></tr>
          <% if (invoice.commission_amount > 0) { %>
          <tr><td colspan="6" class="text-end fw-bold text-info">Less Commission (<%= invoice.customer_commission || '' %>%):</td><td class="text-end text-info">-<%= formatCurrency(invoice.commission_amount) %></td></tr>
          <tr class="fs-5 table-warning"><td colspan="6" class="text-end fw-bold">GROSS AMOUNT:</td><td class="text-end fw-bold"><%= formatCurrency(invoice.total - invoice.commission_amount) %></td></tr>
          <% } %>
        </tfoot>
      </table>
    </div>

    <!-- Bilty Section -->
    <% if (bilty) { %>
    <div class="mt-3 p-3 rounded border-start border-info border-3 bg-light">
      <strong><i class="bi bi-send text-info"></i> Transport Details:</strong>
      <span class="ms-2"><%= bilty.transport_name %></span>
      <% if (bilty.bilty_no) { %> | Bilty No: <strong><%= bilty.bilty_no %></strong><% } %>
      | From: <strong><%= bilty.from_city %></strong> → To: <strong><%= bilty.to_city %></strong>
      | Freight: <strong class="text-success"><%= formatCurrency(bilty.freight_charges) %></strong>
      | Status: <span class="badge bg-<%= statusBadge(bilty.status) %>"><%= bilty.status %></span>
    </div>
    <% } %>

    <% if (invoice.notes) { %><div class="mt-3 text-muted"><strong>Notes:</strong> <%= invoice.notes %></div><% } %>

    <div class="text-center text-muted border-top mt-4 pt-3">
      <small>Thank you for your business! — PLASTIC MARKAZ</small>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
