<%- include('../partials/header') %>
<div class="page-header">
  <h2><i class="bi bi-receipt"></i> <%= edit ? 'Edit Invoice' : 'New Invoice' %></h2>
  <a href="/invoices" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>
<form method="post" action="/invoices/<%= edit ? 'edit/'+invoice.id : 'add' %>">
<%- include("../partials/form-error") %>
  <div class="row g-3 mb-3">
    <div class="col-md-4">
      <div class="card">
        <div class="card-header">Invoice Details</div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label fw-bold">Account *</label>
            <select name="account_scope" class="form-select" required>
              <% var _invScope = (invoice && invoice.account_scope) || 'plastic_markaz'; %>
              <option value="plastic_markaz"  <%= _invScope === 'plastic_markaz'  ? 'selected' : '' %>>Plastic Markaz</option>
              <option value="wings_furniture" <%= _invScope === 'wings_furniture' ? 'selected' : '' %>>Wings Furniture</option>
              <option value="cooler"          <%= _invScope === 'cooler'          ? 'selected' : '' %>>Cooler</option>
            </select>
            <div class="form-text">Invoice will be booked under this business account.</div>
          </div>
          <div class="mb-3"><label class="form-label">Customer *</label>
            <select name="customer_id" class="form-select" required>
              <option value="">Select Customer</option>
              <% customers.forEach(c => { %><option value="<%= c.id %>" <%= (invoice && c.id==invoice.customer_id)?'selected':'' %>><%= c.name %></option><% }) %>
            </select>
          </div>
          <div class="mb-3"><label class="form-label">Invoice Date *</label><input type="date" name="invoice_date" id="invoice_date" class="form-control" value="<%= invoice?.invoice_date || new Date().toISOString().split('T')[0] %>" required onchange="applyDuePreset()"></div>
          <div class="mb-3">
            <label class="form-label">Due Date *</label>
            <div class="input-group">
              <select id="due_preset" class="form-select" style="max-width:130px" onchange="applyDuePreset()">
                <option value="">— Custom —</option>
                <option value="15">+15 days</option>
                <option value="30" selected>+30 days</option>
                <option value="45">+45 days</option>
                <option value="60">+60 days</option>
              </select>
              <input type="date" name="due_date" id="due_date" class="form-control" value="<%= invoice?.due_date || '' %>" required>
            </div>
          </div>
          <div class="mb-3"><label class="form-label">Delivery Date</label><input type="date" name="delivery_date" class="form-control" value="<%= invoice?.delivery_date || new Date().toISOString().split('T')[0] %>"></div>
          <div class="mb-3"><label class="form-label fw-bold">Warehouse *</label>
            <select name="warehouse_id" class="form-select" required>
              <option value="">Select Warehouse</option>
              <% warehouses?.forEach(w => { %><option value="<%= w.id %>" <%= (invoice && w.id==invoice.warehouse_id)?'selected':'' %>><%= w.name %></option><% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Bilty #</label>
            <div class="input-group">
              <input type="text" name="bilty_no" id="bilty_no" class="form-control" value="<%= invoice?.bilty_no || '' %>" placeholder="e.g. 1234 → BLT-0001">
              <button type="button" id="biltyNextBtn" class="btn btn-outline-secondary" title="Auto-fill next Bilty #"><i class="bi bi-hash"></i> Next</button>
            </div>
            <div class="form-text">Enter digits (e.g. 42) — auto-formats to BLT-0042 on save.</div>
          </div>
          <div class="mb-3"><label class="form-label">Transport <span id="transportRequired" class="text-danger d-none">*</span></label>
            <div class="input-group">
              <select name="transport_id" id="transport_id" class="form-select">
                <option value="">— None —</option>
                <% (typeof transports !== 'undefined' ? transports : []).forEach(t => { %>
                  <option value="<%= t.id %>" <%= (invoice && invoice.transport_id==t.id)?'selected':'' %>><%= t.name %></option>
                <% }) %>
              </select>
              <a href="/transports/add" target="_blank" class="btn btn-outline-secondary" title="New transport"><i class="bi bi-plus"></i></a>
            </div>
            <input type="hidden" name="transporter_name" value="<%= invoice?.transporter_name || '' %>">
          </div>
          <div class="mb-3"><label class="form-label">Transport Charges (+/-)</label><input type="number" step="0.01" name="transport_charges" id="transport_charges" class="form-control" value="<%= invoice?.transport_charges || 0 %>" onchange="calcTotal()"></div>
          <input type="hidden" name="delivery_charges" id="delivery_charges" value="0">
          <!-- Link Orders dropdown removed — use 'Generate Invoice from Orders' button on listing page -->
          <% if (!edit && typeof linkedOrderIds !== 'undefined' && linkedOrderIds && linkedOrderIds.length) { %>
            <% linkedOrderIds.forEach(oid => { %>
              <input type="hidden" name="order_ids" value="<%= oid %>">
            <% }) %>
            <div class="alert alert-info py-2 mb-3"><i class="bi bi-link-45deg"></i> This invoice is being generated from <strong><%= linkedOrderIds.length %> order(s)</strong>. Items pre-loaded — edit as needed.</div>
          <% } %>
          <% if (edit) { %>
          <div class="mb-3"><label class="form-label">Status</label>
            <select name="status" class="form-select">
              <% ['unpaid','paid','partial'].forEach(s => { %><option value="<%= s %>" <%= invoice.status===s?'selected':'' %>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option><% }) %>
            </select>
          </div>
          <% } %>
          <div class="mb-3"><label class="form-label">Notes</label><textarea name="notes" class="form-control" rows="2"><%= invoice?.notes || '' %></textarea></div>
        </div>
      </div>
    </div>
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">Invoice Items <small class="text-muted">Commission per item</small></div>
        <div class="card-body">
          <%- include('../partials/item-rows') %>
          <div class="text-end border-top pt-3">
            <div class="d-flex justify-content-end gap-4 mb-2"><span class="text-muted">Subtotal:</span><strong id="subtotal">0.00</strong></div>
            <div class="d-flex justify-content-end gap-4 mb-2"><span class="fs-5 fw-bold">TOTAL:</span><strong class="fs-5 text-success" id="grandTotal">0.00</strong></div>
            <div class="d-flex justify-content-end gap-4 mb-2 text-info">
              <span>Less Commission (<span id="commPctDisp">0</span>%):</span><strong id="commAmount">0.00</strong>
            </div>
            <div class="d-flex justify-content-end gap-4 mb-2 text-secondary">
              <span>Less Discount:</span><strong id="discAmount">0.00</strong>
            </div>
            <div class="d-flex justify-content-end gap-4 border-top pt-2">
              <span class="fs-5 fw-bold text-warning">NET AMOUNT:</span><strong class="fs-5 text-warning" id="grossAmount">0.00</strong>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary btn-lg px-5"><i class="bi bi-save"></i> <%= edit ? 'Update Invoice' : 'Create Invoice' %></button>
    <a href="/invoices" class="btn btn-outline-secondary btn-lg">Cancel</a>
  </div>
</form>

<script>
function applyDuePreset() {
  const sel = document.getElementById('due_preset');
  const inv = document.getElementById('invoice_date');
  const due = document.getElementById('due_date');
  if (!sel || !inv || !due) return;
  if (!sel.value) return;
  const days = parseInt(sel.value, 10);
  if (!Number.isFinite(days)) return;
  const d = new Date(inv.value || new Date().toISOString().split('T')[0]);
  d.setDate(d.getDate() + days);
  due.value = d.toISOString().split('T')[0];
}
function syncTransportReq() {
  const bilty = document.getElementById('bilty_no');
  const trans = document.getElementById('transport_id');
  const star = document.getElementById('transportRequired');
  if (!bilty || !trans) return;
  const has = (bilty.value || '').trim().length > 0;
  trans.required = has;
  if (star) star.classList.toggle('d-none', !has);
}
// ── Bilty # auto-format ───────────────────────────────────────────────────────
function fmtBiltyNo(v) {
  if (!v) return '';
  v = v.trim();
  const m = v.match(/^(?:BLT-?)?(\d+)$/i);
  return m ? 'BLT-' + String(parseInt(m[1], 10)).padStart(4, '0') : v.toUpperCase();
}

document.addEventListener('DOMContentLoaded', () => {
  calcTotal();
  // Default due_date to invoice_date+30 only when empty
  const due = document.getElementById('due_date');
  if (due && !due.value) applyDuePreset();
  const bilty = document.getElementById('bilty_no');
  if (bilty) {
    bilty.addEventListener('input', syncTransportReq);
    bilty.addEventListener('blur', function() { if (this.value) this.value = fmtBiltyNo(this.value); });
  }
  syncTransportReq();
  // Next bilty # button
  const nextBtn = document.getElementById('biltyNextBtn');
  if (nextBtn) {
    nextBtn.addEventListener('click', function() {
      this.disabled = true;
      fetch('/api/next-bilty-no')
        .then(r => r.json())
        .then(d => { if (bilty && d.next) { bilty.value = d.next; syncTransportReq(); } })
        .catch(() => {})
        .finally(() => { this.disabled = false; });
    });
  }
});
</script>
<%- include('../partials/footer') %>
