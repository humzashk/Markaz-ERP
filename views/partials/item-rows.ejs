<!-- Reusable items table for Orders/Invoices/Purchases -->
<div class="table-responsive">
<table class="table items-table" id="itemsTable">
  <thead>
    <tr>
      <th width="30">#</th>
      <th>Product</th>
      <th width="90" class="text-center">Ctns</th>
      <th width="80" class="text-center">Pcs/Ctn</th>
      <th width="100" class="text-center">Total Pcs</th>
      <th width="95" class="text-center">Rate/Pc</th>
      <th width="110" class="text-center">Amount</th>
      <th width="40"></th>
    </tr>
  </thead>
  <tbody id="itemsBody">
    <% if (typeof items !== 'undefined' && items.length) { %>
      <% items.forEach((item, idx) => { %>
      <tr>
        <td class="text-muted"><%= idx+1 %></td>
        <td>
          <select name="product_id" class="form-select product-select" required onchange="onProductChange(this)">
            <option value="">— Select Product —</option>
            <% products.forEach(p => { %>
            <option value="<%= p.id %>" data-packaging="<%= p.packaging %>" data-rate="<%= p.rate %>" data-stock="<%= p.stock %>" <%= p.id == item.product_id ? 'selected' : '' %>><%= p.name %> &nbsp;·&nbsp; Stock: <%= p.stock %></option>
            <% }) %>
          </select>
        </td>
        <td>
          <input type="number" name="packages" class="form-control pkg-input text-center fw-bold" min="0" value="<%= item.packages %>" oninput="calcRow(this)" placeholder="0">
        </td>
        <td>
          <input type="number" name="packaging" class="form-control packaging-input text-center text-muted" min="1" value="<%= item.packaging %>" oninput="calcRow(this)">
        </td>
        <td>
          <input type="number" name="quantity" class="form-control qty-input text-center fw-bold text-primary" min="0" value="<%= item.quantity %>" required oninput="onQtyInput(this)">
        </td>
        <td>
          <input type="number" name="rate" class="form-control rate-input text-center" min="0" step="0.01" value="<%= item.rate %>" required oninput="calcTotal()">
        </td>
        <td class="text-center">
          <span class="row-amount fw-bold text-success"><%= item.amount.toFixed(2) %></span>
        </td>
        <td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRow(this)"><i class="bi bi-x"></i></button></td>
      </tr>
      <% }) %>
    <% } else { %>
      <tr>
        <td class="text-muted">1</td>
        <td>
          <select name="product_id" class="form-select product-select" required onchange="onProductChange(this)">
            <option value="">— Select Product —</option>
            <% products.forEach(p => { %>
            <option value="<%= p.id %>" data-packaging="<%= p.packaging %>" data-rate="<%= p.rate %>" data-stock="<%= p.stock %>"><%= p.name %> &nbsp;·&nbsp; Stock: <%= p.stock %></option>
            <% }) %>
          </select>
        </td>
        <td><input type="number" name="packages" class="form-control pkg-input text-center fw-bold" min="0" value="" oninput="calcRow(this)" placeholder="0"></td>
        <td><input type="number" name="packaging" class="form-control packaging-input text-center text-muted" min="1" value="1" oninput="calcRow(this)"></td>
        <td><input type="number" name="quantity" class="form-control qty-input text-center fw-bold text-primary" min="0" value="" required oninput="onQtyInput(this)" placeholder="0"></td>
        <td><input type="number" name="rate" class="form-control rate-input text-center" min="0" step="0.01" value="" required oninput="calcTotal()" placeholder="0.00"></td>
        <td class="text-center"><span class="row-amount fw-bold text-success">0.00</span></td>
        <td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRow(this)"><i class="bi bi-x"></i></button></td>
      </tr>
    <% } %>
  </tbody>
</table>
</div>
<button type="button" class="btn btn-sm btn-outline-primary mb-3" onclick="addItemRow()">
  <i class="bi bi-plus-circle"></i> Add Item
</button>
<script>window.productsData = <%- JSON.stringify(products) %>;</script>
