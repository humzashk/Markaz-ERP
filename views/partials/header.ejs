<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Plastic Markaz ERP</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/airbnb.css" rel="stylesheet">
</head>
<body>
  <!-- Sidebar -->
  <nav id="sidebar" class="sidebar">
    <div class="sidebar-brand">
      <i class="bi bi-box-seam"></i>
      <span>PLASTIC MARKAZ</span>
    </div>
    <ul class="sidebar-nav">
      <li><a href="/" class="<%= page === 'dashboard' ? 'active' : '' %>"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a></li>

      <li class="sidebar-section">PARTIES</li>
      <li><a href="/customers" class="<%= page === 'customers' ? 'active' : '' %>"><i class="bi bi-people"></i><span>Customers</span></a></li>
      <li><a href="/vendors" class="<%= page === 'vendors' ? 'active' : '' %>"><i class="bi bi-truck"></i><span>Vendors</span></a></li>

      <li class="sidebar-section">INVENTORY</li>
      <li><a href="/products" class="<%= page === 'products' ? 'active' : '' %>"><i class="bi bi-box"></i><span>Products</span></a></li>
      <li><a href="/ratelist" class="<%= page === 'ratelist' ? 'active' : '' %>"><i class="bi bi-tags"></i><span>Rate List</span></a></li>
      <li><a href="/warehouses" class="<%= page === 'warehouses' ? 'active' : '' %>"><i class="bi bi-building"></i><span>Warehouses</span></a></li>
      <li><a href="/stock" class="<%= page === 'stock' ? 'active' : '' %>"><i class="bi bi-boxes"></i><span>Stock Adjust</span></a></li>

      <li class="sidebar-section">TRANSACTIONS</li>
      <li><a href="/orders" class="<%= page === 'orders' ? 'active' : '' %>"><i class="bi bi-cart"></i><span>Orders</span></a></li>
      <li><a href="/invoices" class="<%= page === 'invoices' ? 'active' : '' %>"><i class="bi bi-receipt"></i><span>Invoices</span></a></li>
      <li><a href="/purchases" class="<%= page === 'purchases' ? 'active' : '' %>"><i class="bi bi-bag"></i><span>Purchases</span></a></li>
      <li><a href="/creditnotes" class="<%= page === 'creditnotes' ? 'active' : '' %>"><i class="bi bi-file-earmark-minus"></i><span>Returns / Notes</span></a></li>
      <li><a href="/bilty" class="<%= page === 'bilty' ? 'active' : '' %>"><i class="bi bi-send"></i><span>Bilty</span></a></li>
      <li><a href="/breakage" class="<%= page === 'breakage' ? 'active' : '' %>"><i class="bi bi-exclamation-triangle"></i><span>Breakage</span></a></li>
      <li><a href="/expenses" class="<%= page === 'expenses' ? 'active' : '' %>"><i class="bi bi-wallet2"></i><span>Expenses</span></a></li>

      <li class="sidebar-section">PAYMENTS</li>
      <li><a href="/payments/receive" class="<%= page === 'payments-receive' ? 'active' : '' %>"><i class="bi bi-cash-coin"></i><span>Receive Payment</span></a></li>
      <li><a href="/payments/pay" class="<%= page === 'payments-pay' ? 'active' : '' %>"><i class="bi bi-cash-stack"></i><span>Pay Vendor</span></a></li>
      <li><a href="/bank" class="<%= page === 'bank' ? 'active' : '' %>"><i class="bi bi-bank"></i><span>Bank Accounts</span></a></li>

      <li class="sidebar-section">ACCOUNTS</li>
      <li><a href="/daybook" class="<%= page === 'daybook' ? 'active' : '' %>"><i class="bi bi-calendar-day"></i><span>Day Book</span></a></li>
      <li><a href="/journal" class="<%= page === 'journal' ? 'active' : '' %>"><i class="bi bi-journal-bookmark"></i><span>Journal Entry</span></a></li>
      <li><a href="/ledger" class="<%= page === 'ledger' ? 'active' : '' %>"><i class="bi bi-journal-text"></i><span>Ledger</span></a></li>
      <li><a href="/reports" class="<%= page === 'reports' ? 'active' : '' %>"><i class="bi bi-bar-chart"></i><span>Reports</span></a></li>

      <li class="sidebar-section">SETUP</li>
      <li><a href="/categories" class="<%= page === 'categories' ? 'active' : '' %>"><i class="bi bi-tags"></i><span>Categories</span></a></li>
      <li><a href="/importexport" class="<%= page === 'importexport' ? 'active' : '' %>"><i class="bi bi-arrow-left-right"></i><span>Import / Export</span></a></li>
      <li><a href="/settings" class="<%= page === 'settings' ? 'active' : '' %>"><i class="bi bi-gear"></i><span>Settings</span></a></li>
    </ul>
  </nav>

  <!-- Main Content -->
  <main class="main-content">
    <div class="topbar">
      <button class="btn btn-link sidebar-toggle" onclick="document.body.classList.toggle('sidebar-collapsed')">
        <i class="bi bi-list fs-4"></i>
      </button>
      <div class="topbar-right">
        <span class="text-muted"><i class="bi bi-calendar3"></i> <%= new Date().toLocaleDateString('en-PK', {weekday:'long', day:'2-digit', month:'short', year:'numeric'}) %></span>
      </div>
    </div>
    <div class="content-wrapper">
